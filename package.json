        "dotenv":          "^17.2.3",
        "express":         "^5.1.0",
        "lil-gui":         "^0.21.0",
        "nodemon":         "^3.1.10",
        "qrcode":          "^1.5.4",
        "socket.io":       "^4.8.1",
        "socket.io-client":"^4.8.1"
    },
    "devDependencies": {
        "@tailwindcss/cli":   "^4.1.16",
        "@tailwindcss/vite":  "^4.1.16",
        "concurrently":       "^9.1.2",
        "tailwindcss":        "^4.1.16",
        "vite":               "^7.1.10"
    }
