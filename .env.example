# Copy to .env and fill in your values

PORT=3000

# n8n — m_src calls this directly from the browser (fire-and-forget).
# Use /webhook-test/... while building in the n8n UI,
# switch to /webhook/... when you activate the workflow for production.
VITE_N8N_EVENT_URL=http://localhost:5678/webhook-test/user-event

# URL n8n should POST back to when it has finished processing.
# Add an HTTP Request node at the end of your n8n workflow pointing here.
# Body: { "room": "{{$json.room}}", "simulation": { ...params } }
SERVER_CALLBACK_URL=http://localhost:3000/n8n-sim-update

# Full URL to the m_src page — used to generate the QR code in the simulation.
# In production this should match wherever your server is reachable from the audience.
VITE_USER_URL=http://localhost:3000/m_src/

# Directory for cached images (served as random media trail placeholders)
SERVER_ASSETS_DIR=prev-images

# Optional: add extra CORS origins separated by comma
EXTRA_ORIGINS=
