# Copy to .env and fill in your values

PORT=3000

# Vite dev server port — Express redirects HTML page requests here in dev mode.
VITE_PORT=5173

# Exposed to the Vite client so sim.js / remote/main.js can connect to Express
# directly in dev (bypassing the Vite dev server proxy).
VITE_SERVER_PORT=3000

# ── n8n direct integration ────────────────────────────────────────────────────
# Base URL of your n8n instance (no trailing slash, no path).
# Used by both the browser sim (VITE_) and the server (N8N_BASE_URL).
# Leave blank to disable n8n entirely.

# Used by both the browser sim and the server (Node can read VITE_ vars too).
# Browser calls /webhook/heartbeat and /webhook/sim-event.
# Server calls /webhook/spectator on every spectator join/leave.
VITE_N8N_BASE_URL=

# Public base URL for the QR code.
#   QR code points to  $VITE_USER_URL/?s=<session>
#   Caddy handles routing the /?s= path to /remote/ internally.
#   Socket.IO uses VITE_SOCKET_URL separately (see below).
VITE_USER_URL=http://localhost:3000

# Socket.IO server origin used by the browser clients in production.
# Caddy must proxy /socket.io/* to Express so Socket.IO traffic reaches the server.
# In dev this is ignored — clients always connect directly to Express (VITE_SERVER_PORT).
# Leave blank to fall back to the page origin ('/'), which works when Caddy and Express
# share the same public hostname.
VITE_SOCKET_URL=https://api.stubfx.io

# Directory for cached images (served as random media trail placeholders)
SERVER_ASSETS_DIR=prev-images

# Optional: add extra CORS origins separated by comma
EXTRA_ORIGINS=

# Password for the config save endpoint (POST /simAss-config).
# Pass as ?password=<value> in the sim URL. Leave blank to disable saving.
PASSWORD=
