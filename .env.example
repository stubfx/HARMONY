# Copy to .env and fill in your values

PORT=3000

# Vite dev server port — Express redirects HTML page requests here in dev mode.
VITE_PORT=5173

# Exposed to the Vite client so sim.js / remote/main.js can connect to Express
# directly in dev (bypassing the Vite dev server proxy).
VITE_SERVER_PORT=3000

# ── Event routing ─────────────────────────────────────────────────────────────
# Controls how user events from /remote devices are forwarded.
#   direct  — event goes straight from the server socket to the simulation (default)
#   n8n     — event is POSTed to N8N_WEBHOOK_URL; n8n processes and calls /n8n-sim-update
RELAY_MODE=direct

# n8n webhook URL (only used when RELAY_MODE=n8n).
# Use /webhook-test/... while building in the n8n UI,
# switch to /webhook/...  when you activate the workflow for production.
N8N_WEBHOOK_URL=http://localhost:5678/webhook/user-event

# URL n8n should POST back to when it has finished processing.
# Add an HTTP Request node at the end of your n8n workflow pointing here.
# Body: { "room": "{{$json.room}}", "simulation": { ...params } }
SERVER_CALLBACK_URL=http://localhost:3000/n8n-sim-update

# Public base URL — two uses:
#   1. QR code points to  $VITE_USER_URL/remote/?s=<session>
#   2. Socket.IO client connects to $VITE_SOCKET_URL in production
# In production both should be the Caddy-fronted public origin (e.g. https://api.stubfx.io).
VITE_USER_URL=http://localhost:3000

# Socket.IO server origin used by the browser clients in production.
# Caddy must proxy /socket.io/* to Express so Socket.IO traffic reaches the server.
# In dev this is ignored — clients always connect directly to Express (VITE_SERVER_PORT).
# Leave blank to fall back to the page origin ('/'), which works when Caddy and Express
# share the same public hostname.
VITE_SOCKET_URL=https://api.stubfx.io

# Directory for cached images (served as random media trail placeholders)
SERVER_ASSETS_DIR=prev-images

# Optional: add extra CORS origins separated by comma
EXTRA_ORIGINS=
