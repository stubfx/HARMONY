# Copy to .env and fill in your values

PORT=3000

# n8n webhook base URL (no trailing slash, no /webhook path)
N8N_WEBHOOK_URL=http://localhost:5678/webhook

# Dev (no Caddy): Vite proxies /socket.io, /uuid, /rndImage → :3000
# For iOS / Caddy: set to https://localhost/ and https://localhost/m_src/
VITE_API_HOSTNAME=http://localhost:5173/
VITE_USER_URL=http://localhost:5173/m_src/

# Directory for cached images (served as random media trail placeholders)
SERVER_ASSETS_DIR=prev-images

# Optional: add extra CORS origins separated by comma
EXTRA_ORIGINS=
