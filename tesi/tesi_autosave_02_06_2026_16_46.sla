        <PAGEOBJECT XPOS="84.6666666666665" YPOS="5084.01700787402" OwnPage="15" ItemID="424771376" PTYPE="2" WIDTH="770.767034120735" HEIGHT="627.635275590552" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="0.2732" LOCALSCY="0.2732" LOCALX="-191.556857003416" LOCALY="221.997286942355" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" Pagenumber="0" PFILE="assets/bird_flock.png" PRFILE="Embedded sRGB built-in" IRENDER="0" EPROF="Embedded sRGB built-in" TransValue="0.95" path="M0 0 L770.767 0 L770.767 627.635 L0 627.635 L0 0 Z" copath="M0 0 L770.767 0 L770.767 627.635 L0 627.635 L0 0 Z" gXpos="84.6666666666665" gYpos="5084.01700787402" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1"/>
        <PAGEOBJECT XPOS="140.00062992126" YPOS="695.276535433071" OwnPage="1" ItemID="299092048" PTYPE="4" WIDTH="339.527559055118" HEIGHT="243.464566929134" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="2" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L339.528 0 L339.528 243.465 L0 243.465 L0 0 Z" copath="M0 0 L339.528 0 L339.528 243.465 L0 243.465 L0 0 Z" gXpos="140.00062992126" gYpos="695.276535433071" gWidth="0" gHeight="0" PSTYLE="section_title" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle PARENT="section_title"/>
                <ITEXT CH="Introduzione"/>
                <trail PARENT="section_title"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="140.00062992126" YPOS="967.087559055118" OwnPage="1" ItemID="299110224" PTYPE="4" WIDTH="339.527559055118" HEIGHT="243.464566929134" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="28.3464566929134" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L339.528 0 L339.528 243.465 L0 243.465 L0 0 Z" copath="M0 0 L339.528 0 L339.528 243.465 L0 243.465 L0 0 Z" gXpos="140.00062992126" gYpos="967.087559055118" gWidth="0" gHeight="0" PSTYLE="section_body" LAYER="0" NEXTITEM="348353744" BACKITEM="-1">
            <StoryText>
                <DefaultStyle PARENT="section_body"/>
                <ITEXT CH="C'è un verbo nuovo nel modo in cui parliamo dei sistemi computazionali. Prima si cercava su Google. Adesso si chiede a ChatGPT. Chiedere implica che dall'altra parte ci sia qualcuno in grado di capire, di interpretare, di rispondere nel senso pieno della parola. È una piccola cosa, ma dice molto su come stiamo ridefinendo il confine tra strumento e interlocutore."/>
                <para PARENT="section_body"/>
                <ITEXT CH="Eppure, guardando da vicino come funziona questa interazione, c'è qualcosa che non torna. Il formato è sempre lo stesso: io scrivo, il sistema risponde, io scrivo di nuovo. Un turno alla volta, in sequenza, come una corrispondenza per lettera accelerata. Il sistema non fa mai la prima mossa. Non si manifesta finché non viene chiamato. Vive in uno stato di attesa permanente, pronto a rispondere ma incapace di proporre."/>
                <para PARENT="section_body"/>
                <ITEXT CH="Questo crea una relazione strana. Gli attribuiamo qualcosa che somiglia a un pensiero. Eppure lo trattiamo come un servizio: lo convochiamo quando ne abbiamo bisogno, otteniamo quello che cercavamo, e poi la conversazione finisce. L'interazione è sempre privata e sempre orientata verso un risultato preciso. C'è poco spazio per quello che non è stato chiesto."/>
                <para PARENT="section_body"/>
                <ITEXT CH="Quello che mi ha incuriosito è capire cosa succederebbe se il sistema non aspettasse di essere interrogato, ma fosse già presente, già in movimento, già impegnato a fare qualcosa. A fare il primo passo nel momento in cui le persone entrano nella stanza, e a continuare a farlo che ci sia qualcuno o meno. Un sistema con un proprio ritmo già in corso, dentro cui ci si infila come si entra in una conversazione che è già iniziata, senza poterla portare dall'inizio. Si arriva tardi, e si sceglie se ascoltare o se dire qualcosa."/>
                <para PARENT="section_body"/>
                <ITEXT CH="Mi sono chiesto come sarebbe interagire con un sistema vivo, con un suo ritmo, che risponde al gruppo invece che al singolo, e che cambia forma in base a come quel gruppo si organizza."/>
                <para PARENT="section_body" KeepWithNext="0" KeepTogether="0"/>
                <ITEXT CH="Questo progetto nasce da quella domanda."/>
                <trail PARENT="section_subtitle"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="124.00062992126" YPOS="3116.37795275591" OwnPage="7" ItemID="300976032" PTYPE="4" WIDTH="515.275590551181" HEIGHT="16" FRTYPE="0" CLIPEDIT="0" ROT="270" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="2" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L515.276 0 L515.276 16 L0 16 L0 0 Z" copath="M0 0 L515.276 0 L515.276 16 L0 16 L0 0 Z" gXpos="124.00062992126" gYpos="3116.37795275591" gWidth="0" gHeight="0" PSTYLE="section_title" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle PARENT="section_title"/>
                <ITEXT CH="L'arte che risponde."/>
                <trail PARENT="section_title"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="161.228976377953" YPOS="2636.69291338583" OwnPage="7" ItemID="300220160" PTYPE="4" WIDTH="318.299212598425" HEIGHT="479.685039370082" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="28.3464566929134" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L318.299 0 L318.299 479.685 L0 479.685 L0 0 Z" copath="M0 0 L318.299 0 L318.299 479.685 L0 479.685 L0 0 Z" gXpos="161.228976377953" gYpos="2636.69291338583" gWidth="0" gHeight="0" PSTYLE="section_body" LAYER="0" NEXTITEM="304746432" BACKITEM="-1">
            <StoryText>
                <DefaultStyle PARENT="section_body" LINESPMode="0" ParagraphEffectOffset="0" ParagraphEffectIndent="0" DROP="0" Bullet="0" Numeration="0"/>
                <ITEXT CH="A metà del Novecento, l’arte smette di essere solo un oggetto da contemplare. Non è una rivoluzione annunciata da un manifesto, ma una tensione che emerge dalle pratiche, dalle domande e dalle frustrazioni degli artisti. La cornice non basta più. L’opera, chiusa in sé stessa, sembra incapace di dialogare con chi le sta davanti. La separazione tra osservatore e osservato diventa un limite da superare."/>
                <para PARENT="section_body"/>
                <ITEXT CH="La risposta è arrivata da direzioni diverse, con linguaggi diversi. Pittori che hanno smesso di dipingere, scultori che hanno cominciato a costruire ambienti, registi e coreografi che sono entrati nei musei. In quasi tutti i casi, la domanda era la stessa: cosa succede quando l'opera non è più un oggetto da guardare, ma un'esperienza da vivere?"/>
                <para PARENT="section_body"/>
                <ITEXT CH="Dalla contemplazione alla partecipazione"/>
                <para PARENT="section_subtitle"/>
                <ITEXT CH="Negli anni Sessanta, in Europa e negli Stati Uniti, una serie di movimenti ha cominciato "/>
                <para PARENT="section_body"/>
                <ITEXT CH="a mettere in discussione la separazione tra opera e pubblico. Il Groupe de Recherche d'Art Visuel, fondato a Parigi nel 1960, costruiva ambienti in cui il visitatore era chiamato a interagire fisicamente con gli elementi esposti: superfici instabili, luci che reagivano al movimento, strutture che mutavano sotto il peso o il tocco della mano. Non si trattava di arte decorativa né di intrattenimento. Era una critica alla passività dello spettatore, formulata attraverso l'esperienza diretta invece che attraverso il testo."/>
                <para PARENT="section_body"/>
                <ITEXT CH="Nello stesso periodo, Allan Kaprow negli Stati Uniti stava inventando una forma ancora più radicale di coinvolgimento. Gli Happenings erano eventi aperti, senza trama fissa, senza confine netto tra chi li organizzava e chi vi partecipava. Kaprow li immaginava come situazioni in cui un gruppo di persone, raggiunta una sala, un cortile o uno spazio industriale dismesso, eseguiva una serie di azioni semplici: spostare oggetti da un lato all'altro, attraversare la stanza in un certo ordine, ripetere un gesto a un segnale, accendere una luce, leggere una frase. L'importante era esserci e fare; non c'era una vera comprensione da raggiungere, e nemmeno un significato già scritto da decifrare. Il primo evento di questo tipo, *18 Happenings in 6 Parts*, si svolse alla Reuben Gallery di New York nel 1959: il pubblico, in piedi, riceveva istruzioni minime e diventava parte dell'azione, in alcuni casi senza capire del tutto se stesse guardando o agendo. L'opera non esisteva come oggetto: era la situazione, l'incontro, il tempo condiviso. Kaprow aveva capito qualcosa che sarebbe rimasto rilevante per decenni: che il corpo del pubblico, portato dentro uno spazio progettato, diventa esso stesso materiale dell'opera."/>
                <para PARENT="section_body"/>
                <ITEXT CH="&gt; **[IMG]** Fotografia di un Happening di Allan Kaprow (anni Sessanta): partecipanti in uno spazio non convenzionale, confine tra autore e pubblico dissolto."/>
                <para PARENT="section_body"/>
                <ITEXT CH="Quello che questi lavori condividevano era una ridefinizione del ruolo del visitatore: da testimone passivo a elemento attivo, anche inconsapevole. Il pubblico non &quot;fruiva&quot; l'opera nel senso tradizionale. La completava. E la completava in modo diverso ogni volta, perché ogni corpo porta con sé una storia e una decisione diversa."/>
                <para PARENT="section_body"/>
                <ITEXT CH="L'arte cinetica, nel frattempo, esplorava un'altra forma di partecipazione: più silenziosa, più individuale, ma ugualmente radicale nel suo implicare il corpo dello spettatore. Julio Le Parc costruiva strutture in movimento che rispondevano all'aria, alla luce, alla presenza fisica delle persone nello spazio. Nicolas Schöffer progettava torri cibernetiche che processavano dati ambientali per produrre luce e suono. In questi lavori, il sistema non aspetta il pubblico: è già in movimento. Il pubblico entra in qualcosa che ha già una vita propria."/>
                <para PARENT="section_body"/>
                <ITEXT CH="&gt; **[IMG]** Installazione di arte cinetica di Julio Le Parc o Nicolas Schöffer: elementi in movimento, luce che cambia in risposta alla presenza nello spazio."/>
                <para PARENT="section_body"/>
                <ITEXT CH="Questo cambio di paradigma ha richiesto un ripensamento profondo di cosa significa fare arte. La pratica si avvicinava all'architettura: si costruivano condizioni, percorsi, atmosfere, dentro cui qualcosa potesse accadere tra le persone e lo spazio. Quello che restava dell'opera, dopo che il pubblico se n'era andato, era il ricordo dell'esperienza che si era stati capaci di rendere possibile. Una traccia materiale, in molti casi, non c'era affatto."/>
                <para PARENT="section_body"/>
                <ITEXT CH="La macchina come interlocutore"/>
                <para PARENT="section_body"/>
                <ITEXT CH="Il passo successivo è stato portare la tecnologia dentro questa relazione, e darle un ruolo diverso da quello di sfondo o di strumento neutro: quello di presenza attiva. Qualcosa che percepisce, che risponde, che ha una sua logica."/>
                <para PARENT="section_body"/>
                <ITEXT CH="David Rokeby ha costruito *Very Nervous System* tra il 1986 e il 1990. Il sistema usava telecamere, computer e sintetizzatori per tradurre il movimento del corpo in suono in tempo reale. Chi entrava nello spazio scopriva che i propri gesti producevano effetti sonori: alzare un braccio, spostarsi verso sinistra, fermarsi. L'interfaccia era invisibile. Non c'erano controller, non c'erano istruzioni. C'era solo il proprio corpo, e la scoperta progressiva di come il sistema reagiva a esso. Come ha scritto lo stesso Rokeby, il sistema è «uno specchio che trasforma»: riflette il comportamento del visitatore, ma in una forma nuova, tradotta, non riconoscibile come semplice copia."/>
                <para PARENT="section_body"/>
                <ITEXT CH="&gt; **[IMG]** Fotografia dell'installazione *Very Nervous System* di David Rokeby: spazio vuoto con telecamere visibili, una persona in movimento che non tocca nulla."/>
                <para PARENT="section_body"/>
                <ITEXT CH="Rafael Lozano-Hemmer lavora su una scala diversa, spesso architettonica. Le sue installazioni usano la presenza delle persone come materiale: telecamere che riconoscono i volti, sensori che leggono il battito cardiaco, proiettori che modificano le facciate degli edifici in risposta al pubblico. In *Body Movies* (2001), le sagome del pubblico proiettate in scala gigantesca su una facciata urbana attivavano immagini nascoste alla luce troppo intensa. Il sistema non faceva nulla finché qualcuno non arrivava: aveva bisogno del corpo umano per completarsi."/>
                <para PARENT="section_body"/>
                <ITEXT CH="&gt; **[IMG]** *Body Movies* di Rafael Lozano-Hemmer, Rotterdam 2001: proiezioni di sagome umane di grandi dimensioni su una facciata urbana, attivate dalla presenza del pubblico."/>
                <para PARENT="section_body"/>
                <ITEXT CH="Questi lavori hanno stabilito qualcosa di importante: che la macchina può essere un interlocutore, non solo uno strumento. Che il sistema tecnologico può ascoltare, rispondere, ricordare. E che questa relazione, quando è costruita bene, produce un'esperienza che nessuna delle due parti avrebbe potuto generare da sola."/>
                <para PARENT="section_body"/>
                <ITEXT CH="Il collettivo come materiale"/>
                <para PARENT="section_body"/>
                <ITEXT CH="C'è una categoria di opere che porta questo principio ancora più avanti: opere che esistono solo grazie alla partecipazione simultanea di molte persone, e che producono qualcosa di visibile proprio perché le persone sono tante."/>
                <para PARENT="section_body"/>
                <ITEXT CH="Random International ha realizzato *Rain Room* nel 2012: uno spazio in cui piove continuamente, tranne dove si trova un visitatore. Sensori rilevano la posizione delle persone e bloccano la caduta dell'acqua attorno a loro. Il risultato è un'esperienza quasi magica: camminare sotto la pioggia senza bagnarsi. Ma l'opera funziona in modo completamente diverso quando è piena di gente: i coni di asciutto si moltiplicano, si sovrappongono, si muovono. Il collettivo produce una geometria che nessun individuo avrebbe potuto prevedere."/>
                <para PARENT="section_body"/>
                <ITEXT CH="&gt; **[IMG]** *Rain Room* di Random International, 2012: visitatori che camminano sotto la pioggia, le zone asciutte che si formano attorno a loro come invisibili bolle di protezione."/>
                <para PARENT="section_body"/>
                <ITEXT CH="teamLab costruisce ambienti digitali immersivi in cui le azioni dei visitatori modificano lo spazio in tempo reale. Fiori che sbocciano sotto i piedi, onde che si generano dal movimento, creature che reagiscono al tocco. L'obiettivo dichiarato del collettivo giapponese è creare opere in cui i confini tra l'opera stessa, il corpo del visitatore e l'ambiente circostante diventino indefiniti. Non si guarda un'installazione di teamLab: ci si trova dentro."/>
                <para PARENT="section_body"/>
                <ITEXT CH="&gt; **[IMG]** Installazione immersiva di teamLab: proiezioni di fiori o elementi naturali digitali che coprono pavimento e pareti, visitatori immersi nello spazio visivo."/>
                <para PARENT="section_body"/>
                <ITEXT CH="La differenza tra questi lavori e un'installazione interattiva ordinaria è sottile ma precisa. Hanno bisogno del pubblico per esistere nel senso pieno. Senza corpi, senza movimento, senza la presenza simultanea di più persone, non c'è opera. C'è solo un sistema in attesa."/>
                <para PARENT="section_body"/>
                <ITEXT CH="Il mistero come scelta estetica"/>
                <para PARENT="section_body"/>
                <ITEXT CH="C'è qualcosa che molte delle opere appena descritte condividono, e che vale la pena nominare esplicitamente: nessuna di esse si spiega. Non c'è un cartello che illustra come funziona il sistema, non c'è una guida che insegna i gesti giusti. Il visitatore è lasciato a scoprire la logica da solo, attraverso il proprio corpo e la propria curiosità."/>
                <para PARENT="section_body"/>
                <ITEXT CH="Questa opacità è una scelta estetica precisa. Cambia il tipo di attenzione che il visitatore può portare nello spazio: quando si entra in un luogo e non si capisce immediatamente cosa sta succedendo, ci si rallenta, si osserva, si tenta una mossa per vedere cosa risponde. Il corpo diventa uno strumento di conoscenza, e l'esperienza acquista una qualità di scoperta che un cartello esplicativo cancellerebbe in due secondi."/>
                <para PARENT="section_body"/>
                <ITEXT CH="James Turrell costruisce stanze di luce in cui è difficile capire dove finisce il muro e dove comincia l'aria. L'occhio continua a cercare un bordo, una profondità, una superficie. Non la trova. Questa impossibilità di risolvere la percezione produce un'esperienza che non ha equivalenti nel linguaggio: non si può descrivere quello che si vede, si può solo starci."/>
                <para PARENT="section_body"/>
                <ITEXT CH="&gt; **[IMG]** Opera di James Turrell (es. *Ganzfeld* o *Skyspace*): spazio di luce in cui i confini tra le superfici e lo spazio luminoso diventano impossibili da distinguere."/>
                <para PARENT="section_body"/>
                <ITEXT CH="Non tutti i progetti di questo tipo vogliono essere così radicali. Ma quasi tutti condividono l'idea che la chiarezza immediata non sia sempre una virtù. Che lasciare una domanda aperta, una logica da scoprire, un meccanismo da intuire, possa essere una forma di rispetto verso il pubblico: un invito a partecipare davvero, invece di seguire istruzioni."/>
                <para PARENT="section_body"/>
                <ITEXT CH="È una posizione che questo progetto fa propria. Niente spiega come funziona il sistema. Si scopre usandolo."/>
                <para PARENT="section_body"/>
                <ITEXT CH="Ma cosa rende un sistema capace di rispondere a molte persone insieme, in modo distribuito, senza un centro che governi? Una logica diversa da quella di un motore centralizzato. Una logica in cui ogni elemento del sistema decide solo per sé, ascolta solo i suoi vicini più prossimi, e ciò nonostante il sistema nel suo insieme produce un comportamento unitario, riconoscibile dall'esterno come un'unica forma in movimento. Il capitolo che segue riguarda proprio questa logica: il modo in cui l'intelligenza collettiva emerge senza che nessuno la pianifichi."/>
                <para PARENT="section_body"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="559.528188976378" YPOS="2601.10236220472" OwnPage="8" ItemID="304746432" PTYPE="4" WIDTH="339.527559055118" HEIGHT="515.275590551183" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" ANNAME="body_2col" TEXTFLOWMODE="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="28.3464566929134" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L339.528 0 L339.528 515.276 L0 515.276 L0 0 Z" copath="M0 0 L339.528 0 L339.528 515.276 L0 515.276 L0 0 Z" gXpos="-462.97392895888" gYpos="2530.92735433071" gWidth="0" gHeight="0" PSTYLE="section_body" LAYER="0" NEXTITEM="305987136" BACKITEM="300220160"/>
        <PAGEOBJECT XPOS="140.00062992126" YPOS="3236.37763779527" OwnPage="9" ItemID="305987136" PTYPE="4" WIDTH="339.527559055118" HEIGHT="515.275590551184" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" ANNAME="Copy of body_2col" TEXTFLOWMODE="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="28.3464566929134" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L339.528 0 L339.528 515.276 L0 515.276 L0 0 Z" copath="M0 0 L339.528 0 L339.528 515.276 L0 515.276 L0 0 Z" gXpos="-489.44868031496" gYpos="2096.6475265092" gWidth="0" gHeight="0" PSTYLE="section_body" LAYER="0" NEXTITEM="304767216" BACKITEM="304746432"/>
        <PAGEOBJECT XPOS="559.528188976378" YPOS="3236.37763779527" OwnPage="10" ItemID="304767216" PTYPE="4" WIDTH="339.527559055118" HEIGHT="515.275590551184" FRTYPE="0" CLIPEDIT="1" PWIDTH="1" PLINEART="1" ANNAME="Copy of body_2col (2)" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="28.3464566929134" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L339.528 0 L339.528 515.276 L0 515.276 L0 0 Z" copath="M0 0 L339.527 0 L339.527 515.276 L0 515.276 L0 0 Z" gXpos="-618.564480139982" gYpos="2191.75863762031" gWidth="0" gHeight="0" PSTYLE="section_body" LAYER="0" NEXTITEM="354271232" BACKITEM="305987136"/>
        <PAGEOBJECT XPOS="140.00062992126" YPOS="5777.47874015748" OwnPage="17" ItemID="311117024" PTYPE="4" WIDTH="339.527559055118" HEIGHT="139.527559055123" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="2" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L339.528 0 L339.528 139.528 L0 139.528 L0 0 Z" copath="M0 0 L339.528 0 L339.528 139.528 L0 139.528 L0 0 Z" gXpos="140.00062992126" gYpos="4013.70177007874" gWidth="0" gHeight="0" PSTYLE="section_title" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle PARENT="section_title"/>
                <ITEXT CH="La logica dello sciame"/>
                <trail PARENT="section_title"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="140.00062992126" YPOS="5945.35275590551" OwnPage="17" ItemID="311511936" PTYPE="4" WIDTH="339.527559055118" HEIGHT="347.401574803149" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="28.3464566929134" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L339.528 0 L339.528 347.402 L0 347.402 L0 0 Z" copath="M0 0 L339.528 0 L339.528 347.402 L0 347.402 L0 0 Z" gXpos="140.00062992126" gYpos="4181.57578582677" gWidth="0" gHeight="0" PSTYLE="section_body" LAYER="0" NEXTITEM="311571216" BACKITEM="-1">
            <StoryText>
                <DefaultStyle PARENT="section_body" LINESPMode="0" ParagraphEffectOffset="0" ParagraphEffectIndent="0" DROP="0" Bullet="0" Numeration="0"/>
                <ITEXT CH="C'è qualcosa di difficile da spiegare nella sensazione che si prova guardando uno stormo di storni muoversi nel cielo al tramonto. Non è soltanto bellezza visiva: è la percezione che quella forma stia pensando. Che abbia intenzioni. Che sappia dove vuole andare."/>
                <para/>
                <ITEXT CH="Non lo sa. O almeno, non nel senso in cui lo sappiamo noi."/>
                <para/>
                <ITEXT CH="In natura"/>
                <para PARENT="section_subtitle"/>
                <ITEXT CH="La murmuration degli storni è forse il fenomeno collettivo più fotografato e studiato degli ultimi decenni. Migliaia di uccelli, a volte centinaia di migliaia, si muovono insieme come se fossero un unico organismo fluido: si espandono, si contraggono, girano, si dividono e si ricompongono, senza che nessuno dia ordini. La ricerca condotta da Andrea Cavagna e dai suoi colleghi all'Università di Roma ha dimostrato che ogni storno calibra la propria traiettoria sulla base di sette vicini prossimi, non di più. Avvicinati abbastanza, mantieni la velocità, evita le collisioni. Tre istruzioni, senza eccezioni. Il risultato è quello che vediamo nel cielo."/>
                <para/>
                <ITEXT CH="&gt; **[IMG]** Fotografia di una murmuration di storni al tramonto: la forma collettiva che cambia nel cielo, nessun punto di partenza riconoscibile."/>
                <para/>
                <ITEXT CH="Le colonie di formiche funzionano secondo lo stesso principio, declinato in modo diverso. Una formica singola è un animale quasi cieco, con una memoria brevissima e un repertorio comportamentale molto limitato. Eppure una colonia trova i percorsi più brevi tra il nido e il cibo, regola la temperatura interna, gestisce i propri cadaveri, si difende dagli intrusi. Lo fa attraverso la chimica: le feromoni lasciate da ogni formica modificano il comportamento di quelle che vengono dopo. L'intelligenza non risiede in nessuna formica. Risiede nel sistema di tracce che le formiche producono e lasciano nell'ambiente."/>
                <para/>
                <ITEXT CH="&gt; **[IMG]** Colonia di formiche fotografata dall'alto: percorsi convergenti verso una fonte di cibo, organizzazione senza centro visibile."/>
                <para/>
                <ITEXT CH="Il Physarum polycephalum porta questo principio al suo estremo più sorprendente. È un organismo che vive in una zona grigia della biologia: a metà tra un animale e una pianta, in realtà nessuno dei due. Un micelio, una massa unicellulare di colore giallo brillante che si espande lentamente attraverso superfici umide in cerca di nutrimento. Non possiede neuroni, e nemmeno una struttura che assomigli a un cervello o a un organo decisionale. Eppure, messo di fronte a fonti di cibo distribuite nello spazio, trova invariabilmente il percorso più efficiente per collegarle. In uno studio pubblicato su *Science* nel 2010, i ricercatori Atsushi Tero e colleghi hanno replicato la disposizione geografica delle principali città dell'area metropolitana di Tokyo usando frammenti di nutrimento, e hanno lasciato che il Physarum crescesse tra di loro. In poche ore, il micelio aveva prodotto una rete di connessioni quasi identica alla rete ferroviaria reale, costruita da ingegneri nel corso di decenni di pianificazione. Come concludono gli autori dello studio: «The Physarum network shows characteristics of good transport network design, namely high efficiency, low cost, and resilience against failures.»"/>
                <para/>
                <ITEXT CH="&gt; **[IMG]** Il Physarum polycephalum che cresce su un piano con fonti di cibo posizionate come le città dell'area di Tokyo: la rete del micelio a confronto con la mappa ferroviaria reale."/>
                <para/>
                <ITEXT CH="Storni, formiche, Physarum. Tre sistemi che non si somigliano quasi per niente, eppure condividono la stessa struttura profonda: nessun coordinamento centrale, nessun piano complessivo, nessun elemento che veda più degli altri. Il comportamento globale emerge da interazioni locali ripetute milioni di volte."/>
                <para/>
                <ITEXT CH="Le regole semplici"/>
                <para PARENT="section_subtitle"/>
                <ITEXT CH="&gt; *«Il tutto è più della somma delle sue parti.»*"/>
                <para/>
                <ITEXT CH="&gt; Aristotele, *Metafisica*"/>
                <para/>
                <ITEXT CH="Aristotele non stava parlando di storni. Ma la frase descrive esattamente quello che succede in un sistema collettivo: a un certo livello di organizzazione, appare qualcosa che non era presente negli elementi singoli. La biologia ha un nome per questo fenomeno: emergenza."/>
                <para/>
                <ITEXT CH="Un comportamento è emergente quando compare a un livello superiore rispetto alle componenti che lo generano, senza che nessuna di quelle componenti lo contenesse già. Non è magia. È una proprietà strutturale dei sistemi complessi, studiata con strumenti matematici e computazionali da almeno quarant'anni. Resta però controintuitiva: siamo abituati a pensare che la sofisticazione richieda una mente sofisticata. Quando vediamo lo stormo curvare all'unisono, cerchiamo istintivamente il leader, il punto di partenza, la volontà che ha deciso la forma. Non c'è."/>
                <para/>
                <ITEXT CH="Il concetto di agente autonomo descrive l'unità base di questi sistemi: un'entità che percepisce l'ambiente locale, segue un insieme di regole semplici, e reagisce di conseguenza, senza ricevere istruzioni dall'esterno e senza avere una visione d'insieme. Ogni agente è, per definizione, parziale. Vede una piccola porzione del mondo, agisce su quella porzione, produce effetti che diventano parte dell'ambiente che altri agenti percepiranno. Il sistema è la somma di tutte queste azioni parziali, ma produce qualcosa che nessuna azione singola avrebbe potuto produrre."/>
                <para/>
                <ITEXT CH="&gt; **[IMG]** Diagramma delle tre regole del modello Boids (separazione, allineamento, coesione): ogni agente e il suo campo di percezione locale, senza visione globale."/>
                <para/>
                <ITEXT CH="Il paradosso dell'intelligenza distribuita sta proprio qui: il sistema si comporta come se qualcuno lo stesse guidando, ma non c'è nessuno che guida. La forma nasce dalle relazioni, non dagli elementi. E il fatto che questa forma possa essere bella, funzionale, o sorprendente non cambia la natura di ciò che la genera."/>
                <para/>
                <ITEXT CH="Dallo sciame biologico a quello digitale"/>
                <para/>
                <ITEXT CH="Nel 1987, l'informatico Craig Reynolds presentò al SIGGRAPH, la principale conferenza internazionale di computer grafica, un sistema di simulazione che aveva chiamato Boids. L'obiettivo era replicare il comportamento degli storni in un ambiente digitale. Reynolds aveva identificato tre regole fondamentali che ogni agente avrebbe dovuto seguire: separazione (mantieni una distanza minima dai tuoi vicini per evitare collisioni), allineamento (orienta la tua direzione verso la media di quella dei vicini), coesione (muoviti verso il centro del gruppo locale). Nessuna regola globale. Nessuna mappa dell'intero sistema."/>
                <para/>
                <ITEXT CH="Il risultato fu inatteso anche per chi lo aveva costruito. I Boids si dividevano attorno agli ostacoli e si riunivano dall'altra parte. Oscillavano, formavano code, si separavano e si ricompattavano. Reynolds aveva scritto tre regole: il sistema ne aveva esibite molte di più, tutte emergenti, nessuna programmata. Come osservò lui stesso, il sistema aveva prodotto «the lifelike quality of self-organization» a partire da meccanismi che, presi singolarmente, erano quasi banali."/>
                <para/>
                <ITEXT CH="&gt; **[IMG]** Visualizzazione del modello Boids: agenti in movimento con le loro direzioni individuali visibili, che formano un flusso collettivo riconoscibile."/>
                <para/>
                <ITEXT CH="Da quel momento, i principi dello sciame sono diventati uno strumento computazionale applicato in contesti molto diversi. Gli algoritmi ispirati alle colonie di formiche, noti come *Ant Colony Optimization*, vengono usati per risolvere problemi di routing nelle reti di comunicazione e nella logistica. Il comportamento del Physarum ha ispirato sistemi di ottimizzazione topologica per la progettazione di infrastrutture. Le simulazioni di storni vengono usate per modellare l'evacuazione delle folle in ambienti urbani, per animare masse di personaggi nei film, per generare effetti visivi generativi nell'arte digitale."/>
                <para/>
                <ITEXT CH="In tutti questi casi, la simulazione svolge due funzioni diverse. È uno strumento di analisi: costruire un sistema che si comporta come quello reale permette di isolare le regole che lo governano. Ed è uno strumento creativo: le stesse logiche che spiegano il comportamento degli storni possono generare qualcosa che non sarebbe nato da una mente sola. Qualcosa che sorprende anche chi lo ha costruito."/>
                <para/>
                <ITEXT CH="Questo progetto appartiene alla seconda categoria. Usa la logica dello sciame come strumento di costruzione, senza pretesa di fedeltà biologica: l'obiettivo è la qualità percettiva, la sensazione di trovarsi davanti a un organismo invece che a un programma."/>
                <para/>
                <ITEXT CH="Lo sciame come metafora"/>
                <para PARENT="section_subtitle"/>
                <ITEXT CH="C'è un'ultima cosa che i sistemi collettivi rivelano, e riguarda noi."/>
                <para/>
                <ITEXT CH="Usare lo sciame come modello per parlare di persone è una scelta con implicazioni precise. Gli esseri umani si aggregano, si influenzano reciprocamente, producono comportamenti collettivi che nessuno ha pianificato. Le mode, i movimenti, le ondate di panico o di entusiasmo in una folla. Il modo in cui un pubblico a teatro smette di essere una somma di individui e diventa qualcosa di unitario, con un'unica attenzione, una risposta emotiva condivisa che nessuno ha deciso ma tutti stanno vivendo."/>
                <para/>
                <ITEXT CH="&gt; **[IMG]** Fotografia di una folla o di un pubblico vista dall'alto: la struttura collettiva visibile, i singoli individui distinguibili ma parte di un pattern più grande."/>
                <para/>
                <ITEXT CH="Queste dinamiche non sono belle o brutte in sé. Sono reali. E il fatto che funzionino secondo principi simili a quelli degli storni o delle colonie di formiche dice qualcosa di interessante: l'intelligenza collettiva emerge in qualsiasi contesto in cui agenti sufficientemente semplici si trovano abbastanza vicini e abbastanza a lungo. I sistemi biologici complessi sono solo uno di quei contesti."/>
                <para/>
                <ITEXT CH="Steven Johnson, nel suo saggio *Emergence* (2001), osserva che le città funzionano in modo analogo alle colonie di formiche: nessuno progetta dall'alto i quartieri creativi, i mercati, le vie del commercio. Emergono da migliaia di decisioni individuali che si accumulano e si rinforzano a vicenda. La differenza con una colonia di formiche è che gli esseri umani, a differenza delle formiche, sanno di farne parte. Possono osservare il sistema di cui sono elementi. Possono persino scegliere di comportarsi diversamente una volta che ne riconoscono la logica."/>
                <para/>
                <ITEXT CH="È questa consapevolezza il punto che interessa questo progetto: cosa succede quando le persone sanno di comportarsi come uno sciame. Quando qualcuno mostra loro che il loro comportamento collettivo ha una forma, che quella forma è visibile in tempo reale, che si può osservare mentre si contribuisce a crearla."/>
                <para/>
                <ITEXT CH="Cosa cambia, nell'esperienza di far parte di qualcosa, quando si riesce a vederlo dall'interno?"/>
                <para/>
                <ITEXT CH="Capire la logica di uno sciame è una cosa. Diventarne parte è un'altra. Il capitolo che segue riguarda il punto di contatto tra la persona e il sistema: il corpo, il gesto, e il dispositivo che in questo progetto li mette in relazione."/>
                <para/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="559.528188976378" YPOS="5777.47874015748" OwnPage="18" ItemID="311571216" PTYPE="4" WIDTH="339.527559055118" HEIGHT="515.275590551185" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" ANNAME="Copy of body_2col (3)" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="28.3464566929134" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L339.528 0 L339.528 515.276 L0 515.276 L0 0 Z" copath="M0 0 L339.528 0 L339.528 515.276 L0 515.276 L0 0 Z" gXpos="-713.476676815398" gYpos="3787.08196220473" gWidth="0" gHeight="0" PSTYLE="section_body" LAYER="0" NEXTITEM="312771328" BACKITEM="311511936"/>
        <PAGEOBJECT XPOS="140.00062992126" YPOS="6412.75401574804" OwnPage="19" ItemID="312771328" PTYPE="4" WIDTH="339.527559055118" HEIGHT="515.275590551177" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" ANNAME="Copy of body_2col (4)" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="28.3464566929134" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L339.528 0 L339.528 515.276 L0 515.276 L0 0 Z" copath="M0 0 L339.528 0 L339.528 515.276 L0 515.276 L0 0 Z" gXpos="-485.336133683289" gYpos="3538.48835590552" gWidth="0" gHeight="0" PSTYLE="section_body" LAYER="0" NEXTITEM="311563264" BACKITEM="311571216"/>
        <PAGEOBJECT XPOS="559.528188976378" YPOS="6412.75401574804" OwnPage="20" ItemID="311563264" PTYPE="4" WIDTH="339.527559055118" HEIGHT="515.275590551177" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" ANNAME="Copy of body_2col (5)" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="28.3464566929134" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L339.528 0 L339.528 515.276 L0 515.276 L0 0 Z" copath="M0 0 L339.528 0 L339.528 515.276 L0 515.276 L0 0 Z" gXpos="-594.365565704287" gYpos="3534.35723779528" gWidth="0" gHeight="0" PSTYLE="section_body" LAYER="0" NEXTITEM="-1" BACKITEM="312771328"/>
        <PAGEOBJECT XPOS="140.00062992126" YPOS="7683.30456692914" OwnPage="23" ItemID="316467888" PTYPE="4" WIDTH="339.527559055118" HEIGHT="139.527559055115" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="2" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L339.528 0 L339.528 139.528 L0 139.528 L0 0 Z" copath="M0 0 L339.528 0 L339.528 139.528 L0 139.528 L0 0 Z" gXpos="735.27502992126" gYpos="4155.75062677165" gWidth="0" gHeight="0" PSTYLE="section_title" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle PARENT="section_title"/>
                <ITEXT CH="Il corpo come interfaccia"/>
                <trail PARENT="section_title"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="140.00062992126" YPOS="7851.17858267717" OwnPage="23" ItemID="317813376" PTYPE="4" WIDTH="339.527559055118" HEIGHT="347.40157480315" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="28.3464566929134" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L339.528 0 L339.528 347.402 L0 347.402 L0 0 Z" copath="M0 0 L339.528 0 L339.528 347.402 L0 347.402 L0 0 Z" gXpos="735.27502992126" gYpos="4323.62464251968" gWidth="0" gHeight="0" PSTYLE="section_body" LAYER="0" NEXTITEM="354249520" BACKITEM="-1">
            <StoryText>
                <DefaultStyle PARENT="section_body" LINESPMode="0" ParagraphEffectOffset="0" ParagraphEffectIndent="0" DROP="0" Bullet="0" Numeration="0"/>
                <ITEXT CH="La mano è stata la prima interfaccia. Prima delle parole, prima della scrittura, prima di qualsiasi strumento, il corpo umano ha imparato a comunicare con il mondo attraverso il gesto, la postura, il contatto. Ogni tecnologia che è venuta dopo non ha sostituito questa relazione: l'ha mediata, trasformata, spostata su nuovi oggetti."/>
                <para/>
                <ITEXT CH="Lo smartphone è l'ultimo di questi oggetti, e forse il più strano: uno schermo di vetro che risponde al tocco, che legge l'inclinazione del corpo, che trasmette la posizione nello spazio. In questo progetto, quello schermo diventa qualcosa di diverso da quello per cui è stato progettato. Smette di essere un portale verso un mondo privato e diventa l'estensione del proprio corpo in uno spazio collettivo."/>
                <para/>
                <ITEXT CH="Il gesto prima delle parole"/>
                <para PARENT="section_subtitle"/>
                <ITEXT CH="Il gesto è più antico del linguaggio verbale. Gli studi sull'acquisizione del linguaggio nei bambini mostrano che i gesti di indicazione, di richiesta, di condivisione dell'attenzione precedono le prime parole di mesi. Più in generale, le scienze cognitive hanno stabilito da tempo che gran parte della comunicazione umana avviene attraverso il corpo: la postura, la distanza, il contatto, la direzione dello sguardo. Le parole sono una sovrastruttura costruita sopra un sistema più antico."/>
                <para/>
                <ITEXT CH="Paul Dourish, nel libro *Where the Action Is* (2001), ha sviluppato il concetto di &quot;interazione incarnata&quot;: l'idea che le tecnologie più efficaci siano quelle che si appoggiano sulla competenza corporea già acquisita, invece di richiedere l'apprendimento di nuove astrazioni. Toccare non si impara. È un gesto che il corpo conosce già, prima ancora del linguaggio. Un'interfaccia che usa il tocco come linguaggio primario attinge a un repertorio motorio che il sistema nervoso ha avuto centinaia di migliaia di anni per automatizzare: niente da memorizzare, niente da decifrare. Si poggia il dito, e qualcosa risponde."/>
                <para/>
                <ITEXT CH="&gt; **[IMG]** Studio fotografico di mani che interagiscono con una superficie tattile: gesti naturali di pressione, scorrimento, rotazione, che precedono qualsiasi istruzione."/>
                <para/>
                <ITEXT CH="Quando il gesto diventa dato, però, qualcosa cambia. Toccare un'altra persona e toccare uno schermo sono atti fisicamente simili ma semanticamente molto diversi. Il gesto codificato in un sistema digitale perde alcune delle sue sfumature, la pressione variabile, il calore, la continuità organica del contatto, e ne acquista altre: diventa trasmissibile, registrabile, replicabile. In questo progetto, il gesto del dito su un joystick virtuale diventa un impulso che sposta migliaia di particelle su uno schermo grande. La perdita è reale: il calore della mano sull'altra mano non è trasmissibile, e nessuno lo confonderebbe con un cursore. Il guadagno è anche reale: un dito su un vetro può smuovere migliaia di entità simultaneamente, e farsi sentire in un punto della stanza dove la mano fisica non potrebbe arrivare."/>
                <para/>
                <ITEXT CH="Lo smartphone come strumento"/>
                <para PARENT="section_subtitle"/>
                <ITEXT CH="Quando si pensa a un controller per un sistema interattivo, la prima cosa che viene in mente è spesso un oggetto costruito apposta: un joystick fisico, un guanto sensoriale, un dispositivo dedicato. Questi strumenti hanno senso in certi contesti. Ma richiedono che le persone li imparino, li indossino, li accettino come mediatori tra sé e il sistema."/>
                <para/>
                <ITEXT CH="Lo smartphone non richiede nulla di tutto questo. È già in tasca. È già acceso. Le sue interfacce fondamentali, lo schermo touchscreen, l'accelerometro, il giroscopio, sono diventate familiari in pochi anni a quasi tutti gli adulti. Usarlo come controller fa leva su qualcosa che è già lì: nessun oggetto da distribuire al pubblico, nessun pulsante da spiegare, nessun rito di iniziazione. Lo si pesca dalla tasca e si comincia."/>
                <para/>
                <ITEXT CH="&gt; **[IMG]** Schermata dell'interfaccia controller su smartphone: joystick virtuale, selettore colore, sfondo scuro, interfaccia minimale del progetto."/>
                <para/>
                <ITEXT CH="In questo progetto, lo smartphone cambia di status nel momento in cui si scansiona il codice QR. Smette di essere un oggetto personale, il mio telefono, con le mie app, la mia musica, le mie fotografie, e diventa un dispositivo collettivo. Il colore che si sceglie entra nel sistema insieme ai colori di tutti gli altri. Il gesto che si fa non muove solo le proprie particelle: partecipa al movimento complessivo dello sciame. Questa trasformazione avviene senza che nessuno la annunci. Si scopre mentre accade."/>
                <para/>
                <ITEXT CH="C'è qualcosa di significativo nel fatto che un oggetto così privato, così personale nel suo uso ordinario, possa diventare il punto di accesso a uno spazio comune. Il telefono in tasca è l'archivio della vita di una persona: contatti, foto, conversazioni. Lo stesso oggetto, in questo contesto, diventa un canale verso qualcosa che appartiene a tutti."/>
                <para/>
                <ITEXT CH="Essere presenti a distanza"/>
                <para PARENT="section_subtitle"/>
                <ITEXT CH="Mark Weiser, nel suo saggio fondamentale *The Computer for the 21st Century* (1991), immaginava un futuro in cui la tecnologia sarebbe diventata così integrata nell'ambiente da sparire alla percezione consapevole. «Le tecnologie più profonde», scriveva, «sono quelle che scompaiono. Si intrecciano nella trama della vita quotidiana finché non si distinguono da essa.» Weiser chiamava questa visione *ubiquitous computing*: il calcolo ovunque, invisibile, parte dell'ambiente."/>
                <para/>
                <ITEXT CH="Quello che Weiser descriveva come una promessa del futuro, in molti contesti è già realtà. Lo smartphone è un dispositivo di presenza ubiqua: accompagna il corpo, registra la posizione, trasmette dati in continuazione. In questo progetto, questa caratteristica viene usata in modo deliberato: il telefono è il punto di contatto tra il corpo fisico della persona, seduta in una sala, e il sistema digitale proiettato sullo schermo grande."/>
                <para/>
                <ITEXT CH="&gt; **[IMG]** Fotografia di una persona che guarda il telefono mentre, sullo schermo in background, le particelle si muovono in risposta al suo input: la connessione tra il piccolo e il grande."/>
                <para/>
                <ITEXT CH="Questa forma di presenza mediata ha qualcosa di peculiare. Il corpo della persona non è direttamente visibile nel sistema: non c'è un avatar, non c'è una telecamera che riprende chi partecipa. Quello che c'è è un colore, un vettore di movimento, un impulso nel flusso collettivo. La persona è presente nello sciame, ma non è riconoscibile come tale. Esiste come effetto, non come immagine."/>
                <para/>
                <ITEXT CH="Questo tipo di presenza, parziale e tradotta, ha dei precedenti interessanti. La voce al telefono è presenza senza corpo. Il testo in una chat è presenza senza voce. Qui la presenza è ancora più astratta: è un colore, una direzione, una piccola perturbazione in un sistema complesso. Eppure è reale. Qualcuno la sta producendo, in questo momento, con la mano."/>
                <para/>
                <ITEXT CH="L'individuo nel gruppo"/>
                <para PARENT="section_subtitle"/>
                <ITEXT CH="C'è un momento preciso nell'esperienza di questo progetto in cui qualcosa cambia: il momento in cui si realizza che non si è soli. Che le altre particelle sullo schermo hanno qualcuno dietro, un altro telefono, un'altra mano, un'altra persona seduta nella stessa sala. Che quello che sembra un sistema automatico è in realtà un sistema collettivo, abitato."/>
                <para/>
                <ITEXT CH="Questa realizzazione modifica il modo in cui si agisce. Si comincia a cercare gli altri nel flusso, a interpretare i loro movimenti, a rispondere a ciò che fanno. Lo sciame smette di essere uno sfondo e diventa una conversazione."/>
                <para/>
                <ITEXT CH="&gt; **[IMG]** Screenshot che mostra più colori distinti mescolati nel flusso delle particelle: la traccia visibile della presenza simultanea di più partecipanti, ognuno riconoscibile dalla propria tinta."/>
                <para/>
                <ITEXT CH="L'anonimato, in questo contesto, è una condizione che permette una libertà particolare: si può muovere lo sciame in qualsiasi direzione, scegliere qualsiasi colore, seguire un impulso senza dover rendere conto a nessuno. Nessun nome è visibile, nessun punteggio sta tenendo il conto, nessuna metrica racconterà poi quanto bene si è partecipato. Questa libertà produce spesso comportamenti inaspettati: alcuni esplorano i bordi dello schermo, altri sembrano cercare di coordinarsi con il vicino di posto, altri ancora si siedono fermi e guardano cosa fanno gli altri, come se il sistema fosse qualcosa da osservare piuttosto che qualcosa da usare."/>
                <para/>
                <ITEXT CH="Il colore personale rimane visibile nello sciame anche quando ci sono molti partecipanti. Si mescola, si attenua, cambia in relazione agli altri. Ma c'è. È la traccia di una presenza individuale all'interno di un corpo collettivo. Questa coesistenza tra il singolo e il gruppo non è risolta, non approda a nessun equilibrio stabile: oscilla, come lo sciame stesso, tra la coesione e la dispersione. Ed è proprio in questa oscillazione che l'esperienza diventa interessante da abitare."/>
                <para/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="140.00062992126" YPOS="11027.5549606299" OwnPage="33" ItemID="317864464" PTYPE="4" WIDTH="339.527559055118" HEIGHT="347.40157480315" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="28.3464566929134" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L339.528 0 L339.528 347.402 L0 347.402 L0 0 Z" copath="M0 0 L339.528 0 L339.528 347.402 L0 347.402 L0 0 Z" gXpos="735.27502992126" gYpos="6618.11253543307" gWidth="0" gHeight="0" PSTYLE="section_body" LAYER="0" NEXTITEM="354366192" BACKITEM="-1">
            <StoryText>
                <DefaultStyle PARENT="section_body" LINESPMode="0" ParagraphEffectOffset="0" ParagraphEffectIndent="0" DROP="0" Bullet="0" Numeration="0"/>
                <ITEXT CH="Ogni progetto comincia da una distinzione. Nel caso di questo, la distinzione era semplice da enunciare e difficile da costruire: uno schermo mostra qualcosa, un sistema è qualcosa."/>
                <para/>
                <ITEXT CH="La differenza sembra sottile. In pratica cambia tutto."/>
                <para/>
                <ITEXT CH="Un organismo, non uno schermo"/>
                <para PARENT="section_subtitle"/>
                <ITEXT CH="Uno schermo mostra. Può mostrare qualsiasi cosa: un film, una grafica, un dato in tempo reale. La relazione tra lo schermo e il suo contenuto è di contenitore e contenuto. Lo schermo potrebbe mostrare qualcos'altro domani, senza cambiare natura."/>
                <para/>
                <ITEXT CH="Un organismo ha una logica propria. Si comporta in un certo modo perché è fatto in un certo modo. Il suo comportamento è interno, e si manifesta dall'esterno. La differenza tra mostrare e essere è ontologica: lo schermo cambia natura ogni volta che si cambia il file che gli si proietta sopra, l'organismo no, perché la sua identità coincide con il modo in cui i suoi elementi si influenzano a vicenda."/>
                <para/>
                <ITEXT CH="Da questo punto di vista, l'obiettivo del progetto era costruire un sistema che potesse essere percepito come organismo: qualcosa che ha intenzioni proprie (anche se sono soltanto formule matematiche), che segue un ritmo proprio (anche se è generato algoritmicamente), che risponde al contesto (anche se il contesto è ridotto a pochi parametri misurabili). L'obiettivo era produrre la sensazione di trovarsi davanti a qualcosa di vivo. Niente di scientifico, nessun modello di un organismo reale: un dispositivo estetico, costruito perché lo spettatore vi presti la stessa attenzione che si presta davanti a uno stormo di storni o a un acquario, e non quella che si presta a un programma in esecuzione."/>
                <para/>
                <ITEXT CH="La scelta di lavorare con particelle ha una ragione precisa. Una particella singola è quasi niente: un punto luminoso con una direzione e una velocità. Ma migliaia di particelle che si influenzano a vicenda seguendo regole semplici producono qualcosa di molto più ricco di quello che chiunque avrebbe potuto progettare intenzionalmente. Il sistema trova forme che nessuno aveva previsto. È qui che risiede la qualità organica dell'esperienza. Le particelle in sé non somigliano a niente di biologico: sono punti luminosi su uno schermo, regolati da formule matematiche. L'effetto organico sta altrove, nel sistema preso come insieme, e in particolare nel fatto che sfugge al controllo completo di chi lo ha costruito. Quando un cluster di mille particelle si comporta in un modo che non era stato previsto, il programmatore si trova a osservarlo come si osserva una cosa, non come si controlla un programma."/>
                <para/>
                <ITEXT CH="&gt; **[IMG]** Screenshot del sistema in movimento a piena risoluzione: le particelle come organismo fluido, senza elementi grafici sovrapposti, solo il sistema e il nero."/>
                <para/>
                <ITEXT CH="La sala come spazio performativo"/>
                <para PARENT="section_subtitle"/>
                <ITEXT CH="L'installazione è pensata per uno spazio specifico: una sala al buio, con uno schermo grande sulla parete di fronte e le persone libere di sedersi o muoversi nella stanza. I telefoni sono l'unica fonte di luce personale, oltre alla proiezione."/>
                <para/>
                <ITEXT CH="Questa geometria non è casuale. Lo schermo grande crea una scala che rende il sistema percettibile come qualcosa che supera il singolo individuo: le particelle si muovono in uno spazio che eccede il campo visivo di chi le guarda da vicino. I telefoni, piccoli, personali, quasi nascosti in mano, sono il punto di contatto tra l'individuo e quel sistema grande. La distanza fisica tra i due, lo schermo lontano e il telefono vicino, rispecchia la distanza concettuale tra il collettivo e il singolo."/>
                <para/>
                <ITEXT CH="&gt; **[IMG]** Schizzo o diagramma dello spazio espositivo ideale: schermo grande frontale, persone distribuite nella sala, telefoni come punti di luce individuale nell'oscurità."/>
                <para/>
                <ITEXT CH="Il buio è una scelta estetica, e non risponde a esigenze tecniche di proiezione. Riduce le distrazioni, concentra l'attenzione su quello che accade sullo schermo, crea un senso di raccoglimento che rende l'esperienza più intensa. È un'eredità del cinema, del teatro, delle camere oscure di certe installazioni di luce contemporanee: chiunque abbia spento la luce in una stanza prima di mostrare qualcosa lo sa, l'oscurità funziona come una promessa che qualcosa sta per cominciare. È anche una condizione che abbassa le difese: al buio, in un gruppo, si è meno consapevoli di essere osservati, più disposti a fare qualcosa senza calcolare come appare agli altri."/>
                <para/>
                <ITEXT CH="La dimensione dello schermo conta. Un monitor da scrivania produrrebbe un'esperienza completamente diversa: più personale, più controllabile, meno soverchiante. La scala grande costringe lo sguardo ad accettare di non vedere tutto contemporaneamente. Bisogna muovere gli occhi, scegliere dove guardare, lasciare che il sistema sia più grande del proprio campo visivo. Questa perdita di controllo percettivo è parte integrante dell'esperienza."/>
                <para/>
                <ITEXT CH="Guidare senza imporre"/>
                <para PARENT="section_subtitle"/>
                <ITEXT CH="Il sistema non è muto. A intervalli, arrivano frammenti di testo o immagini: parole che compaiono sullo schermo e che le particelle abitano, attratte come se il linguaggio avesse un peso fisico. Sono frammenti di una narrativa che non viene mai spiegata per intero, che orienta senza concludere."/>
                <para/>
                <ITEXT CH="Questa scelta ha a che fare con la differenza tra un sistema che racconta e uno che lascia raccontare. Un sistema che racconta dà una storia completa: inizio, sviluppo, conclusione. Un sistema che lascia raccontare dà degli indizi, e lascia che chi guarda costruisca il significato a partire da quello che ha visto, sentito, fatto. È una struttura non lontana da quello che Umberto Eco, nel 1962, ha chiamato *opera aperta*: un lavoro che chiama il fruitore a completarlo, e che cambia di significato a ogni nuovo passaggio. La seconda opzione è più difficile da costruire, perché richiede di resistere alla tentazione di spiegare. Ma produce un'esperienza più personale: ognuno porta via qualcosa di leggermente diverso."/>
                <para/>
                <ITEXT CH="&gt; **[IMG]** Screenshot della modalità narrativa: testo visibile sullo schermo, le particelle che si addensano attorno alle parole come attratte da un campo gravitazionale."/>
                <para/>
                <ITEXT CH="La narrativa arriva in frammenti perché l'esperienza dura quanto dura la presenza delle persone nella sala. L'arco narrativo non ha un tempo fisso. Il sistema risponde al ritmo del gruppo, si adatta a quanto le persone sono coinvolte, può accelerare o rallentare. Due sessioni diverse della stessa installazione producono esperienze diverse: cambia il comportamento del sistema, cambia il significato che il pubblico vi costruisce sopra."/>
                <para/>
                <ITEXT CH="La soglia"/>
                <para/>
                <ITEXT CH="L'esperienza comincia con un gesto deliberato: scansionare un codice QR con il proprio telefono. Questo momento è piccolo, quasi banale nella vita quotidiana. In questo contesto ha un peso diverso."/>
                <para/>
                <ITEXT CH="Scansionare il codice significa scegliere di partecipare. Si decide di entrare nel sistema, con un gesto che differisce dalla curiosità casuale di chi passa davanti a una vetrina e si ferma a guardare. Questa scelta attiva produce una responsabilità leggera, ma reale: da quel momento, il proprio gesto ha conseguenze visibili. Il proprio colore è sullo schermo. Si fa parte dello sciame."/>
                <para/>
                <ITEXT CH="&gt; **[IMG]** Fotografia di qualcuno che scansiona il codice QR con il telefono, con sullo sfondo la proiezione del sistema in movimento."/>
                <para/>
                <ITEXT CH="La soglia è bassa, intenzionalmente: nessuna registrazione, nessuna informazione personale, nessun percorso imposto. È comunque una soglia, un momento in cui si passa da un lato all'altro. Prima del QR code, si è nella stanza. Dopo, si è nel sistema."/>
                <para/>
                <ITEXT CH="Questo passaggio è parte dell'opera tanto quanto il sistema di particelle. Forse di più, perché è il momento in cui si decide di essere presenti davvero. Tutti i gesti successivi, il joystick, il colore, il voto, hanno la qualità che hanno proprio perché sono stati preceduti da questa scelta. Si è scelto di entrare."/>
                <para/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="140.00062992126" YPOS="13400.7820472441" OwnPage="41" ItemID="321737952" PTYPE="4" WIDTH="339.527559055118" HEIGHT="139.527559055072" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="2" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L339.528 0 L339.528 139.528 L0 139.528 L0 0 Z" copath="M0 0 L339.528 0 L339.528 139.528 L0 139.528 L0 0 Z" gXpos="735.27502992126" gYpos="8109.45113700788" gWidth="0" gHeight="0" PSTYLE="section_title" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle PARENT="section_title"/>
                <ITEXT CH="capitolo 5"/>
                <para PARENT="section_title"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="140.00062992126" YPOS="13568.6560629921" OwnPage="41" ItemID="325898864" PTYPE="4" WIDTH="339.527559055118" HEIGHT="347.401574803149" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="28.3464566929134" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L339.528 0 L339.528 347.402 L0 347.402 L0 0 Z" copath="M0 0 L339.528 0 L339.528 347.402 L0 347.402 L0 0 Z" gXpos="735.27502992126" gYpos="8277.32515275593" gWidth="0" gHeight="0" PSTYLE="section_body" LAYER="0" NEXTITEM="354399152" BACKITEM="-1">
            <StoryText>
                <DefaultStyle PARENT="section_body" LINESPMode="0" ParagraphEffectOffset="0" ParagraphEffectIndent="0" DROP="0" Bullet="0" Numeration="0"/>
                <ITEXT CH="Un sistema è fatto di scelte. Ogni decisione tecnica ha una ragione concettuale dietro, e ogni ragione concettuale ha conseguenze sull'esperienza. Quello che segue è la descrizione di quelle scelte. Le parti tecniche compaiono solo dove servono a capirle."/>
                <para/>
                <ITEXT CH="Le particelle"/>
                <para PARENT="section_subtitle"/>
                <ITEXT CH="Le particelle sono l'unità fondamentale del sistema. Ogni particella è un agente autonomo: ha una posizione nello spazio, una velocità, una direzione, un colore. Segue regole che determinano come si muove in relazione alle altre particelle, ai campi di forza presenti nella scena, agli input che arrivano dai partecipanti."/>
                <para/>
                <ITEXT CH="Presa singolarmente, una particella è quasi invisibile: un punto luminoso contro il nero. Il sistema ne gestisce fino a diversi milioni in parallelo, su scheda grafica, dove ogni unità di calcolo processa migliaia di agenti simultaneamente. Quando tutti questi agenti si influenzano reciprocamente ogni frammento di secondo, il risultato è qualcosa che nessuno ha progettato: forme che si contraggono e si espandono, correnti che attraversano lo spazio, addensamenti che nascono e si dissolvono."/>
                <para/>
                <ITEXT CH="&gt; **[IMG]** Primo piano di un cluster di particelle ad alta densità: luce che si accumula e produce un bagliore, singoli punti distinguibili ai margini dove la densità decresce."/>
                <para/>
                <ITEXT CH="Il fatto che ogni particella abbia un colore che corrisponde a un partecipante specifico crea una struttura nascosta dentro il sistema: in ogni momento, lo sciame è la sovrapposizione di tanti sotto-sciami individuali, ognuno con la propria tinta. È il modo in cui l'identità individuale sopravvive dentro il corpo collettivo. Se ci si concentra su un singolo colore e lo si segue per qualche secondo, si vede che non sparisce: si attenua, si sposta, si confonde con gli altri, ma rimane localizzato in una porzione di sciame riconoscibile. La presenza è sempre lì, anche quando in superficie non si distingue più."/>
                <para/>
                <ITEXT CH="Il dispositivo remoto"/>
                <para PARENT="section_subtitle"/>
                <ITEXT CH="Quando una persona scansiona il codice QR, il proprio telefono diventa parte del sistema. La connessione è in tempo reale: ogni movimento del joystick virtuale trascina una piccola frazione delle proprie particelle verso la direzione indicata, e l'effetto sulla proiezione è immediato. Non c'è latenza percepibile. Il gesto e il risultato sono, per l'esperienza di chi partecipa, simultanei."/>
                <para/>
                <ITEXT CH="Il controller è volutamente minimale. C'è un joystick, uno spazio per scegliere il colore, poco altro. Non ci sono spiegazioni, non ci sono tutorial. La prima cosa che quasi tutti fanno è muovere il joystick per vedere cosa succede: scoprono in tempo reale che le particelle rispondono, che il loro colore è visibile nello sciame, che c'è una corrispondenza diretta tra il gesto e il risultato sullo schermo."/>
                <para/>
                <ITEXT CH="&gt; **[IMG]** Schermata del controller su smartphone: joystick virtuale al centro, selettore colore, interfaccia minimalista su sfondo scuro."/>
                <para/>
                <ITEXT CH="Quando una persona lascia il sistema (chiude il browser, si allontana), le sue particelle non spariscono di colpo. Si riorientano lentamente, si mescolano alle altre, perdono gradualmente la direzionalità che aveva il partecipante. Questa dissoluzione lenta è una scelta: rende l'arrivo e la partenza delle persone un evento fluido invece di un cambiamento brusco. Produce la sensazione che il sistema abbia una propria inerzia, una propria memoria del movimento passato."/>
                <para/>
                <ITEXT CH="Il suono"/>
                <para PARENT="section_subtitle"/>
                <ITEXT CH="Il microfono del dispositivo che gestisce la simulazione ascolta la stanza in continuazione. Misura il volume ambientale, il livello sonoro complessivo dell'ambiente, senza registrare nulla e senza analizzare il contenuto di ciò che sente. Questo valore, elaborato in tempo reale, modifica la luminosità delle particelle: più la stanza è rumorosa, più le particelle si fanno brillanti."/>
                <para/>
                <ITEXT CH="C'è qualcosa di Cage in questa scelta. Nel 1952, con *4'33&quot;*, John Cage aveva chiesto al pubblico di ascoltare quello che già c'era nella sala: i fruscii, i colpi di tosse, il rumore del condizionatore. Il silenzio non esiste, c'è solo il suono ambientale. In questo progetto il sistema fa qualcosa di simile, in modo strumentale: prende quel suono e lo trasforma in luce."/>
                <para/>
                <ITEXT CH="&gt; **[IMG]** Due stati della simulazione a confronto: ambiente silenzioso (particelle dim, luce contenuta) e ambiente rumoroso (particelle brillanti, bagliore più intenso e diffuso)."/>
                <para/>
                <ITEXT CH="Questa scelta aggiunge al sistema una dimensione che normalmente non viene associata alla grafica computazionale: l'ascolto. Il sistema non aspetta di essere toccato. Sente. Risponde a quello che succede nella stanza anche quando nessuno sta interagendo direttamente con esso. Il rumore di una conversazione, un momento di risata collettiva, il silenzio improvviso: tutto modifica la luminosità dello sciame. È una forma di consapevolezza ambientale molto primitiva. Produce però la sensazione che il sistema sia attento a quello che succede nella stanza, ben oltre l'input esplicito dei partecipanti."/>
                <para/>
                <ITEXT CH="La narrativa automatica"/>
                <para PARENT="section_subtitle"/>
                <ITEXT CH="A intervalli, il sistema riceve frammenti di contenuto: parole, frasi brevi, immagini. Questi elementi compaiono su uno strato separato della proiezione, e le particelle vengono attratte verso di essi come se fossero campi di forza fisici. Le parole vengono abitate: le particelle vi si addensano sopra, le contornano, le riempiono di luce. Il testo entra a far parte dello spazio in cui le particelle si muovono, e smette di essere un livello grafico sovrapposto."/>
                <para/>
                <ITEXT CH="&gt; **[IMG]** Screenshot della simulazione con testo sovrapposto visibile: le particelle che si addensano attorno alle lettere, formando la sagoma delle parole con la propria luce accumulata."/>
                <para/>
                <ITEXT CH="Questo meccanismo consente di introdurre una narrativa nell'esperienza senza che essa sia mai didattica o lineare. I frammenti arrivano come suggestioni: una parola può apparire per dieci secondi senza un contesto chiaro, lasciando al pubblico la libertà di costruirci un senso sopra, di ignorarla, o di tenerla come sfondo visivo finché scompare. Le particelle, per parte loro, non distinguono tra parole importanti e parole banali. Rispondono alla geometria delle lettere, e si addensano sopra una preposizione con la stessa convinzione con cui si addensano sopra un nome."/>
                <para/>
                <ITEXT CH="La gestione di questa narrativa è automatizzata: un sistema di orchestrazione esterno decide cosa mostrare e quando, senza richiedere supervisione durante la sessione. Il flusso narrativo si svolge da solo, seguendo un piano preparato in anticipo. Resta possibile, se serve, intervenire mentre l'installazione è in corso, per spingere la narrazione in una direzione più aderente al pubblico in sala quella sera. È una scelta che protegge il progetto da uno dei rischi più comuni delle installazioni interattive: dover stare davanti a un computer durante la mostra, invece di poter stare in mezzo alle persone che la vivono."/>
                <para/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="140.00062992126" YPOS="15941.8831496063" OwnPage="49" ItemID="327498864" PTYPE="4" WIDTH="339.527559055118" HEIGHT="139.527559055085" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="2" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L339.528 0 L339.528 139.528 L0 139.528 L0 0 Z" copath="M0 0 L339.528 0 L339.528 139.528 L0 139.528 L0 0 Z" gXpos="735.27502992126" gYpos="9768.66375433071" gWidth="0" gHeight="0" PSTYLE="section_title" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle PARENT="section_title"/>
                <ITEXT CH="Le modalità dell'esperienza"/>
                <trail PARENT="section_title"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="140.00062992126" YPOS="16109.7571653543" OwnPage="49" ItemID="304763968" PTYPE="4" WIDTH="339.527559055118" HEIGHT="347.401574803149" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="28.3464566929134" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L339.528 0 L339.528 347.402 L0 347.402 L0 0 Z" copath="M0 0 L339.528 0 L339.528 347.402 L0 347.402 L0 0 Z" gXpos="735.27502992126" gYpos="9936.53777007877" gWidth="0" gHeight="0" PSTYLE="section_body" LAYER="0" NEXTITEM="354424416" BACKITEM="-1">
            <StoryText>
                <DefaultStyle PARENT="section_body" LINESPMode="0" ParagraphEffectOffset="0" ParagraphEffectIndent="0" DROP="0" Bullet="0" Numeration="0"/>
                <ITEXT CH="Il sistema non è sempre uguale a se stesso. Ha stati diversi, che corrispondono a qualità diverse dell'esperienza: momenti di raccoglimento, di deriva, di dialogo, di decisione collettiva, di traccia, di scrittura condivisa. Ogni stato ha una logica propria e produce un'atmosfera propria."/>
                <para/>
                <ITEXT CH="DOT: raccoglimento"/>
                <para PARENT="section_subtitle"/>
                <ITEXT CH="Quando il sistema entra in modalità DOT, le particelle smettono di seguire la logica distribuita del normale e cominciano a convergere verso il centro dello schermo. Il movimento non è brusco: è lento, spiralato, quasi gravitazionale. Come se qualcosa al centro della scena esercitasse un'attrazione silenziosa, e ogni particella vi cedesse gradualmente."/>
                <para/>
                <ITEXT CH="Il risultato visivo è un addensamento progressivo: le particelle si avvicinano, si sovrappongono, la luminosità al centro aumenta fino a creare un bagliore intenso mentre i bordi dello schermo si svuotano. Il sistema si contrae su sé stesso. Aspetta."/>
                <para/>
                <ITEXT CH="&gt; **[IMG]** Screenshot della modalità DOT: particelle convergenti verso il centro in spirale, bagliore intenso al centro, bordi dello schermo scuri e quasi vuoti."/>
                <para/>
                <ITEXT CH="DOT è pensata come pausa: il momento che precede qualcosa, o che segue un momento di alta attività. Il raccoglimento prima di un nuovo frammento narrativo, la quiete dopo una fase di voto collettivo. Ha una qualità contemplativa che contrasta con la dispersione delle altre modalità, e che prepara il pubblico a qualcosa senza annunciare cosa. DOT è uno stato di tensione latente, simile a un respiro trattenuto prima che accada qualcosa."/>
                <para/>
                <ITEXT CH="Gli input dei partecipanti non vengono ignorati in questa modalità: le particelle rispondono ancora al joystick. Ma la forza di attrazione verso il centro è abbastanza forte da rendere evidente che c'è un campo più grande del gesto individuale. Il sistema ha la propria intenzione, e quella intenzione in questo momento è raccogliersi."/>
                <para/>
                <ITEXT CH="FREEROAM: deriva"/>
                <para PARENT="section_subtitle"/>
                <ITEXT CH="In modalità FREEROAM, non c'è nessuna direzione imposta al sistema. Le particelle seguono solo la propria inerzia e le interazioni reciproche: si muovono per la scena seguendo la fisica interna del sistema, senza essere attratte da nessun centro, senza rispondere a nessuna formula direzionale esterna."/>
                <para/>
                <ITEXT CH="Il sistema, in questa modalità, respira da solo. Se ci sono partecipanti connessi, le loro particelle seguono ancora il loro input, ma il flusso generale non ha una forma complessiva riconoscibile: è diffuso, casuale nell'aspetto, sempre in cambiamento. È la modalità più aperta in senso costruttivo: produce configurazioni sempre diverse, mai prevedibili."/>
                <para/>
                <ITEXT CH="È anche la modalità che il sistema assume quando nessuno ha ancora connesso il telefono. L'attesa è uno stato vivo. Lo schermo non è mai fermo: c'è sempre qualcosa che si muove, qualcosa che succede. Questo era importante nella fase di progettazione: il sistema non doveva sembrare spento quando non veniva usato. Doveva sembrare in attesa, nel senso più attivo del termine, come un organismo che continua a vivere anche quando nessuno lo sta guardando."/>
                <para/>
                <ITEXT CH="&gt; **[IMG]** Screenshot della modalità FREEROAM: particelle distribuite liberamente nello schermo, traiettorie multiple senza direzione dominante, movimento organico senza struttura imposta."/>
                <para/>
                <ITEXT CH="NORMAL: dialogo"/>
                <para PARENT="section_subtitle"/>
                <ITEXT CH="La modalità NORMAL è quella in cui il sistema è più attivo nella propria logica interna. Formule matematiche invisibili guidano il flusso delle particelle, producendo correnti, vortici, pattern che cambiano lentamente. Il sistema sembra in relazione con qualcosa, anche se non è immediatamente chiaro con cosa."/>
                <para/>
                <ITEXT CH="I partecipanti connessi possono spingere il proprio sotto-sciame in qualsiasi direzione: il risultato è una tensione tra la logica del sistema e l'impulso individuale. Chi partecipa non ha il controllo totale. Il sistema ha una propria resistenza, una propria tendenza direzionale. L'interazione è una forma di negoziazione: si suggerisce una direzione, il sistema accetta in parte, in parte propone qualcosa di suo, e quello che si vede sullo schermo è il risultato di una contrattazione in cui nessuno vince e nessuno perde."/>
                <para/>
                <ITEXT CH="&gt; **[IMG]** Screenshot della modalità NORMAL: flusso di particelle con pattern visibili, correnti e vortici emergenti, movimento strutturato ma non rigido."/>
                <para/>
                <ITEXT CH="Questa tensione è intenzionale. Se ogni partecipante potesse controllare completamente le proprie particelle, il sistema diventerebbe una somma di controlli individuali e perderebbe la qualità che lo distingue: quella di avere qualcosa di proprio da proporre, una direzione che nessuno gli ha chiesto e che però c'è. La resistenza è la condizione del dialogo."/>
                <para/>
                <ITEXT CH="NORMAL è la modalità predefinita dell'esperienza, quella in cui si trascorre la maggior parte del tempo. Le altre modalità sono eccezioni, cambi di qualità che rendono più evidente per contrasto quello che il sistema fa normalmente."/>
                <para/>
                <ITEXT CH="Il voto"/>
                <para PARENT="section_subtitle"/>
                <ITEXT CH="A certi momenti dell'esperienza, il sistema pone una domanda al pubblico: due opzioni, nessuna risposta giusta. Ogni partecipante può votare dal proprio telefono. Il risultato aggregato orienta una variazione, dentro una struttura narrativa che procede comunque: cambia la tessitura del tragitto, il dettaglio che fa sentire la storia come una storia di quel pubblico, in quella sera."/>
                <para/>
                <ITEXT CH="Il meccanismo del voto introduce una dimensione esplicita di decisione collettiva. Il sistema chiede al gruppo di orientarsi. Il fatto che nessuna opzione sia &quot;corretta&quot; è parte della scelta: l'obiettivo è coinvolgere il pubblico in una decisione reale, le cui conseguenze si vedranno immediatamente sullo schermo, senza alcuna pretesa di metterlo alla prova."/>
                <para/>
                <ITEXT CH="&gt; **[IMG]** Schermata del voto sul telefono: due opzioni, timer visibile, interfaccia minimale. Sullo schermo grande in background, il sistema in attesa del risultato."/>
                <para/>
                <ITEXT CH="Quello che rende il voto interessante è il momento che lo precede: la consapevolezza che quello che si fa conta, che la propria scelta si aggrega con quella degli altri, che il gruppo deciderà qualcosa insieme anche se ognuno lo fa nel silenzio della propria mano. È un atto politico in miniatura, eseguito da ciascuno per conto proprio."/>
                <para/>
                <ITEXT CH="Il voto introduce anche il tempo come componente dell'esperienza: c'è un countdown, un momento di attesa, un risultato che arriva. Questo ritmo scandisce l'esperienza e crea un senso di evento condiviso, qualcosa che accade insieme e ha una durata precisa."/>
                <para/>
                <ITEXT CH="Il disegno"/>
                <para/>
                <ITEXT CH="In modalità disegno, un gesto tracciato sullo schermo diventa territorio: una forma visibile sullo sfondo, verso cui le particelle vengono attratte. Le particelle abitano il disegno, lo riempiono di luce, lo fanno proprio. Il gesto individuale non scompare: rimane visibile come struttura attorno a cui il collettivo si organizza."/>
                <para/>
                <ITEXT CH="&gt; **[IMG]** Screenshot della modalità disegno: una forma o traccia visibile sullo schermo, le particelle che si addensano lungo il perimetro e all'interno, come se la forma avesse gravità."/>
                <para/>
                <ITEXT CH="C'è qualcosa di particolare in questo meccanismo. La traccia funziona come campo di attrazione, una forma di gravità: non dice alle particelle dove andare in modo prescrittivo, lascia che si avvicinino con la propria logica, la contornino, la riempiano a modo loro. Il risultato è ogni volta una traduzione collettiva di quell'impulso individuale, e non somiglia mai esattamente al gesto originale."/>
                <para/>
                <ITEXT CH="Il disegno è anche l'unica modalità in cui una singola persona può lasciare un segno duraturo nell'esperienza collettiva: la forma rimane sullo schermo, e le particelle di tutti continuano ad essere attratte da essa, anche di chi non ha partecipato alla sua creazione. È una forma di influenza anonima: si sa che c'è un disegno, ma non chi lo ha fatto."/>
                <para/>
                <ITEXT CH="Quello che rimane dopo che la traccia scompare è una configurazione del sistema che nessuno aveva previsto, prodotta dalla combinazione di un gesto e di migliaia di risposte."/>
                <para/>
                <ITEXT CH="La parola scritta"/>
                <para PARENT="section_subtitle"/>
                <ITEXT CH="In alcuni momenti dell'esperienza, il telefono apre una casella di scrittura. Per qualche secondo, ogni partecipante può digitare quello che vuole: una parola, una frase breve, un nome. Poi la casella si chiude e il sistema fa il resto."/>
                <para/>
                <ITEXT CH="Quello che si scrive non compare leggibile sullo schermo, almeno non subito. Le particelle si organizzano nello spazio occupato dalle lettere, vi si addensano lentamente, lasciano la loro luce dentro la forma del testo. La parola viene abitata, e diventa leggibile solo grazie alla densità con cui lo sciame la riempie. Emerge dal flusso come una nebbia che si compatta."/>
                <para/>
                <ITEXT CH="&gt; **[IMG]** Screenshot della modalità di scrittura: una parola digitata da un partecipante, le particelle che si addensano nella forma delle lettere senza definirle in modo netto, leggibili ma con i bordi sfilacciati."/>
                <para/>
                <ITEXT CH="Quello che rimane sulla proiezione è una traccia, il segno di una parola che è passata. Una trascrizione vera non c'è. Cosa significhi per uno sciame &quot;scrivere&quot; una parola digitata da qualcuno è una domanda che il progetto lascia aperta. Forse è il momento in cui la distanza tra l'individuo che digita e il collettivo che lo riceve si riduce: una parola privata diventa visibile a tutti, e l'anonimato del partecipante, per qualche secondo, ha una crepa."/>
                <para/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="140.00062992126" YPOS="18482.9842519686" OwnPage="57" ItemID="331676672" PTYPE="4" WIDTH="339.527559055118" HEIGHT="139.527559055055" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="2" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L339.528 0 L339.528 139.528 L0 139.528 L0 0 Z" copath="M0 0 L339.528 0 L339.528 139.528 L0 139.528 L0 0 Z" gXpos="735.27502992126" gYpos="11427.8763716535" gWidth="0" gHeight="0" PSTYLE="section_title" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle PARENT="section_title"/>
                <ITEXT CH="Il design dell'invisibilità"/>
                <trail PARENT="section_title"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="140.00062992126" YPOS="18650.8582677165" OwnPage="57" ItemID="330559520" PTYPE="4" WIDTH="339.527559055118" HEIGHT="347.401574803151" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="28.3464566929134" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L339.528 0 L339.528 347.402 L0 347.402 L0 0 Z" copath="M0 0 L339.528 0 L339.528 347.402 L0 347.402 L0 0 Z" gXpos="735.27502992126" gYpos="11595.7503874016" gWidth="0" gHeight="0" PSTYLE="section_body" LAYER="0" NEXTITEM="354512800" BACKITEM="-1">
            <StoryText>
                <DefaultStyle PARENT="section_body" LINESPMode="0" ParagraphEffectOffset="0" ParagraphEffectIndent="0" DROP="0" Bullet="0" Numeration="0"/>
                <ITEXT CH="Ogni scelta visiva di questo progetto è una decisione concettuale. Non esiste un elemento estetico neutro: il colore dello sfondo, la dimensione delle particelle, la quantità di testo sull'interfaccia del telefono, tutto dice qualcosa su come si vuole che l'esperienza venga vissuta."/>
                <para/>
                <ITEXT CH="Il principio che guida queste scelte ha un nome paradossale: il design dell'invisibilità. L'obiettivo è che l'interfaccia sparisca, e che rimanga solo l'esperienza."/>
                <para/>
                <ITEXT CH="Il nero come spazio"/>
                <para PARENT="section_subtitle"/>
                <ITEXT CH="La prima scelta è stata il nero, inteso come ambiente. Lo sfondo è passivo, è ciò che c'è quando non c'è nient'altro. L'ambiente è attivo, è la condizione che rende possibile quello che contiene."/>
                <para/>
                <ITEXT CH="Il nero assoluto del display permette alle particelle di esistere come luce pura: ogni punto luminoso emerge dal buio senza competere con altri elementi visivi. Quando le particelle si addensano, la luce si accumula, si sovrappone, produce bagliori che non sarebbero possibili su uno sfondo chiaro. Il contrasto è la condizione della visibilità: senza buio attorno, le particelle perderebbero il margine vibrante che fa apparire dieci punti come cento, e cento punti come una piccola nebulosa."/>
                <para/>
                <ITEXT CH="&gt; **[IMG]** Screenshot del sistema su sfondo nero totale: le particelle come punti di luce in uno spazio senza riferimenti, il nero come spazio fisico e non come assenza di colore."/>
                <para/>
                <ITEXT CH="Il buio della sala in cui si svolge l'installazione prolunga questo principio nello spazio fisico. Non c'è separazione netta tra il nero dello schermo e il nero della stanza: la proiezione sembra emergere dall'oscurità dell'ambiente, non da una superficie delimitata. Questo produce un effetto di profondità e continuità che uno schermo illuminato in una stanza normale non potrebbe avere."/>
                <para/>
                <ITEXT CH="C'è anche una ragione storica per questa scelta. Gran parte dell'arte che lavora con la luce, da James Turrell a Bruce Nauman, usa il buio come condizione. Il buio è una forma di presenza: ricettiva, attenta, capace di accogliere quello che la attraversa. Crea una qualità di percezione diversa rispetto alla luce ordinaria: l'occhio, lasciato senza riferimenti familiari, si abitua a cercare la luce dove c'è, e una volta che ha cominciato a cercarla la trova anche dove è debole, intermittente, quasi infinitesima. È in quel momento che lo sciame, anche disperso, diventa un evento e non un effetto."/>
                <para/>
                <ITEXT CH="Le particelle come luce"/>
                <para PARENT="section_subtitle"/>
                <ITEXT CH="Una singola particella, sullo schermo, è quasi niente: un punto bianco di pochi pixel, appena visibile. Ma quando migliaia di particelle si trovano nello stesso punto, la loro luce si somma. Il rendering usa un metodo di miscelazione additivo: invece di coprirsi a vicenda come farebbe della pittura, i colori si sommano come farebbe la luce reale. Due luci sovrapposte producono una luce più intensa, non una mescolanza opaca."/>
                <para/>
                <ITEXT CH="Questo significa che la densità diventa luminosità. Un cluster denso di particelle produce un bagliore che supera di molto la luminosità di qualsiasi particella singola. Le forme che emergono dallo sciame non sono disegnate: sono effetti di luce, prodotti dall'accumulo."/>
                <para/>
                <ITEXT CH="&gt; **[IMG]** Due stati a confronto: sciame disperso (particelle dim, quasi invisibili individualmente) e sciame denso (bagliore intenso, luce accumulata che produce alone luminoso)."/>
                <para/>
                <ITEXT CH="C'è qualcosa di fisicamente accurato in questo comportamento: così funziona la luce reale. Una stella singola è un punto nel cielo notturno; una galassia è una nube luminosa. La bellezza che emerge dalla densità ha un'origine nel modo in cui la luce si comporta davvero, non in una scelta puramente estetica. La simulazione, in questo senso, si comporta come una fotografia della realtà fisica: le regole che segue sono le stesse che seguono i fotoni."/>
                <para/>
                <ITEXT CH="Il colore come voce"/>
                <para PARENT="section_subtitle"/>
                <ITEXT CH="Ogni partecipante sceglie un colore. Non c'è altro da scegliere: niente nome, niente avatar, niente numero."/>
                <para/>
                <ITEXT CH="La scelta non è casuale. Il colore è il solo identificatore che funziona sia su uno schermo personale da pochi centimetri sia su una proiezione grande come una parete, senza richiedere lettura né interpretazione. Esiste come qualità percettiva pura: chi guarda lo sciame non deve cercare un'etichetta, basta seguire una tinta."/>
                <para/>
                <ITEXT CH="&gt; **[IMG]** Screenshot con più colori distinti visibili nel flusso: tinte individuali riconoscibili all'interno del movimento collettivo, come fili colorati in un tessuto."/>
                <para/>
                <ITEXT CH="Tecnicamente, i colori nel sistema si comportano come la luce, non come la pittura. Il rendering usa un metodo di miscelazione additivo: dove le particelle di due partecipanti si sovrappongono, i loro colori si sommano. Due tinte sovrapposte producono una terza, più luminosa. Una folla di colori tende al bagliore bianco. L'effetto è che nessun colore copre un altro: si mescolano verso qualcosa di comune senza perdere la propria origine."/>
                <para/>
                <ITEXT CH="La scelta del colore è anche il primo gesto che il partecipante compie nel sistema, prima ancora di muovere il joystick. È una scelta puramente estetica, senza conseguenze funzionali: rosso e blu muovono le particelle esattamente allo stesso modo. Ma il colore resta nello sciame per tutta la durata della connessione. È la firma di una presenza percepibile, anche se senza nome: una persona che entra in sala dopo che l'installazione è già cominciata può individuare con un'occhiata la tinta di chi è arrivato per primo, e riconoscerla nei minuti successivi come si riconosce una voce sentita da lontano, senza saperne nient'altro."/>
                <para/>
                <ITEXT CH="L'interfaccia che scompare"/>
                <para PARENT="section_subtitle"/>
                <ITEXT CH="Il telefono mostra tre cose: il joystick, il selettore del colore, un punto di stato nell'angolo. Nient'altro."/>
                <para/>
                <ITEXT CH="Nel corso del progetto, questa schermata ha perso elementi. Un testo introduttivo, rimosso. Icone di stato, ridotte a un punto. Un bottone di aiuto, eliminato. A ogni iterazione ci si chiedeva: questo elemento serve all'esperienza, o serve a rassicurare chi ha progettato il sistema che l'utente non si perderà? La seconda risposta ha sempre portato alla rimozione."/>
                <para/>
                <ITEXT CH="&gt; **[IMG]** Schermata del telefono: interfaccia quasi vuota, sfondo scuro, elementi minimi: il meno possibile tra la persona e l'esperienza."/>
                <para/>
                <ITEXT CH="Il costo è misurabile. In alcune sessioni di test, non tutti hanno capito subito dove guardare: alcuni hanno fissato il telefono invece di alzare gli occhi verso lo schermo grande, cercando sull'oggetto piccolo la risposta che stava accadendo su quello grande. Questa latenza, di qualche secondo, raramente di più, è il prezzo del minimalismo."/>
                <para/>
                <ITEXT CH="Non è un problema che si vuole risolvere. Il momento in cui qualcuno smette di guardare il telefono e alza gli occhi verso la proiezione è esattamente il momento in cui l'interfaccia scompare. Non si può accelerarlo con le istruzioni. Bisogna aspettare che accada da solo."/>
                <para/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="140.00062992126" YPOS="21024.0853543307" OwnPage="65" ItemID="337040752" PTYPE="4" WIDTH="339.527559055118" HEIGHT="139.527559055114" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="2" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L339.528 0 L339.528 139.528 L0 139.528 L0 0 Z" copath="M0 0 L339.528 0 L339.528 139.528 L0 139.528 L0 0 Z" gXpos="735.27502992126" gYpos="13087.0889889764" gWidth="0" gHeight="0" PSTYLE="section_title" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle PARENT="section_title"/>
                <ITEXT CH="Fare come forma di conoscenza"/>
                <trail PARENT="section_title"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="140.00062992126" YPOS="21191.9593700787" OwnPage="65" ItemID="336182912" PTYPE="4" WIDTH="339.527559055118" HEIGHT="347.401574803151" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="28.3464566929134" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L339.528 0 L339.528 347.402 L0 347.402 L0 0 Z" copath="M0 0 L339.528 0 L339.528 347.402 L0 347.402 L0 0 Z" gXpos="735.27502992126" gYpos="13254.9630047244" gWidth="0" gHeight="0" PSTYLE="section_body" LAYER="0" NEXTITEM="354574800" BACKITEM="-1">
            <StoryText>
                <DefaultStyle PARENT="section_body" LINESPMode="0" ParagraphEffectOffset="0" ParagraphEffectIndent="0" DROP="0" Bullet="0" Numeration="0"/>
                <ITEXT CH="Costruire questo progetto ha insegnato cose che non avrei potuto imparare in nessun altro modo. Cose che vanno al di là della parte tecnica, oltre l'imparare un'API grafica o gestire connessioni in tempo reale. Si tratta di capire come si comporta un sistema complesso da dentro, mentre prende forma."/>
                <para/>
                <ITEXT CH="Esiste una forma di conoscenza che nasce soltanto dal fare. È una conoscenza diversa da quella che nasce dallo studio: più difficile da trasmettere, più difficile da documentare, strettamente legata all'esperienza diretta di costruire qualcosa che non è mai esistito nella forma in cui lo si immagina. C'è chi dice che il lavoro creativo non si produca tanto quanto si riceva, e che l'autore sia in ascolto di quello che il progetto stesso vuole diventare. L'idea che il lavoro possa avere una propria direzione, che spinga verso qualcosa che il creatore non aveva previsto, corrisponde esattamente a quello che è successo qui."/>
                <para/>
                <ITEXT CH="L'errore come informazione"/>
                <para PARENT="section_subtitle"/>
                <ITEXT CH="I sistemi di simulazione basati su agenti hanno una caratteristica che li rende particolarmente instabili nelle fasi di sviluppo: le interazioni tra migliaia di entità producono comportamenti emergenti che non si possono prevedere leggendo il codice. Un errore in una formula di movimento produce raramente un risultato sbagliato in modo ovvio: produce un comportamento inaspettato, che a volte è un bug e a volte è qualcosa di interessante."/>
                <para/>
                <ITEXT CH="Più volte durante lo sviluppo mi sono trovato davanti a comportamenti che non avevo scritto. Particelle che formavano strutture filiformi invece di cluster tondi. Correnti che si organizzavano in pattern ripetuti invece di fluire liberamente. Oscillazioni che sembravano respirazione. In alcuni casi erano errori da correggere. In altri erano proprietà emergenti del sistema che non sapevo di voler costruire, ma che una volta viste sembravano ovvie."/>
                <para/>
                <ITEXT CH="&gt; **[IMG]** Screenshot di un comportamento emergente inaspettato della simulazione: un pattern o una struttura che non era stata progettata esplicitamente, visivamente interessante proprio per la sua natura non intenzionale."/>
                <para/>
                <ITEXT CH="Questo ha cambiato il modo in cui ho pensato alla simulazione. Ha smesso di essere un sistema che controllavo e ha cominciato a essere un sistema con cui negoziavo. Le mie decisioni tecniche producevano effetti che poi osservavo, valutavo, e usavo per prendere la decisione successiva. Il processo di sviluppo era esso stesso un'esperienza di sciame: io come agente, il sistema come ambiente, la simulazione come risultato emergente di quella relazione."/>
                <para/>
                <ITEXT CH="La distinzione che è emersa da questo processo è importante: c'è una differenza tra *simulare* un sistema e *capire come si comporta*. Si può costruire la formula giusta senza sapere cosa produrrà nel contesto delle migliaia di interazioni che avvengono ad ogni frame. La comprensione vera arriva solo dall'osservazione in esecuzione, dal vedere quello che succede quando il sistema gira davvero."/>
                <para/>
                <ITEXT CH="Quando qualcosa ha funzionato"/>
                <para PARENT="section_subtitle"/>
                <ITEXT CH="C'è un momento difficile da descrivere ma facile da riconoscere: il momento in cui un sistema smette di sembrare un esperimento e comincia a sembrare un'esperienza."/>
                <para/>
                <ITEXT CH="&gt; **[IMG]** Screenshot di un momento particolarmente significativo della simulazione: composizione visiva intensa, luce e movimento in equilibrio, il sistema che sembra avere una propria presenza."/>
                <para/>
                <ITEXT CH="Per questo progetto, quel momento è arrivato la prima volta che ho visto le particelle rispondere all'input audio della stanza. Il sistema era già funzionante: le particelle si muovevano, i colori dei partecipanti erano visibili, il joystick funzionava. Ma quando ho capito che la luminosità dello sciame cambiava ogni volta che alzavo la voce, qualcosa ha cambiato qualità. Non stavo più guardando un programma che funzionava. Stavo guardando qualcosa che ascoltava."/>
                <para/>
                <ITEXT CH="Questa differenza è difficile da codificare in criteri oggettivi. Non si misura in frame rate o in numero di particelle. Si percepisce: c'è un momento in cui il sistema comincia ad avere una presenza, un carattere, qualcosa che lo rende riconoscibile come sé stesso invece che come una variante di qualcosa che esiste già. Riconoscere quel momento, e poi lavorare per preservare quella qualità nelle iterazioni successive, è uno degli obiettivi impliciti di qualsiasi processo creativo."/>
                <para/>
                <ITEXT CH="La distanza tra l'intenzione e il risultato"/>
                <para PARENT="section_subtitle"/>
                <ITEXT CH="Il progetto che avevo in mente all'inizio era diverso da quello che esiste adesso. Le grandi linee tengono. Sono i dettagli che si sono spostati, e in alcuni casi si sono spostati abbastanza da cambiare il senso complessivo dell'esperienza."/>
                <para/>
                <ITEXT CH="Alcune cose sono state semplificate: aspetti che sembravano fondamentali all'inizio si sono rivelati inutili una volta provati, o impossibili da implementare nei tempi disponibili, o semplicemente meno interessanti di quanto pensassi. La narrativa originale avrebbe dovuto essere più strutturata, più lineare, con un arco preciso. Nel processo, si è frammentata, e quella frammentazione si è rivelata più adatta all'esperienza."/>
                <para/>
                <ITEXT CH="Altre cose sono emerse durante il processo e si sono rivelate centrali: la reattività audio, per esempio, non era nel piano originale. È venuta fuori da una domanda semplice, cosa succederebbe se il sistema sentisse la stanza?, e ha cambiato in modo significativo la qualità dell'esperienza."/>
                <para/>
                <ITEXT CH="&gt; **[IMG]** Documentazione di una fase intermedia dello sviluppo: screenshot più grezzo o interfaccia meno rifinita, a confronto implicito con lo stato attuale."/>
                <para/>
                <ITEXT CH="Questa distanza tra intenzione e risultato è una parte normale di qualsiasi processo creativo serio. È il segno che il lavoro ha avuto vita propria, e ha cambiato forma mentre era in costruzione. Chi costruisce qualcosa di non banale lo sa: l'oggetto finito raramente coincide con quello immaginato all'inizio, e quando coincide spesso è perché si è progettato in difetto, evitando di seguire le occasioni che il processo apriva strada facendo. Come scrive Rick Rubin in *The Creative Act* (2023), «il progetto non appartiene all'artista. L'artista è il custode del progetto, non il suo creatore.» Il lavoro ha una sua direzione che si manifesta solo attraverso il processo, e in anticipo non si può sapere dove porta. Si può solo stare attenti a riconoscerlo quando ci si arriva."/>
                <para/>
                <ITEXT CH="Alla fine quello che rimane è quello che si è riusciti a fare, con i vincoli del tempo, delle competenze disponibili e di quello che il sistema stesso suggeriva di diventare. Non è esattamente quello che si voleva fare. In molti casi, è meglio."/>
                <para/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="140.00062992126" YPOS="23565.1864566929" OwnPage="73" ItemID="340936544" PTYPE="4" WIDTH="339.527559055118" HEIGHT="139.527559055066" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="2" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L339.528 0 L339.528 139.528 L0 139.528 L0 0 Z" copath="M0 0 L339.528 0 L339.528 139.528 L0 139.528 L0 0 Z" gXpos="735.27502992126" gYpos="14746.3016062992" gWidth="0" gHeight="0" PSTYLE="section_title" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle PARENT="section_title"/>
                <ITEXT CH="Il dialogo tra umano e macchina"/>
                <trail PARENT="section_title"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="140.00062992126" YPOS="23733.0604724409" OwnPage="73" ItemID="340313888" PTYPE="4" WIDTH="339.527559055118" HEIGHT="347.401574803149" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="28.3464566929134" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L339.528 0 L339.528 347.402 L0 347.402 L0 0 Z" copath="M0 0 L339.528 0 L339.528 347.402 L0 347.402 L0 0 Z" gXpos="735.27502992126" gYpos="14914.1756220472" gWidth="0" gHeight="0" PSTYLE="section_body" LAYER="0" NEXTITEM="354627360" BACKITEM="-1">
            <StoryText>
                <DefaultStyle PARENT="section_body" LINESPMode="0" ParagraphEffectOffset="0" ParagraphEffectIndent="0" DROP="0" Bullet="0" Numeration="0"/>
                <ITEXT CH="Il rapporto tra una persona e un sistema interattivo non è mai semplice come sembra. Si entra in uno spazio con l'idea di controllare qualcosa, e si scopre che qualcosa ci sta anche controllando. Il ruolo di soggetto, che si era assunti entrando, si rivela parziale: di fronte a un sistema che risponde, si è anche oggetto."/>
                <para/>
                <ITEXT CH="Questa circolarità è al centro di molte delle domande più interessanti che la tecnologia computazionale ha aperto negli ultimi decenni. Non interessa qui chi sia più intelligente, l'umano o la macchina. Interessa come si trasforma la relazione tra i due, quando il sistema è abbastanza complesso da rispondere in modi non completamente prevedibili."/>
                <para/>
                <ITEXT CH="Chi guida chi"/>
                <para PARENT="section_subtitle"/>
                <ITEXT CH="In un sistema di particelle orientate da partecipanti, la risposta alla domanda &quot;chi guida?&quot; è sempre provvisoria. I partecipanti guidano le proprie particelle: questo è ovvio. Ma il comportamento delle particelle degli altri influenza quello che si vede, e quello che si vede influenza i gesti successivi. Il sistema ha una propria logica che resiste alle direzioni individuali. La narrativa che arriva dall'esterno orienta l'attenzione."/>
                <para/>
                <ITEXT CH="Alla fine, non è chiaro chi stia guidando. O meglio: tutti guidano e nessuno guida completamente. Il controllo è distribuito, come nel modello dello sciame: nessuno vede l'intero, ognuno influenza una porzione, e il risultato finale appartiene a tutti i partecipanti insieme senza appartenere a nessuno in particolare."/>
                <para/>
                <ITEXT CH="&gt; **[IMG]** Diagramma della circolarità dell'influenza: partecipanti che influenzano il sistema, il sistema che modifica il comportamento dei partecipanti, la narrativa esterna come terzo elemento."/>
                <para/>
                <ITEXT CH="Alan Turing, nel suo saggio del 1950 *Computing Machinery and Intelligence*, si chiedeva se si potesse mai distinguere, in una conversazione, una risposta umana da una risposta di macchina. La domanda di Turing era sulla simulazione del linguaggio. Ma la struttura del problema si applica anche qui: quando non si riesce più a distinguere quali parti del comportamento del sistema sono state causate dai partecipanti e quali dalla logica interna, chi si può dire che stia guidando?"/>
                <para/>
                <ITEXT CH="In questo progetto, la risposta è deliberatamente ambigua. Il sistema non vuole essere trasparente. Vuole essere percepito come qualcosa con cui si è in relazione, non come uno strumento che si usa. La circolarità dell'influenza, il fatto che nessuno abbia il controllo completo, è parte di questa intenzione."/>
                <para/>
                <ITEXT CH="Il sistema come specchio"/>
                <para PARENT="section_subtitle"/>
                <ITEXT CH="Uno degli effetti più interessanti di un sistema collettivo è che rivela strutture che non erano visibili guardando i singoli. Le persone in una stanza si organizzano in modi che nessuna di loro ha pianificato: formano gruppi, seguono leader informali, producono ritmi condivisi di attenzione. Queste strutture sono reali, ma normalmente invisibili."/>
                <para/>
                <ITEXT CH="Quando il comportamento collettivo di un gruppo è visualizzato in tempo reale su uno schermo grande, quelle strutture diventano osservabili. Si può vedere dove l'attenzione del gruppo si concentra. Si può vedere se qualcuno sta guidando il movimento degli altri, anche senza volerlo. Si può vedere il ritmo collettivo nella forma del flusso."/>
                <para/>
                <ITEXT CH="&gt; **[IMG]** Screenshot che mostra un pattern visivo chiaro emergente dal comportamento collettivo: una struttura nel flusso che rivela l'organizzazione implicita del gruppo in quel momento."/>
                <para/>
                <ITEXT CH="La logica è la stessa che Rokeby aveva identificato nel suo lavoro, descritta nel primo capitolo: il sistema non restituisce una copia fedele di ciò che riceve. Lo traduce. E la traduzione introduce una distanza interpretativa che rende osservabile quello che altrimenti resterebbe invisibile. Su scala collettiva, questa traduzione opera su un materiale più complesso del movimento di un corpo singolo: opera sul comportamento aggregato di un gruppo. Quello che si vede sullo schermo è il gruppo, ma trasformato in qualcosa che il gruppo non avrebbe potuto vedere di sé stesso in nessun altro modo."/>
                <para/>
                <ITEXT CH="Questa trasformazione ha un effetto preciso: rende osservabile quello che normalmente si sente soltanto. Si può avere la sensazione di far parte di un gruppo coeso o di un gruppo disperso; con questo sistema, quella sensazione ha una forma visiva. Si può vederla."/>
                <para/>
                <ITEXT CH="La macchina che propone"/>
                <para PARENT="section_subtitle"/>
                <ITEXT CH="Tutti i sistemi descritti fin qui, le particelle, le modalità, la narrativa, condividono una caratteristica che non è mai stata nominata direttamente: il sistema non aspetta."/>
                <para/>
                <ITEXT CH="&gt; **[IMG]** Screenshot della modalità DOT o FREEROAM: il sistema in uno stato attivo senza input esterno, le particelle che si muovono secondo una propria logica visibile."/>
                <para/>
                <ITEXT CH="Quando le persone entrano nella stanza, il sistema ha già qualcosa in corso. Esiste prima che qualcuno arrivi, e continuerà a esistere dopo che se ne sarà andato."/>
                <para/>
                <ITEXT CH="Questo cambia tutto nel tipo di relazione che si stabilisce. Di fronte a un ambiente già in movimento, la prima domanda non è &quot;come lo uso?&quot;. È &quot;cosa sta facendo?&quot;. Si osserva prima di agire. Si cerca di capire la logica prima di intervenire. È una postura radicalmente diversa da quella di chi usa uno strumento: chi usa uno strumento si avvicina con uno scopo già pronto, e cerca i tasti che servono a raggiungerlo. Chi entra in questo progetto, le prime volte, si trova senza scopo. E quel vuoto, lontano dall'essere un difetto dell'interfaccia, è esattamente ciò che il sistema cerca di produrre."/>
                <para/>
                <ITEXT CH="Il sistema propone. Propone un comportamento, un ritmo, una qualità dell'esperienza. I partecipanti rispondono a quella proposta con la propria. Il dialogo è già iniziato quando si connette il telefono: si entra in una conversazione in corso, non si apre una conversazione nuova."/>
                <para/>
                <ITEXT CH="Questo è un modello molto diverso da quello dell'assistente conversazionale, che aspetta la domanda e risponde. È più vicino a quello di un musicista che sta già suonando quando gli altri entrano nella stanza: l'interazione comincia dall'ascolto, non dall'interrogazione."/>
                <para/>
                <ITEXT CH="Un'estetica della relazione"/>
                <para PARENT="section_subtitle"/>
                <ITEXT CH="Nicolas Bourriaud, nel suo libro *Estetica relazionale* (1998), descrive una tendenza nell'arte degli anni Novanta verso opere che producono modi di stare insieme, forme di relazione, piuttosto che oggetti da contemplare. L'opera diventa contesto: lo spazio in cui si creano incontri tra persone, tra persone e sistemi, tra idee e corpi. Smette di essere un messaggio trasmesso da un autore a un pubblico."/>
                <para/>
                <ITEXT CH="Questo progetto appartiene a quella tradizione, ma la prolunga in una direzione che Bourriaud non poteva prevedere: il sistema stesso diventa un interlocutore attivo, una presenza che partecipa alla relazione invece di limitarsi a ospitarla."/>
                <para/>
                <ITEXT CH="&gt; **[IMG]** Fotografia o screenshot che cattura l'esperienza complessiva dell'installazione: persone nella sala, proiezione grande sullo sfondo, telefoni in mano, la dimensione collettiva dell'evento."/>
                <para/>
                <ITEXT CH="Quello che questo progetto propone, implicitamente, è un modello diverso per pensare il rapporto tra umani e sistemi intelligenti. Un modello distante sia dallo strumento che si usa quando serve sia dall'oracolo che risponde alle domande. Più vicino a una presenza: un sistema che ha una propria vita, che si modifica in risposta al contesto, che offre qualcosa e chiede qualcosa in cambio. Una funzione che diventa relazione."/>
                <para/>
                <ITEXT CH="Questa proposta non ha ambizioni di universalità. È un esperimento, un prototipo, una domanda formulata attraverso la forma invece che attraverso il testo. E come ogni domanda formulata bene, non esaurisce il problema che pone: lo rende più preciso, più maneggiabile, più difficile da ignorare."/>
                <para/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="140.00062992126" YPOS="26106.2875590551" OwnPage="81" ItemID="344956208" PTYPE="4" WIDTH="339.527559055118" HEIGHT="139.527559055117" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="2" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L339.528 0 L339.528 139.528 L0 139.528 L0 0 Z" copath="M0 0 L339.528 0 L339.528 139.528 L0 139.528 L0 0 Z" gXpos="735.27502992126" gYpos="16405.514223622" gWidth="0" gHeight="0" PSTYLE="section_title" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle PARENT="section_title"/>
                <ITEXT CH="Limiti e direzioni future"/>
                <trail PARENT="section_title"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="140.00062992126" YPOS="26274.1615748031" OwnPage="81" ItemID="343555168" PTYPE="4" WIDTH="339.527559055118" HEIGHT="347.401574803149" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="28.3464566929134" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L339.528 0 L339.528 347.402 L0 347.402 L0 0 Z" copath="M0 0 L339.528 0 L339.528 347.402 L0 347.402 L0 0 Z" gXpos="735.27502992126" gYpos="16573.38823937" gWidth="0" gHeight="0" PSTYLE="section_body" LAYER="0" NEXTITEM="354692672" BACKITEM="-1">
            <StoryText>
                <DefaultStyle PARENT="section_body" LINESPMode="0" ParagraphEffectOffset="0" ParagraphEffectIndent="0" DROP="0" Bullet="0" Numeration="0"/>
                <ITEXT CH="Costruire qualcosa insegna anche cosa non si riesce a fare. Questo non è un dato neutro: i limiti di un sistema ne rivelano la natura con la stessa precisione delle sue possibilità. Quello che un sistema non sa fare dice dove finisce la sua intelligenza e dove comincia la necessità di qualcosa di diverso."/>
                <para/>
                <ITEXT CH=" Cosa il sistema non riesce ancora a fare"/>
                <para PARENT="section_subtitle"/>
                <ITEXT CH="Il limite più evidente è nella qualità dell'ascolto. Il sistema percepisce il volume ambientale della stanza, ma non distingue i suoni. Non sa se quello che sente è musica, conversazione, applauso, o silenzio improvviso. Risponde alla quantità di suono, non alla sua qualità. Questo produce effetti interessanti, ma limita molto la gamma di risposte possibili: il sistema non può reagire diversamente a una risata collettiva e a un rumore di sottofondo casuale."/>
                <para/>
                <ITEXT CH="Una limitazione simile riguarda la visione. Il sistema non vede la stanza. Non sa quante persone ci sono, dove sono posizionate, se si stanno muovendo o stanno ferme. L'unico canale di informazione sul comportamento fisico dei partecipanti è il telefono. Questo lascia fuori gran parte di ciò che un corpo fa in uno spazio: la postura, il movimento, la direzione dello sguardo, la distanza dagli altri."/>
                <para/>
                <ITEXT CH="&gt; **[IMG]** Diagramma schematico di quello che il sistema percepisce (volume audio, input touch) rispetto a quello che non vede (posizione fisica, gesti corporei, espressioni, numero di persone presenti)."/>
                <para/>
                <ITEXT CH="Un'altra limitazione riguarda la memoria. Il sistema non ricorda. Ogni sessione comincia da zero: le particelle non sanno nulla di quello che è successo nelle sessioni precedenti, e niente di quello che succede in quella corrente diventa permanente. Il sistema è potente nel brevissimo termine. Sul tempo lungo, è cieco. Non ha storia: il pubblico che è venuto ieri sera non lascia tracce visibili a quello di stasera, e tutto ricomincia da capo a ogni accensione, come se il sistema fosse stato appena costruito."/>
                <para/>
                <ITEXT CH="Infine, c'è una limitazione che riguarda la scala dell'esperienza. Il progetto è stato concepito e testato in condizioni controllate. Non è mai stato esposto a un pubblico reale in un contesto espositivo vero. Molte delle assunzioni che lo attraversano, su come le persone reagiscono, su quanto tempo passano connesse, su come si comporta il sistema con dieci o venti persone simultanee, rimangono ipotesi da verificare."/>
                <para/>
                <ITEXT CH="La questione della scala"/>
                <para PARENT="section_subtitle"/>
                <ITEXT CH="Il progetto è stato pensato per una sala di dimensioni moderate, con un numero limitato di partecipanti. A questa scala, il sistema funziona: c'è abbastanza partecipazione da produrre dinamiche collettive interessanti, e abbastanza controllo da gestire la connessione in tempo reale."/>
                <para/>
                <ITEXT CH="Ma cosa succederebbe con cento persone? Con mille? In uno spazio aperto, in una piazza, in un aeroporto?"/>
                <para/>
                <ITEXT CH="&gt; **[IMG]** Schizzo o mock-up concettuale del sistema in uno spazio pubblico di grandi dimensioni: visualizzazione ipotetica di un'installazione in un grande auditorium, in una piazza, o in un atrio di stazione."/>
                <para/>
                <ITEXT CH="Le sfide tecniche di questa espansione sono reali ma risolvibili. Le sfide concettuali sono più interessanti. Con mille partecipanti, le dinamiche collettive cambierebbero natura: si formerebbero sottogruppi, emergerebbero strutture di influenza più complesse, la logica dello sciame diventerebbe ancora più evidente e meno controllabile. Il singolo individuo si sentirebbe ancora meno come un agente di controllo e ancora di più come parte di qualcosa che lo supera."/>
                <para/>
                <ITEXT CH="Questo potrebbe essere bellissimo. Oppure soverchiante, nell'accezione negativa del termine: qualcosa che non lascia spazio all'individuo, che annulla invece di includere. La differenza tra questi due esiti dipende da scelte di design che a questa scala non sono ancora state fatte. È una domanda aperta."/>
                <para/>
                <ITEXT CH="Estensioni possibili"/>
                <para PARENT="section_subtitle"/>
                <ITEXT CH="Le direzioni in cui questo progetto potrebbe crescere sono molte, e non tutte tecnologiche."/>
                <para/>
                <ITEXT CH="Sul fronte dei sensi: il suono è già presente come input, ma potrebbe diventare anche output. Un sistema che risponde al suono della stanza producendo suono a sua volta, in una retroazione audio-visiva, aprirebbe una dimensione completamente nuova. Allo stesso modo, sistemi di visione artificiale potrebbero estendere la percezione del sistema dal tocco sullo schermo al corpo nel suo complesso: la postura, il movimento, la direzione dello sguardo."/>
                <para/>
                <ITEXT CH="Sul fronte del tempo: un sistema che ricorda. Che mantiene traccia di quello che è successo nelle sessioni passate, che si modifica lentamente nel corso di settimane o mesi di esposizione. Che porta con sé la storia del pubblico che l'ha attraversato. Sarebbe una forma di memoria diversa da quella umana, e in tutto reale: un sistema che cambia perché è stato vissuto."/>
                <para/>
                <ITEXT CH="&gt; **[IMG]** Tavola concettuale con schizzi di possibili estensioni: nuovi sensi integrati (visione, temperatura), configurazioni spaziali diverse, timeline di evoluzione del sistema nel tempo."/>
                <para/>
                <ITEXT CH="Sul fronte dei luoghi: installazioni distribuite in più spazi simultaneamente, connesse in rete. Sciami che si trovano in città diverse ma si influenzano a vicenda in tempo reale. La distanza fisica che scompare nella condivisione di uno sciame comune: persone a Milano e persone a Tokyo che muovono lo stesso sistema, che vedono sullo schermo il risultato di azioni che nessuno di loro conosce completamente."/>
                <para/>
                <ITEXT CH="Tutte queste direzioni sono possibili. Nessuna è ovvia, e ognuna richiederebbe di affrontare problemi che questo progetto non ha ancora toccato. Ma la logica di base è già qui: un organismo distribuito, che risponde al contesto, che produce qualcosa di significativo quando le persone si avvicinano abbastanza e abbastanza a lungo."/>
                <para/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="140.00062992126" YPOS="28647.3886614173" OwnPage="89" ItemID="349242512" PTYPE="4" WIDTH="339.527559055118" HEIGHT="139.527559055114" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="2" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L339.528 0 L339.528 139.528 L0 139.528 L0 0 Z" copath="M0 0 L339.528 0 L339.528 139.528 L0 139.528 L0 0 Z" gXpos="735.27502992126" gYpos="18064.7268409449" gWidth="0" gHeight="0" PSTYLE="section_title" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle PARENT="section_title"/>
                <ITEXT CH="Conclusione"/>
                <trail PARENT="section_title"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="140.00062992126" YPOS="28815.2626771653" OwnPage="89" ItemID="351486176" PTYPE="4" WIDTH="339.527559055118" HEIGHT="347.401574803149" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="28.3464566929134" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L339.528 0 L339.528 347.402 L0 347.402 L0 0 Z" copath="M0 0 L339.528 0 L339.528 347.402 L0 347.402 L0 0 Z" gXpos="735.27502992126" gYpos="18232.6008566929" gWidth="0" gHeight="0" PSTYLE="section_body" LAYER="0" NEXTITEM="354747600" BACKITEM="-1">
            <StoryText>
                <DefaultStyle PARENT="section_body" LINESPMode="0" ParagraphEffectOffset="0" ParagraphEffectIndent="0" DROP="0" Bullet="0" Numeration="0"/>
                <ITEXT CH="Questo progetto nasce da una domanda sull'interazione. Finisce, almeno in questa forma, con molte domande in più."/>
                <para/>
                <ITEXT CH="Non è un fallimento. Le domande che rimangono aperte alla fine di un lavoro serio sono spesso più preziose delle risposte che ha prodotto. Indicano dove c'è ancora qualcosa da capire, dove il pensiero non è ancora arrivato, dove il fare non ha ancora esaurito le sue possibilità."/>
                <para/>
                <ITEXT CH="La domanda da cui tutto è partito era semplice: cosa succede quando un sistema intelligente è già presente nella stanza, invece di aspettare di essere interrogato? La risposta che questo progetto propone è parziale, senza alcuna pretesa di essere definitiva. Ed è concreta: si può costruire qualcosa che abbia una propria vita, un proprio ritmo, una propria logica, e che risponda alla presenza delle persone senza che le persone debbano fare nulla di speciale per farlo funzionare. Basta essere lì."/>
                <para/>
                <ITEXT CH="&gt; **[IMG]** Screenshot finale del sistema in uno dei suoi momenti più belli: la composizione visiva più significativa dell'intera tesi, scelta con cura per essere l'ultima immagine che il lettore porta con sé."/>
                <para/>
                <ITEXT CH="Quello che rimane, dopo l'esperienza, non è il ricordo del sistema. È il ricordo di essere stati parte di qualcosa. Di aver visto il proprio gesto tradursi in luce su uno schermo, di aver riconosciuto il proprio colore nel flusso degli altri, di aver partecipato a una decisione collettiva senza che nessuno lo avesse organizzato davvero."/>
                <para/>
                <ITEXT CH="La tecnologia che produce questa esperienza scompare durante l'esperienza stessa. Il telefono in mano si dimentica. Lo schermo smette di essere uno schermo e diventa un fenomeno. Questo sparire è l'obiettivo di ogni design che funziona davvero. Una sparizione che fa spazio a qualcosa di più importante, non una rinuncia pigra."/>
                <para/>
                <ITEXT CH="C'è una cosa che vale la pena dire, alla fine, sul perché di questo progetto. L'ho costruito perché volevo vedere cosa sarebbe successo se avessi messo insieme un sistema complesso e delle persone in una stanza buia, senza spiegare nulla. Non per dimostrare l'efficacia di un algoritmo o per esplorare una tecnologia nuova. Quello che è successo, ogni volta che ho provato, è che le persone hanno cominciato a giocare. A esplorare. A collaborare senza che nessuno glielo chiedesse."/>
                <para/>
                <ITEXT CH="È una cosa piccola. Ma dice qualcosa su come le persone si comportano quando si sentono libere, quando non c'è una risposta giusta, quando il sistema che le circonda è abbastanza aperto da contenere qualsiasi cosa decidano di fare."/>
                <para/>
                <ITEXT CH="Forse è questo che manca, nel rapporto ordinario con i sistemi intelligenti. Non potenza in più, non accuratezza in più. Spazio in più. Spazio per fare cose che nessuno aveva previsto."/>
                <para/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="140.00062992126" YPOS="10859.6809448819" OwnPage="33" ItemID="352594320" PTYPE="4" WIDTH="339.527559055118" HEIGHT="139.527559055117" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="2" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L339.528 0 L339.528 139.528 L0 139.528 L0 0 Z" copath="M0 0 L339.528 0 L339.528 139.528 L0 139.528 L0 0 Z" gXpos="735.27502992126" gYpos="4686.4615496063" gWidth="0" gHeight="0" PSTYLE="section_title" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle PARENT="section_title"/>
                <ITEXT CH="Concept e intenzione"/>
                <trail PARENT="section_title"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="559.528188976378" YPOS="695.276535433071" OwnPage="2" ItemID="348353744" PTYPE="4" WIDTH="339.527559055118" HEIGHT="515.275590551181" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L339.528 0 L339.528 515.276 L0 515.276 L0 0 Z" copath="M0 0 L339.528 0 L339.528 515.276 L0 515.276 L0 0 Z" gXpos="559.528188976378" gYpos="695.276535433071" gWidth="0" gHeight="0" PSTYLE="section_body" LAYER="0" NEXTITEM="-1" BACKITEM="299110224"/>
        <PAGEOBJECT XPOS="86.3274015748031" YPOS="1912.15385826772" OwnPage="5" ItemID="348345296" PTYPE="6" WIDTH="866.401574803149" HEIGHT="622.622047244094" FRTYPE="0" CLIPEDIT="1" PWIDTH="1" PCOLOR="Black" PCOLOR2="Black" PLINEART="1" path="M0 0 L866.402 0 L866.402 622.622 L0 622.622 L0 0 Z" copath="M0 0 L866.402 0 L866.402 622.622 L0 622.622 L0 0 Z" gXpos="0.199037620297418" gYpos="2.27937007873675" gWidth="866.799650043745" gHeight="627.180787401575" LAYER="2"/>
        <PAGEOBJECT XPOS="559.528188976378" YPOS="1965.82708661417" OwnPage="6" ItemID="352692752" PTYPE="4" WIDTH="339.527559055118" HEIGHT="515.275590551183" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="2" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L339.528 0 L339.528 515.276 L0 515.276 L0 0 Z" copath="M0 0 L339.528 0 L339.528 515.276 L0 515.276 L0 0 Z" gXpos="473.399825021872" gYpos="55.9525984251975" gWidth="866.799650043745" gHeight="627.180787401575" PSTYLE="section_title" LAYER="3" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle PARENT="section_title" FONTSIZE="100"/>
                <ITEXT CH="L'arte che risponde"/>
                <trail PARENT="section_megatitle"/>
            </StoryText>
            <PageItemAttributes>
                <ItemAttribute Name="TOC" Type="none" Value="SHIIIII" Parameter="" Relationship="none" RelationshipTo="" AutoAddTo="none"/>
