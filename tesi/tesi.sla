        <MASTEROBJECT XPOS="263.465196850394" YPOS="530.237480314961" OwnPage="1" ItemID="346834037" PTYPE="4" WIDTH="92.5984251968504" HEIGHT="85.0393700787403" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="1" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L92.5984 0 L92.5984 85.0394 L0 85.0394 L0 0 Z" copath="M0 0 L92.5984 0 L92.5984 85.0394 L0 85.0394 L0 0 Z" OnMasterPage="Normal Right" gXpos="1335878795.71151" gYpos="39097379939.4476" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
