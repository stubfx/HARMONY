        <PAGEOBJECT XPOS="559.528188976378" YPOS="4506.92818897638" OwnPage="14" ItemID="759019933" PTYPE="4" WIDTH="339.527559055118" HEIGHT="515.275590551181" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L339.528 0 L339.528 515.276 L0 515.276 L0 0 Z" copath="M0 0 L339.528 0 L339.528 515.276 L0 515.276 L0 0 Z" gXpos="559.528188976378" gYpos="4506.92818897638" gWidth="0" gHeight="0" PSTYLE="Default Paragraph Style" LAYER="0" NEXTITEM="759008397" BACKITEM="791308989"/>
        <PAGEOBJECT XPOS="161.228976377953" YPOS="5142.20346456693" OwnPage="15" ItemID="759008397" PTYPE="4" WIDTH="318.299212598425" HEIGHT="515.275590551181" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L318.299 0 L318.299 515.276 L0 515.276 L0 0 Z" copath="M0 0 L318.299 0 L318.299 515.276 L0 515.276 L0 0 Z" gXpos="161.228976377953" gYpos="5142.20346456693" gWidth="0" gHeight="0" PSTYLE="Default Paragraph Style" LAYER="0" NEXTITEM="759033741" BACKITEM="759019933"/>
        <PAGEOBJECT XPOS="559.528188976378" YPOS="5142.20346456693" OwnPage="16" ItemID="759033741" PTYPE="4" WIDTH="339.527559055118" HEIGHT="515.275590551181" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L339.528 0 L339.528 515.276 L0 515.276 L0 0 Z" copath="M0 0 L339.528 0 L339.528 515.276 L0 515.276 L0 0 Z" gXpos="559.528188976378" gYpos="5142.20346456693" gWidth="0" gHeight="0" PSTYLE="Default Paragraph Style" LAYER="0" NEXTITEM="-1" BACKITEM="759008397"/>
