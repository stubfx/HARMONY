        <PAGEOBJECT XPOS="84.6666666666663" YPOS="5719.29228346457" OwnPage="17" ItemID="730893965" PTYPE="2" WIDTH="770.767034120735" HEIGHT="627.635275590552" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="0.2732" LOCALSCY="0.2732" LOCALX="-191.556857003416" LOCALY="221.997286942355" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" Pagenumber="0" PFILE="assets/bird_flock.png" PRFILE="Embedded sRGB built-in" IRENDER="0" EPROF="Embedded sRGB built-in" TransValue="0.95" path="M0 0 L770.767 0 L770.767 627.635 L0 627.635 L0 0 Z" copath="M0 0 L770.767 0 L770.767 627.635 L0 627.635 L0 0 Z" gXpos="84.6666666666663" gYpos="5719.29228346457" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1"/>
        <PAGEOBJECT XPOS="161.228976377953" YPOS="1330.55181102362" OwnPage="3" ItemID="728069805" PTYPE="4" WIDTH="318.299212598425" HEIGHT="515.275590551182" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="28.3464566929134" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L318.299 0 L318.299 515.276 L0 515.276 L0 0 Z" copath="M0 0 L318.299 0 L318.299 515.276 L0 515.276 L0 0 Z" gXpos="161.228976377953" gYpos="1330.55181102362" gWidth="0" gHeight="0" PSTYLE="Default Paragraph Style" LAYER="0" NEXTITEM="791285693" BACKITEM="-1">
            <StoryText>
                <DefaultStyle PARENT="Default Paragraph Style" LINESPMode="1" CPARENT="Default Character Style"/>
                <ITEXT CH="Introduzione"/>
                <para PARENT="section_subtitle"/>
                <ITEXT CH="C'è un verbo nuovo nel modo in cui parliamo dei sistemi computazionali. Prima si cercava su Google. Adesso si chiede a ChatGPT. "/>
                <ITEXT CPARENT="Italic" CH="Chiedere"/>
                <ITEXT CH=" implica che dall'altra parte ci sia qualcuno in grado di capire, di interpretare, di rispondere nel senso pieno della parola. È una piccola cosa, ma dice molto su come stiamo ridefinendo il confine tra strumento e interlocutore."/>
                <para/>
                <ITEXT CH="Eppure, guardando da vicino come funziona questa interazione, c'è qualcosa che non torna. Il formato è sempre lo stesso, io scrivo, il sistema risponde, io scrivo di nuovo, un turno alla volta, in sequenza, come una corrispondenza per lettera accelerata. Il sistema non fa mai la prima mossa. Non si manifesta finché non viene chiamato. Vive in uno stato di attesa permanente, pronto a rispondere ma incapace di proporre."/>
                <para/>
                <ITEXT CH="Questo crea una relazione strana. Gli attribuiamo qualcosa che somiglia a un pensiero. Eppure lo trattiamo come un servizio, lo convochiamo quando ci serve, otteniamo quello che cercavamo e poi la conversazione finisce. L'interazione è sempre privata e sempre orientata verso un risultato preciso. C'è poco spazio per quello che non è stato chiesto."/>
                <para/>
                <ITEXT CH="Quello che mi ha incuriosito è capire cosa succederebbe se il sistema non aspettasse di essere interrogato, ma fosse già presente, già in movimento, già impegnato a fare qualcosa. A fare il primo passo nel momento in cui le persone entrano nella stanza, e a continuare a farlo che ci sia qualcuno o no. Un sistema con un proprio ritmo già in corso, dentro cui ci si infila come si entra in una conversazione che è già iniziata, senza poterla portare dall'inizio. Si arriva tardi, e si sceglie se ascoltare o se dire qualcosa."/>
                <para/>
                <ITEXT CH="Mi sono chiesto come sarebbe interagire con un sistema vivo, che segue un suo ritmo, che risponde al gruppo invece che al singolo, e che cambia forma in base a come quel gruppo si organizza."/>
                <para/>
                <ITEXT CH="Questo progetto nasce da quella domanda."/>
                <para/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="124.00062992126" YPOS="3751.65322834646" OwnPage="9" ItemID="728445389" PTYPE="4" WIDTH="515.275590551181" HEIGHT="16" FRTYPE="0" CLIPEDIT="0" ROT="270" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="2" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L515.276 0 L515.276 16 L0 16 L0 0 Z" copath="M0 0 L515.276 0 L515.276 16 L0 16 L0 0 Z" gXpos="124.00062992126" gYpos="3751.65322834646" gWidth="0" gHeight="0" PSTYLE="section_title" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle PARENT="section_title"/>
                <ITEXT CH="L'arte che risponde."/>
                <trail PARENT="section_title"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="161.228976377953" YPOS="3236.37763779528" OwnPage="9" ItemID="730109101" PTYPE="4" WIDTH="318.299212598425" HEIGHT="515.275590551184" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="28.3464566929134" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L318.299 0 L318.299 515.276 L0 515.276 L0 0 Z" copath="M0 0 L318.299 0 L318.299 515.276 L0 515.276 L0 0 Z" gXpos="161.228976377953" gYpos="3236.37763779528" gWidth="0" gHeight="0" PSTYLE="Default Paragraph Style" LAYER="0" NEXTITEM="746579533" BACKITEM="-1">
            <StoryText>
                <DefaultStyle PARENT="Default Paragraph Style" LINESPMode="1" CPARENT="Default Character Style"/>
                <ITEXT CH="1. L'arte"/>
                <para PARENT="section_subtitle"/>
                <ITEXT CH="Non tutte le opere hanno bisogno di qualcuno. Un quadro appeso resta quello che è anche in una sala vuota in cui il pubblico passa, guarda, esce, e non lascia traccia. Esistono però opere che senza una persona davanti sono solo un sistema in attesa, e che con quella persona diventano qualcos'altro. Il progetto di questa tesi è una di queste, e non è il primo. Appartiene a una tradizione che ha attraversato tutta la seconda metà del Novecento. Quella tradizione nasce da un'insoddisfazione. Per una parte degli artisti, tra gli anni Cinquanta e Sessanta, l'oggetto chiuso nella cornice aveva smesso di essere l'unico posto in cui l'arte poteva accadere. La spinta, però, non era semplicemente far partecipare il pubblico, perché la partecipazione da sola scivola facilmente nell'intrattenimento. Era qualcosa di più esigente. Si trattava di un'opera che non stesse ferma ad aspettare lo sguardo, ma che percepisse chi le stava davanti, gli rispondesse, e in certi casi esistesse soltanto perché c'erano delle persone, spesso molte insieme. Questa possibilità è stata esplorata in modi diversi. C'è chi ha portato il corpo del pubblico dentro l'opera, chi ha dato alla macchina un ruolo attivo, chi ha fatto del collettivo il materiale del lavoro. Quasi sempre, senza spiegare nulla a chi entrava."/>
                <para/>
                <ITEXT CH="1.1 Dalla contemplazione alla partecipazione"/>
                <para PARENT="section_subtitle"/>
                <ITEXT CH="Il primo cambiamento riguarda il ruolo di chi guarda. Per secoli l'opera era stata qualcosa da contemplare a distanza, e il pubblico restava un testimone, finché alcuni artisti hanno cominciato a chiedere di più, a volere che le persone entrassero, si muovessero e facessero qualcosa perché l'opera accadesse, trasformando lo spettatore in parte attiva dell'esperienza. Qui però si apre una differenza che per questo progetto conta molto. In alcune di quelle opere il pubblico diventava letteralmente il contenuto, perché senza i corpi delle persone non restava niente da vedere ed erano loro stesse a costituire l'opera. Questo progetto prende un'altra strada, perché le persone non diventano l'opera ma restano distinte da essa, reagiscono al sistema e decidono come va a finire, e quello che si vede nasce dal loro incontro con la macchina, due cose che rimangono separate. C'è poi un secondo aspetto, perché alcune di quelle opere non aspettavano il pubblico per cominciare, ma erano già in movimento e avevano già una vita propria, così che chi entrava si trovava dentro qualcosa che era partito senza di lui. È l'idea su cui si regge questo progetto, dove la macchina è viva nella stanza prima che arrivi la prima persona e continua a esserlo dopo che l'ultima è uscita."/>
                <para/>
                <ITEXT CH="1.2 La macchina come presenza"/>
                <para PARENT="section_subtitle"/>
                <ITEXT CH="Con la tecnologia questa relazione cambia natura, perché la macchina smette di essere lo sfondo o lo strumento neutro e prova a diventare una presenza, qualcosa che ha una propria logica e un proprio comportamento. La parola «presenza», però, può voler dire due cose molto diverse, e la distanza tra le due è il punto di questa sezione. Da una parte c'è la macchina che reagisce, quella che traduce in immagini o in suono quello che le persone fanno e che, senza un gesto da cui partire, resta ferma ad aspettare. È una presenza condizionata, una specie di specchio che rimanda quello che riceve ma che da solo non produce niente, e che si accende soltanto quando qualcuno arriva a metterla in moto. Dall'altra parte c'è una macchina che è già viva di suo, che ha un suo movimento e un suo ritmo anche quando la stanza è vuota, e che chi entra non attiva ma incontra, trovandola già in corso. Il pubblico può intervenire e cambiarne la direzione, ma non è lui ad accenderla, perché lei era sveglia da prima. La differenza tra le due non è tecnica ma di postura. La prima macchina dorme finché non la si sveglia, la seconda è sveglia da prima che arrivi qualcuno, ed è in questa seconda famiglia, quella delle macchine già vive, che il progetto si riconosce."/>
                <para/>
                <ITEXT CH="1.3 Il collettivo come materiale"/>
                <para PARENT="section_subtitle"/>
                <ITEXT CH="C'è poi una famiglia di opere che spinge tutto questo ancora più in là, perché esistono solo grazie alla presenza di molte persone insieme e quello che mostrano nasce proprio dal fatto che le persone sono tante. Non si tratta della somma dei singoli gesti, ma di una forma che nessuno ha disegnato e che compare soltanto quando il gruppo diventa abbastanza grande. Basta immaginare uno spazio in cui ognuno, muovendosi per conto suo, lascia attorno a sé una piccola traccia, e pensare a cosa succede quando le persone diventano molte, perché quelle tracce si moltiplicano e si sovrappongono fino a formare una geometria che cambia di continuo e che nessuno dei presenti ha deciso. Da solo non la si potrebbe ottenere, perché serve la quantità, serve che tante volontà separate agiscano nello stesso momento senza mettersi d'accordo. È questo il senso di «collettivo» che interessa al progetto, e non l'immersione o il pubblico che si scioglie nell'ambiente, perché qui le persone restano distinte e proprio agendo ciascuna per sé fanno emergere una forma comune. Togli i corpi e la loro simultaneità e l'opera non si indebolisce, semplicemente non c'è più, e resta soltanto un sistema in attesa."/>
                <para/>
                <ITEXT CH="1.4 Il mistero come scelta estetica"/>
                <para PARENT="section_subtitle"/>
                <ITEXT CH="L'ultima scelta riguarda il modo in cui un'opera si lascia capire, o meglio il modo in cui decide di non lasciarsi capire fino in fondo. Ci sono lavori in cui quello che si vede non si riesce mai a mettere del tutto a fuoco, in cui l'occhio continua a cercare un bordo, una distanza, una superficie a cui appoggiarsi e non la trova, e questa impossibilità di risolvere ciò che si ha davanti non è un limite ma è proprio il centro dell'esperienza. Quando si entra in un luogo e non si capisce subito cosa stia succedendo cambia il modo di starci, perché ci si ferma, si guarda più a lungo, si prova un gesto per vedere cosa cambia, e quel non capire immediatamente apre uno spazio che una spiegazione chiuderebbe in pochi secondi. Chi guarda smette di essere qualcuno a cui viene detto qualcosa e diventa qualcuno che esplora. È una posizione che questo progetto fa propria, perché niente spiega come funziona il sistema e lo si capisce soltanto usandolo, e perché le forme che compaiono sullo schermo non chiedono di essere riconosciute come oggetti ma restano qualcosa che si può solo guardare mentre accade. Resta però una domanda. Cosa rende un sistema capace di rispondere a molte persone insieme, in modo distribuito, senza un centro che lo governi? Serve una logica diversa da quella di un motore unico, una logica in cui ogni elemento decide soltanto per sé e ascolta solo i vicini più prossimi, e in cui, nonostante questo, l'insieme produce un comportamento unitario che dall'esterno si riconosce come un'unica forma in movimento. È proprio questa logica il tema del prossimo capitolo, il modo in cui un'intelligenza collettiva emerge senza che nessuno la pianifichi."/>
                <para/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="559.528188976378" YPOS="3236.37763779527" OwnPage="10" ItemID="746579533" PTYPE="4" WIDTH="339.527559055118" HEIGHT="515.275590551183" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" ANNAME="body_2col" TEXTFLOWMODE="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="28.3464566929134" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L339.528 0 L339.528 515.276 L0 515.276 L0 0 Z" copath="M0 0 L339.528 0 L339.528 515.276 L0 515.276 L0 0 Z" gXpos="-462.97392895888" gYpos="3166.20262992126" gWidth="0" gHeight="0" PSTYLE="Default Paragraph Style" LAYER="0" NEXTITEM="747110173" BACKITEM="730109101"/>
        <PAGEOBJECT XPOS="161.228976377953" YPOS="3871.65291338582" OwnPage="11" ItemID="747110173" PTYPE="4" WIDTH="318.299212598425" HEIGHT="515.275590551184" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" ANNAME="Copy of body_2col" TEXTFLOWMODE="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="28.3464566929134" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L318.299 0 L318.299 515.276 L0 515.276 L0 0 Z" copath="M0 0 L318.299 0 L318.299 515.276 L0 515.276 L0 0 Z" gXpos="-468.220333858267" gYpos="2731.92280209975" gWidth="0" gHeight="0" PSTYLE="Default Paragraph Style" LAYER="0" NEXTITEM="746577789" BACKITEM="746579533"/>
        <PAGEOBJECT XPOS="559.528188976378" YPOS="3871.65291338582" OwnPage="12" ItemID="746577789" PTYPE="4" WIDTH="339.527559055118" HEIGHT="515.275590551184" FRTYPE="0" CLIPEDIT="1" PWIDTH="1" PLINEART="1" ANNAME="Copy of body_2col (2)" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="28.3464566929134" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L339.528 0 L339.528 515.276 L0 515.276 L0 0 Z" copath="M0 0 L339.527 0 L339.527 515.276 L0 515.276 L0 0 Z" gXpos="-618.564480139982" gYpos="2827.03391321086" gWidth="0" gHeight="0" PSTYLE="Default Paragraph Style" LAYER="0" NEXTITEM="791308989" BACKITEM="747110173"/>
        <PAGEOBJECT XPOS="161.228976377953" YPOS="6412.75401574803" OwnPage="19" ItemID="752301949" PTYPE="4" WIDTH="318.299212598425" HEIGHT="515.275590551179" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="28.3464566929134" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L318.299 0 L318.299 515.276 L0 515.276 L0 0 Z" copath="M0 0 L318.299 0 L318.299 515.276 L0 515.276 L0 0 Z" gXpos="161.228976377953" gYpos="4648.97704566929" gWidth="0" gHeight="0" PSTYLE="Default Paragraph Style" LAYER="0" NEXTITEM="746523085" BACKITEM="-1">
            <StoryText>
                <DefaultStyle PARENT="Default Paragraph Style" LINESPMode="1" CPARENT="Default Character Style"/>
                <ITEXT CH="2. Lo sciame"/>
                <para PARENT="section_subtitle"/>
                <ITEXT CH="C'è qualcosa di difficile da spiegare nella sensazione che si prova guardando uno stormo di storni muoversi nel cielo al tramonto. Non è soltanto bellezza visiva, è la percezione che quella forma stia pensando, che abbia intenzioni, che sappia dove vuole andare."/>
                <para/>
                <ITEXT CH="Non lo sa. O almeno, non nel senso in cui lo sappiamo noi."/>
                <para/>
                <ITEXT CH="2.1 In natura"/>
                <para PARENT="section_subtitle"/>
                <ITEXT CH="La murmuration degli storni è forse il fenomeno collettivo più fotografato e studiato degli ultimi decenni. Migliaia di uccelli, a volte centinaia di migliaia, si muovono insieme come un unico organismo fluido, si espandono, si contraggono, girano, si dividono e si ricompongono senza che nessuno dia ordini. Gli studi hanno mostrato che ogni storno non tiene d'occhio l'intero stormo, ma soltanto una manciata di vicini, in media fra sei e sette, e regola su di loro la propria traiettoria. Avvicìnati a sufficienza, mantieni la velocità, evita gli urti, tre istruzioni e nient'altro, da cui nasce quello che vediamo nel cielo."/>
                <para/>
                <ITEXT CPARENT="Bold" CH="[IMG]"/>
                <ITEXT CH=" Fotografia di una murmuration di storni al tramonto: la forma collettiva che cambia nel cielo, nessun punto di partenza riconoscibile."/>
                <para/>
                <ITEXT CH="Le colonie di formiche funzionano sullo stesso principio, declinato in modo diverso. Una singola formica è quasi cieca, con una memoria brevissima e un repertorio di comportamenti molto limitato, eppure una colonia trova i percorsi più brevi tra il nido e il cibo, gestisce i propri morti, si difende dagli intrusi, e in alcune specie regola perfino la temperatura del nido. Lo fa attraverso la chimica, perché i feromoni lasciati da ogni formica modificano il comportamento di quelle che passano dopo. L'intelligenza non sta in nessuna formica, sta nel sistema di tracce che le formiche depositano nell'ambiente."/>
                <para/>
                <ITEXT CPARENT="Bold" CH="[IMG]"/>
                <ITEXT CH=" Colonia di formiche fotografata dall'alto: percorsi convergenti verso una fonte di cibo, organizzazione senza centro visibile."/>
                <para/>
                <ITEXT CH="Il Physarum polycephalum porta questo principio al suo estremo più sorprendente. È un organismo che vive in una zona grigia della biologia, a metà tra un animale e una pianta e in realtà né l'uno né l'altra, una massa unicellulare di colore giallo brillante che si espande lentamente su superfici umide in cerca di nutrimento. Non possiede neuroni, eppure, messo davanti a fonti di cibo distribuite nello spazio, trova quasi sempre il percorso più efficiente per collegarle. In un esperimento diventato celebre alcuni ricercatori hanno disposto frammenti di nutrimento come le città dell'area di Tokyo e hanno lasciato che il micelio crescesse tra loro, e in poche ore quello aveva formato una rete di connessioni quasi identica alla rete ferroviaria reale, costruita da ingegneri in decenni di pianificazione."/>
                <para/>
                <ITEXT CPARENT="Bold" CH="[IMG]"/>
                <ITEXT CH=" Il Physarum polycephalum che cresce su un piano con fonti di cibo posizionate come le città dell'area di Tokyo: la rete del micelio a confronto con la mappa ferroviaria reale."/>
                <para/>
                <ITEXT CH="Storni, formiche, Physarum. Tre sistemi che non si somigliano quasi per niente, eppure condividono la stessa struttura profonda, nessun coordinamento centrale, nessun piano complessivo, nessun elemento che veda più degli altri. Il comportamento globale emerge da interazioni locali ripetute milioni di volte."/>
                <para/>
                <ITEXT CH="2.2 Le regole semplici"/>
                <para PARENT="section_subtitle"/>
                <ITEXT CH="A un certo livello di organizzazione appare qualcosa che, nelle parti prese da sole, non c'era. La biologia ha un nome per questo fenomeno, l'emergenza."/>
                <para/>
                <ITEXT CH="Un comportamento è emergente quando compare a un livello superiore rispetto alle componenti che lo generano, senza che nessuna di quelle componenti lo contenesse già. Non è magia, è una proprietà strutturale dei sistemi complessi, studiata con strumenti matematici e computazionali da decenni. Resta però controintuitiva, perché siamo abituati a pensare che la complessità richieda una mente complessa, e quando vediamo lo stormo curvare all'unisono cerchiamo d'istinto il leader, il punto di partenza, la volontà che ha deciso la forma. Non c'è."/>
                <para/>
                <ITEXT CH="Il concetto di agente autonomo descrive l'unità base di questi sistemi, un'entità che percepisce solo l'ambiente vicino, segue poche regole semplici e reagisce di conseguenza, senza istruzioni dall'esterno e senza una visione d'insieme. Ogni agente è per definizione parziale, vede una piccola porzione del mondo, agisce su quella, e produce effetti che diventano parte dell'ambiente percepito dagli altri. Il sistema è la somma di tutte queste azioni parziali, ma produce qualcosa che nessuna azione singola avrebbe potuto produrre."/>
                <para/>
                <ITEXT CPARENT="Bold" CH="[IMG]"/>
                <ITEXT CH=" Diagramma delle tre regole del modello Boids (separazione, allineamento, coesione): ogni agente e il suo campo di percezione locale, senza visione globale."/>
                <para/>
                <ITEXT CH="Il paradosso dell'intelligenza distribuita sta proprio qui, il sistema si comporta come se qualcuno lo guidasse, ma non c'è nessuno che guida. La forma nasce dalle relazioni, non dagli elementi, e il fatto che possa essere bella, funzionale o sorprendente non cambia la natura di ciò che la genera."/>
                <para/>
                <ITEXT CH="2.3 Dallo sciame biologico a quello digitale"/>
                <para PARENT="section_subtitle"/>
                <ITEXT CH="Nel 1987 l'informatico Craig Reynolds presentò al SIGGRAPH, la principale conferenza di computer grafica, un sistema di simulazione che aveva chiamato Boids, con l'obiettivo di replicare il comportamento degli storni in un ambiente digitale. Aveva dato a ogni agente tre regole, separazione (mantieni una distanza minima dai vicini per non scontrarti), allineamento (vai nella direzione media dei vicini), coesione (tendi verso il centro del gruppo vicino). Nessuna regola globale, nessuna mappa dell'intero sistema."/>
                <para/>
                <ITEXT CH="Il risultato sorprese anche chi l'aveva costruito. I Boids si dividevano attorno agli ostacoli e si riunivano dall'altra parte, oscillavano, formavano code, si separavano e si ricompattavano. Reynolds aveva scritto tre regole, e il sistema ne mostrava molte di più, tutte emergenti e nessuna programmata, con quella qualità viva e auto-organizzata che nasceva da meccanismi presi uno per uno quasi banali."/>
                <para/>
                <ITEXT CPARENT="Bold" CH="[IMG]"/>
                <ITEXT CH=" Visualizzazione del modello Boids: agenti in movimento con le loro direzioni individuali visibili, che formano un flusso collettivo riconoscibile."/>
                <para/>
                <ITEXT CH="Da allora i principi dello sciame sono diventati uno strumento usato in contesti molto diversi. Gli algoritmi ispirati alle colonie di formiche servono a risolvere problemi di instradamento nelle reti e nella logistica, il comportamento del Physarum ha ispirato sistemi di ottimizzazione per la progettazione di infrastrutture, e le simulazioni di stormi vengono usate per modellare l'evacuazione delle folle, per animare masse di personaggi nei film, per generare immagini nell'arte digitale."/>
                <para/>
                <ITEXT CH="In tutti questi casi la simulazione fa due cose diverse. È uno strumento di analisi, perché costruire un sistema che si comporta come quello reale permette di isolare le regole che lo governano, ed è uno strumento creativo, perché le stesse logiche che spiegano il comportamento degli storni possono generare qualcosa che non sarebbe nato da una mente sola, qualcosa che sorprende anche chi lo ha costruito."/>
                <para/>
                <ITEXT CH="Questo progetto appartiene alla seconda categoria. Usa la logica dello sciame come strumento di costruzione, senza pretesa di fedeltà biologica, perché l'obiettivo è la qualità percettiva, la sensazione di trovarsi davanti a un organismo invece che a un programma."/>
                <para/>
                <ITEXT CH="Lo stesso principio si ritrova in un altro esempio classico, il Game of Life ideato dal matematico John Conway nel 1970. Qui non ci sono agenti che si muovono, ma una griglia di celle che vivono o muoiono in base a poche regole che contano solo i vicini immediati, e da quelle regole nascono forme che si spostano, si ripetono e si trasformano senza che nessuno le abbia disegnate. È un automa cellulare, l'emergenza nella sua forma più nuda. I Boids e il Game of Life sono i due sistemi autonomi da cui questo progetto ha preso spunto. Non vengono riprodotti tali e quali, ma è da loro che arriva l'idea di fondo, una macchina con un comportamento proprio, in cui l'ordine d'insieme emerge da regole locali e nessuno tiene il timone."/>
                <para/>
                <ITEXT CH="2.4 Lo sciame come metafora"/>
                <para PARENT="section_subtitle"/>
                <ITEXT CH="C'è un'ultima cosa che i sistemi collettivi rivelano, e riguarda noi."/>
                <para/>
                <ITEXT CH="Usare lo sciame come modello per parlare di persone è una scelta con implicazioni precise. Gli esseri umani si aggregano, si influenzano a vicenda, producono comportamenti collettivi che nessuno ha pianificato, le mode, i movimenti, le ondate di panico o di entusiasmo in una folla. È il modo in cui un pubblico a teatro smette di essere una somma di individui e diventa qualcosa di unitario, con un'unica attenzione e una risposta emotiva condivisa che nessuno ha deciso ma che tutti stanno vivendo."/>
                <para/>
                <ITEXT CPARENT="Bold" CH="[IMG]"/>
                <ITEXT CH=" Fotografia di una folla o di un pubblico vista dall'alto: la struttura collettiva visibile, i singoli individui distinguibili ma parte di un pattern più grande."/>
                <para/>
                <ITEXT CH="Queste dinamiche non sono belle o brutte in sé, sono reali. E il fatto che funzionino secondo principi simili a quelli degli storni o delle formiche dice qualcosa di interessante, perché l'intelligenza collettiva emerge in qualunque contesto in cui agenti abbastanza semplici si trovano abbastanza vicini e abbastanza a lungo. I sistemi biologici sono solo uno di quei contesti."/>
                <para/>
                <ITEXT CH="Le città funzionano in modo simile a una colonia di formiche, perché nessuno progetta dall'alto i quartieri creativi, i mercati, le vie del commercio, che emergono invece da migliaia di decisioni individuali che si accumulano e si rinforzano a vicenda. La differenza è che gli esseri umani, a differenza delle formiche, sanno di farne parte. Possono osservare il sistema di cui sono elementi, e possono perfino scegliere di comportarsi diversamente una volta che ne riconoscono la logica."/>
                <para/>
                <ITEXT CH="È questa consapevolezza il punto che interessa al progetto, cosa succede quando le persone sanno di comportarsi come uno sciame, quando qualcuno mostra loro che il loro comportamento collettivo ha una forma, che quella forma è visibile in tempo reale, e che la si può osservare mentre si contribuisce a crearla."/>
                <para/>
                <ITEXT CH="Cosa cambia, nell'esperienza di far parte di qualcosa, quando si riesce a vederlo dall'interno?"/>
                <para/>
                <ITEXT CH="Capire la logica di uno sciame è una cosa, diventarne parte è un'altra. Il capitolo che segue riguarda il punto di contatto tra la persona e il sistema, il corpo, il gesto e il dispositivo che in questo progetto li mette in relazione."/>
                <para/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="559.528188976378" YPOS="6412.75401574803" OwnPage="20" ItemID="746523085" PTYPE="4" WIDTH="339.527559055118" HEIGHT="515.275590551185" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" ANNAME="Copy of body_2col (3)" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="28.3464566929134" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L339.528 0 L339.528 515.276 L0 515.276 L0 0 Z" copath="M0 0 L339.528 0 L339.528 515.276 L0 515.276 L0 0 Z" gXpos="-713.476676815398" gYpos="4422.35723779528" gWidth="0" gHeight="0" PSTYLE="Default Paragraph Style" LAYER="0" NEXTITEM="753917005" BACKITEM="752301949"/>
        <PAGEOBJECT XPOS="161.228976377953" YPOS="7048.02929133859" OwnPage="21" ItemID="753917005" PTYPE="4" WIDTH="318.299212598425" HEIGHT="515.275590551177" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" ANNAME="Copy of body_2col (4)" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="28.3464566929134" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L318.299 0 L318.299 515.276 L0 515.276 L0 0 Z" copath="M0 0 L318.299 0 L318.299 515.276 L0 515.276 L0 0 Z" gXpos="-464.107787226596" gYpos="4173.76363149607" gWidth="0" gHeight="0" PSTYLE="Default Paragraph Style" LAYER="0" NEXTITEM="746545917" BACKITEM="746523085"/>
        <PAGEOBJECT XPOS="559.528188976378" YPOS="7048.02929133859" OwnPage="22" ItemID="746545917" PTYPE="4" WIDTH="339.527559055118" HEIGHT="515.275590551177" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" ANNAME="Copy of body_2col (5)" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="28.3464566929134" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L339.528 0 L339.528 515.276 L0 515.276 L0 0 Z" copath="M0 0 L339.528 0 L339.528 515.276 L0 515.276 L0 0 Z" gXpos="-594.365565704287" gYpos="4169.63251338583" gWidth="0" gHeight="0" PSTYLE="Default Paragraph Style" LAYER="0" NEXTITEM="796122765" BACKITEM="753917005"/>
        <PAGEOBJECT XPOS="161.228976377953" YPOS="9589.13039370078" OwnPage="29" ItemID="757545917" PTYPE="4" WIDTH="318.299212598425" HEIGHT="515.275590551185" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="28.3464566929134" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L318.299 0 L318.299 515.276 L0 515.276 L0 0 Z" copath="M0 0 L318.299 0 L318.299 515.276 L0 515.276 L0 0 Z" gXpos="756.503376377953" gYpos="6061.57645354329" gWidth="0" gHeight="0" PSTYLE="Default Paragraph Style" LAYER="0" NEXTITEM="792450893" BACKITEM="-1">
            <StoryText>
                <DefaultStyle PARENT="Default Paragraph Style" LINESPMode="1" CPARENT="Default Character Style"/>
                <ITEXT CH="3. Il corpo"/>
                <para PARENT="section_subtitle"/>
                <ITEXT CH="La mano è stata la prima interfaccia. Molto prima delle parole e della scrittura, il corpo umano ha imparato a comunicare con il mondo attraverso il gesto, la postura, il contatto, e ogni tecnologia arrivata dopo non ha sostituito quella relazione ma l'ha soltanto spostata su nuovi oggetti."/>
                <para/>
                <ITEXT CH="Lo smartphone è l'ultimo di questi oggetti, e forse il più strano, uno schermo di vetro che risponde al tocco, sente l'inclinazione del corpo e trasmette la posizione nello spazio. In questo progetto quello schermo diventa qualcosa di diverso da ciò per cui è nato, perché smette di essere un portale verso un mondo privato e diventa l'estensione del proprio corpo dentro uno spazio collettivo."/>
                <para/>
                <ITEXT CH="3.1 Il gesto prima delle parole"/>
                <para PARENT="section_subtitle"/>
                <ITEXT CH="Il gesto è più antico del linguaggio. Nei bambini i gesti di indicazione e di richiesta arrivano mesi prima delle prime parole, e in generale gran parte di come comunichiamo passa dal corpo, dalla postura, dalla distanza, dalla direzione dello sguardo, mentre le parole sono una sovrastruttura costruita sopra un sistema molto più antico."/>
                <para/>
                <ITEXT CH="Su questo si appoggiano le interfacce che funzionano meglio, quelle che non chiedono di imparare niente di nuovo ma sfruttano una competenza che il corpo possiede già. Toccare non si impara, è un gesto che le mani conoscono da sempre, e un'interfaccia che usa il tocco come linguaggio attinge a un repertorio che il corpo ha automatizzato in centinaia di migliaia di anni. Non c'è nulla da memorizzare e nulla da decifrare, si poggia il dito e qualcosa risponde."/>
                <para/>
                <ITEXT CPARENT="Bold" CH="[IMG]"/>
                <ITEXT CH=" Studio fotografico di mani che interagiscono con una superficie tattile: gesti naturali di pressione, scorrimento, rotazione, che precedono qualsiasi istruzione."/>
                <para/>
                <ITEXT CH="Quando il gesto diventa dato, però, qualcosa cambia. Toccare un'altra persona e toccare uno schermo sono atti fisicamente simili ma molto diversi nel significato. Il gesto registrato da un sistema digitale perde alcune delle sue sfumature, la pressione variabile, il calore, la continuità del contatto, e in cambio diventa trasmissibile e replicabile. In questo progetto il dito che spinge un joystick virtuale diventa un impulso che muove migliaia di particelle sullo schermo grande. La perdita è reale, il calore di una mano su un'altra mano non passa attraverso il vetro e nessuno lo confonderebbe con un cursore, ma è reale anche il guadagno, perché un dito su un vetro può smuovere migliaia di entità insieme e farsi sentire in un punto della stanza dove la mano non arriverebbe."/>
                <para/>
                <ITEXT CH="3.2 Lo smartphone come strumento"/>
                <para PARENT="section_subtitle"/>
                <ITEXT CH="Quando si pensa a un controller per un sistema interattivo, di solito viene in mente un oggetto costruito apposta, un joystick fisico, un guanto, un dispositivo dedicato. Strumenti del genere hanno senso in certi contesti, ma chiedono alle persone di impararli, di indossarli, di accettarli come mediatori tra sé e il sistema."/>
                <para/>
                <ITEXT CH="Lo smartphone non chiede niente di tutto questo, perché è già in tasca, già acceso, e le sue interfacce di base, il touchscreen, l'accelerometro, il giroscopio, sono diventate familiari a quasi tutti in pochi anni. Usarlo come controller fa leva su qualcosa che è già lì, senza oggetti da distribuire, senza pulsanti da spiegare, senza riti d'iniziazione. Lo si pesca dalla tasca e si comincia."/>
                <para/>
                <ITEXT CPARENT="Bold" CH="[IMG]"/>
                <ITEXT CH=" Schermata dell'interfaccia controller su smartphone: joystick virtuale, selettore colore, sfondo scuro, interfaccia minimale del progetto."/>
                <para/>
                <ITEXT CH="In questo progetto lo smartphone cambia stato nel momento in cui si inquadra il codice QR. Smette di essere un oggetto personale, il mio telefono con le mie app e le mie foto, e diventa un dispositivo collettivo. Il colore che scelgo entra nel sistema insieme a quelli di tutti gli altri, e il gesto che faccio non muove soltanto le mie particelle ma partecipa al movimento dell'intero sciame. Tutto questo succede senza che nessuno lo annunci, e lo si scopre mentre accade."/>
                <para/>
                <ITEXT CH="C'è qualcosa di significativo nel fatto che un oggetto così privato diventi la porta d'accesso a uno spazio comune. Il telefono in tasca è l'archivio della vita di chi lo possiede, i contatti, le foto, le conversazioni, e lo stesso oggetto, qui, diventa un canale verso qualcosa che appartiene a tutti."/>
                <para/>
                <ITEXT CH="3.3 Essere presenti a distanza"/>
                <para PARENT="section_subtitle"/>
                <ITEXT CH="Una tecnologia, quando funziona davvero, tende a sparire dalla percezione. Si intreccia così bene nella vita di tutti i giorni che smettiamo di accorgercene, e lo smartphone è arrivato esattamente a questo punto, un dispositivo che accompagna il corpo ovunque, ne registra la posizione e trasmette dati in continuazione. In questo progetto questa sua natura viene usata di proposito, perché il telefono è il punto di contatto tra il corpo della persona, seduta in sala, e il sistema proiettato sullo schermo grande."/>
                <para/>
                <ITEXT CPARENT="Bold" CH="[IMG]"/>
                <ITEXT CH=" Fotografia di una persona che guarda il telefono mentre, sullo schermo in background, le particelle si muovono in risposta al suo input: la connessione tra il piccolo e il grande."/>
                <para/>
                <ITEXT CH="Questa forma di presenza mediata ha qualcosa di particolare. Il corpo della persona non si vede nel sistema, non c'è un avatar e non c'è una telecamera che riprende chi partecipa, e quello che resta è un colore, una direzione, un piccolo impulso nel flusso collettivo. La persona è presente nello sciame ma non è riconoscibile, esiste come effetto e non come immagine."/>
                <para/>
                <ITEXT CH="Una presenza così, parziale e tradotta, ha dei precedenti. La voce al telefono è presenza senza corpo, il testo in una chat è presenza senza voce, e qui la presenza è ancora più astratta, un colore, una direzione, una piccola perturbazione dentro un sistema complesso. Eppure è reale, perché qualcuno la sta producendo proprio ora, con la mano."/>
                <para/>
                <ITEXT CH="3.4 L'individuo nel gruppo"/>
                <para PARENT="section_subtitle"/>
                <ITEXT CH="C'è un momento preciso, nell'esperienza di questo progetto, in cui qualcosa cambia, ed è quando ci si rende conto di non essere soli. Le altre particelle sullo schermo hanno qualcuno dietro, un altro telefono, un'altra mano, un'altra persona seduta nella stessa sala, e quello che sembrava un sistema automatico si rivela un sistema collettivo, abitato."/>
                <para/>
                <ITEXT CH="Questa scoperta cambia il modo di agire. Si comincia a cercare gli altri nel flusso, a interpretare i loro movimenti, a rispondere a quello che fanno, e lo sciame smette di essere uno sfondo per diventare una conversazione."/>
                <para/>
                <ITEXT CPARENT="Bold" CH="[IMG]"/>
                <ITEXT CH=" Screenshot che mostra più colori distinti mescolati nel flusso delle particelle: la traccia visibile della presenza simultanea di più partecipanti, ognuno riconoscibile dalla propria tinta."/>
                <para/>
                <ITEXT CH="L'anonimato, qui, è la condizione che rende possibile una libertà particolare. Si può muovere lo sciame in qualunque direzione, scegliere qualunque colore, seguire un impulso senza dover rendere conto a nessuno, perché nessun nome è visibile, nessun punteggio tiene il conto e nessuna statistica racconterà poi quanto bene si è partecipato. Questa libertà produce spesso comportamenti inattesi, perché c'è chi esplora i bordi dello schermo, chi prova a coordinarsi con il vicino di posto, e chi resta fermo a guardare cosa fanno gli altri, come se il sistema fosse qualcosa da osservare più che da usare."/>
                <para/>
                <ITEXT CH="Il colore personale resta visibile nello sciame anche quando i partecipanti sono molti. Si mescola, si attenua, cambia in rapporto agli altri, ma c'è, ed è la traccia di una presenza individuale dentro un corpo collettivo. Questa convivenza tra il singolo e il gruppo non si risolve e non trova un equilibrio stabile, ma oscilla, come lo sciame stesso, tra coesione e dispersione, ed è proprio in questa oscillazione che l'esperienza diventa interessante da abitare."/>
                <para/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="161.228976377953" YPOS="12765.5067716535" OwnPage="39" ItemID="752692349" PTYPE="4" WIDTH="318.299212598425" HEIGHT="515.27559055116" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="28.3464566929134" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L318.299 0 L318.299 515.276 L0 515.276 L0 0 Z" copath="M0 0 L318.299 0 L318.299 515.276 L0 515.276 L0 0 Z" gXpos="756.503376377953" gYpos="8356.06434645671" gWidth="0" gHeight="0" PSTYLE="Default Paragraph Style" LAYER="0" NEXTITEM="794071693" BACKITEM="-1">
            <StoryText>
                <DefaultStyle PARENT="Default Paragraph Style" LINESPMode="1" CPARENT="Default Character Style"/>
                <ITEXT CH="4. L'intenzione"/>
                <para PARENT="section_subtitle"/>
                <ITEXT CH="Ogni progetto nasce da una distinzione, e in questo caso la distinzione era semplice da dire e difficile da costruire. Uno schermo mostra qualcosa, un sistema è qualcosa. Sembra una sfumatura, ma in pratica cambia tutto."/>
                <para/>
                <ITEXT CH="4.1 Un organismo, non uno schermo"/>
                <para PARENT="section_subtitle"/>
                <ITEXT CH="Uno schermo mostra, e può mostrare qualunque cosa, un film, una grafica, un dato in tempo reale, perché il legame tra lo schermo e ciò che porta è quello tra un contenitore e il suo contenuto. Domani potrebbe mostrare altro senza cambiare natura."/>
                <para/>
                <ITEXT CH="Un organismo, invece, ha una logica sua. Si comporta in un certo modo perché è fatto in un certo modo, e il suo comportamento nasce dall'interno e si manifesta fuori. La differenza tra mostrare ed essere è di sostanza, perché lo schermo cambia natura ogni volta che gli si proietta sopra un file diverso, mentre l'organismo no, dato che la sua identità coincide con il modo in cui le sue parti si influenzano a vicenda."/>
                <para/>
                <ITEXT CH="Da qui l'obiettivo del progetto, costruire un sistema che si potesse percepire come un organismo. Qualcosa che sembra avere intenzioni proprie, anche se sono solo formule matematiche, che segue un ritmo suo, anche se è generato da un algoritmo, e che reagisce al contesto, anche se quel contesto si riduce a pochi parametri misurabili. L'obiettivo era produrre la sensazione di trovarsi davanti a qualcosa di vivo, senza nessuna pretesa scientifica e senza modellare un organismo reale, ma costruendo un dispositivo estetico che chiede allo spettatore la stessa attenzione che si dà a uno stormo di storni o a un acquario, non quella che si dà a un programma in esecuzione."/>
                <para/>
                <ITEXT CH="La scelta di lavorare con le particelle ha una ragione precisa. Una particella da sola è quasi niente, un punto luminoso con una direzione e una velocità, ma migliaia di particelle che si influenzano seguendo regole semplici producono qualcosa di molto più ricco di ciò che chiunque avrebbe potuto progettare a tavolino. Il sistema trova forme che nessuno aveva previsto, ed è lì che nasce la qualità organica dell'esperienza. Le particelle in sé non somigliano a niente di biologico, sono punti di luce regolati da formule, e l'effetto vivo sta altrove, nell'insieme, e soprattutto nel fatto che il sistema sfugge al controllo completo di chi lo ha costruito. Quando un gruppo di mille particelle si comporta in un modo che non era stato previsto, chi lo ha costruito si ritrova a guardarlo come si guarda una cosa, non come si controlla un programma."/>
                <para/>
                <ITEXT CPARENT="Bold" CH="[IMG]"/>
                <ITEXT CH=" Screenshot del sistema in movimento a piena risoluzione: le particelle come organismo fluido, senza elementi grafici sovrapposti, solo il sistema e il nero."/>
                <para/>
                <ITEXT CH="4.2 La sala come spazio performativo"/>
                <para PARENT="section_subtitle"/>
                <ITEXT CH="L'installazione è pensata per uno spazio preciso, una sala al buio con un grande schermo sulla parete di fronte e le persone libere di sedersi o muoversi. I telefoni sono l'unica luce personale, oltre alla proiezione."/>
                <para/>
                <ITEXT CH="Questa geometria non è casuale. Lo schermo grande dà una scala che fa percepire il sistema come qualcosa che supera il singolo, perché le particelle si muovono in uno spazio più ampio di quanto l'occhio di chi guarda da vicino riesca a contenere. I telefoni, piccoli e quasi nascosti nella mano, sono il punto di contatto tra l'individuo e quel sistema grande, e la distanza fisica tra i due, lo schermo lontano e il telefono vicino, rispecchia la distanza tra il collettivo e il singolo."/>
                <para/>
                <ITEXT CPARENT="Bold" CH="[IMG]"/>
                <ITEXT CH=" Schizzo o diagramma dello spazio espositivo ideale: schermo grande frontale, persone distribuite nella sala, telefoni come punti di luce individuale nell'oscurità."/>
                <para/>
                <ITEXT CH="Il buio è una scelta estetica, non un'esigenza tecnica di proiezione. Toglie le distrazioni, concentra l'attenzione su ciò che accade sullo schermo e crea un raccoglimento che rende l'esperienza più intensa. È un'eredità del cinema, del teatro e delle stanze di luce di certe installazioni contemporanee, e chiunque abbia spento la luce prima di mostrare qualcosa lo sa, perché il buio funziona come la promessa che qualcosa sta per cominciare. È anche una condizione che abbassa le difese, perché al buio, dentro un gruppo, ci si sente meno osservati e si è più disposti a fare qualcosa senza calcolare come si appare agli altri."/>
                <para/>
                <ITEXT CH="Anche la dimensione dello schermo conta. Un monitor da scrivania darebbe un'esperienza del tutto diversa, più personale, più controllabile, meno avvolgente. La scala grande costringe lo sguardo ad accettare di non vedere tutto in una volta, perché bisogna muovere gli occhi, scegliere dove guardare, lasciare che il sistema sia più grande del proprio campo visivo. Questa perdita di controllo percettivo fa parte dell'esperienza."/>
                <para/>
                <ITEXT CH="4.3 Guidare senza imporre"/>
                <para PARENT="section_subtitle"/>
                <ITEXT CH="Il sistema non è muto. Ogni tanto arrivano frammenti di testo o immagini, parole che compaiono sullo schermo e che le particelle abitano, attratte come se il linguaggio avesse un peso fisico. Sono pezzi di una narrazione che non viene mai spiegata per intero, e che orienta senza concludere."/>
                <para/>
                <ITEXT CH="Qui c'è una differenza tra un sistema che racconta e uno che lascia raccontare. Il primo dà una storia completa, con un inizio, uno sviluppo e una fine. Il secondo dà degli indizi e lascia che sia chi guarda a costruire il significato a partire da ciò che ha visto, sentito e fatto. È un'idea vicina a quella di opera aperta che Umberto Eco descrive nel 1962, un lavoro che chiede a chi ne fruisce di completarlo e che cambia di senso a ogni nuovo passaggio. La seconda strada è più difficile, perché obbliga a resistere alla tentazione di spiegare, ma produce un'esperienza più personale, in cui ognuno porta via qualcosa di leggermente diverso."/>
                <para/>
                <ITEXT CPARENT="Bold" CH="[IMG]"/>
                <ITEXT CH=" Screenshot della modalità narrativa: testo visibile sullo schermo, le particelle che si addensano attorno alle parole come attratte da un campo gravitazionale."/>
                <para/>
                <ITEXT CH="La narrazione arriva a frammenti perché l'esperienza dura quanto dura la presenza delle persone nella sala. L'arco non ha un tempo fisso, il sistema segue il ritmo del gruppo, si adatta a quanto le persone sono coinvolte e può accelerare o rallentare. Due sessioni diverse della stessa installazione danno esperienze diverse, perché cambia il comportamento del sistema e cambia il significato che il pubblico ci costruisce sopra."/>
                <para/>
                <ITEXT CH="4.4 La soglia"/>
                <para PARENT="section_subtitle"/>
                <ITEXT CH="L'esperienza comincia con un gesto deliberato, inquadrare un codice QR con il proprio telefono. Nella vita di tutti i giorni è un gesto piccolo, quasi banale, ma qui ha un peso diverso."/>
                <para/>
                <ITEXT CH="Inquadrare il codice significa scegliere di partecipare. Si decide di entrare nel sistema, e questo è diverso dalla curiosità di chi passa davanti a una vetrina e si ferma a guardare. È una scelta attiva, e porta con sé una responsabilità leggera ma reale, perché da quel momento il proprio gesto ha conseguenze visibili, il proprio colore è sullo schermo, si fa parte dello sciame."/>
                <para/>
                <ITEXT CPARENT="Bold" CH="[IMG]"/>
                <ITEXT CH=" Fotografia di qualcuno che scansiona il codice QR con il telefono, con sullo sfondo la proiezione del sistema in movimento."/>
                <para/>
                <ITEXT CH="La soglia è volutamente bassa, senza registrazione, senza dati personali, senza un percorso imposto. Resta però una soglia, un momento in cui si passa da un lato all'altro. Prima del QR si è nella stanza, dopo si è nel sistema."/>
                <para/>
                <ITEXT CH="Questo passaggio è parte dell'opera quanto il sistema di particelle, forse di più, perché è il momento in cui si decide di essere presenti davvero. Tutti i gesti che vengono dopo, il joystick, il colore, il voto, hanno la qualità che hanno proprio perché sono stati preceduti da questa scelta. Si è scelto di entrare."/>
                <para/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="161.228976377953" YPOS="15306.6078740157" OwnPage="47" ItemID="762858061" PTYPE="4" WIDTH="318.299212598425" HEIGHT="515.275590551155" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="28.3464566929134" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L318.299 0 L318.299 515.276 L0 515.276 L0 0 Z" copath="M0 0 L318.299 0 L318.299 515.276 L0 515.276 L0 0 Z" gXpos="756.503376377953" gYpos="10015.2769637796" gWidth="0" gHeight="0" PSTYLE="Default Paragraph Style" LAYER="0" NEXTITEM="794136829" BACKITEM="-1">
            <StoryText>
                <DefaultStyle PARENT="Default Paragraph Style" LINESPMode="1" CPARENT="Default Character Style"/>
                <ITEXT CH="5. Il sistema"/>
                <para PARENT="section_subtitle"/>
                <ITEXT CH="Un sistema è fatto di scelte. Dietro ogni decisione tecnica c'è una ragione concettuale, e ogni ragione concettuale ha conseguenze sull'esperienza. Quello che segue descrive quelle scelte, e le parti tecniche compaiono solo dove servono a capirle."/>
                <para/>
                <ITEXT CH="5.1 Le particelle"/>
                <para PARENT="section_subtitle"/>
                <ITEXT CH="Le particelle sono l'unità fondamentale del sistema. Ogni particella è un agente autonomo, con una posizione, una velocità, una direzione e un colore, e segue regole che ne determinano il movimento in base ai campi di forza presenti nella scena e agli input che arrivano dai partecipanti. Le particelle non si percepiscono direttamente l'una con l'altra, ma muovendosi tutte dentro lo stesso campo finiscono per comporre una forma d'insieme."/>
                <para/>
                <ITEXT CH="Presa da sola una particella è quasi invisibile, un punto luminoso contro il nero, ma il sistema ne gestisce fino a diversi milioni in parallelo sulla scheda grafica, dove ogni unità di calcolo segue migliaia di agenti nello stesso istante. Quando tutti questi punti si muovono insieme, ogni frazione di secondo, il risultato è qualcosa che non è stato disegnato a mano, forme che si contraggono e si espandono, correnti che attraversano lo spazio, addensamenti che nascono e si dissolvono."/>
                <para/>
                <ITEXT CPARENT="Bold" CH="[IMG]"/>
                <ITEXT CH=" Primo piano di un cluster di particelle ad alta densità: luce che si accumula e produce un bagliore, singoli punti distinguibili ai margini dove la densità decresce."/>
                <para/>
                <ITEXT CH="Il fatto che ogni particella abbia un colore legato a un partecipante crea una struttura nascosta dentro il sistema, perché in ogni momento lo sciame è la sovrapposizione di tanti sotto-sciami individuali, ognuno con la sua tinta. È il modo in cui l'identità del singolo sopravvive dentro il corpo collettivo. Se ci si concentra su un colore e lo si segue per qualche secondo non sparisce, ma si attenua, si sposta e si confonde con gli altri, restando comunque localizzato in una porzione di sciame riconoscibile. La presenza è sempre lì, anche quando in superficie non si distingue più."/>
                <para/>
                <ITEXT CH="5.2 Il dispositivo remoto"/>
                <para PARENT="section_subtitle"/>
                <ITEXT CH="Quando una persona inquadra il codice QR, il suo telefono diventa parte del sistema. La connessione è in tempo reale, perché ogni movimento del joystick virtuale trascina una piccola frazione delle sue particelle nella direzione indicata e l'effetto sulla proiezione è immediato. Non c'è una latenza percepibile, e per chi partecipa il gesto e il risultato sono simultanei."/>
                <para/>
                <ITEXT CH="Il controller è volutamente minimale, un joystick, lo spazio per scegliere il colore, poco altro, senza spiegazioni e senza tutorial. La prima cosa che quasi tutti fanno è muovere il joystick per vedere cosa succede, e scoprono in tempo reale che le particelle rispondono, che il loro colore è visibile nello sciame, che c'è una corrispondenza diretta tra il gesto e ciò che accade sullo schermo."/>
                <para/>
                <ITEXT CPARENT="Bold" CH="[IMG]"/>
                <ITEXT CH=" Schermata del controller su smartphone: joystick virtuale al centro, selettore colore, interfaccia minimalista su sfondo scuro."/>
                <para/>
                <ITEXT CH="Quando una persona lascia il sistema, chiude il browser o si allontana, le sue particelle non spariscono di colpo. Si riorientano lentamente, si mescolano alle altre e perdono a poco a poco la direzione che aveva impresso il partecipante. Questa dissoluzione lenta è una scelta, perché rende l'arrivo e la partenza delle persone un evento fluido invece di un cambiamento brusco, e dà la sensazione che il sistema abbia una propria inerzia, una memoria del movimento passato."/>
                <para/>
                <ITEXT CH="5.3 Il suono"/>
                <para PARENT="section_subtitle"/>
                <ITEXT CH="Il microfono del dispositivo che gestisce la simulazione ascolta la stanza di continuo. Misura il volume ambientale, il livello sonoro complessivo, senza registrare nulla e senza analizzare cosa viene detto. Questo valore, elaborato in tempo reale, cambia la luminosità delle particelle, e più la stanza è rumorosa più le particelle si fanno brillanti."/>
                <para/>
                <ITEXT CH="C'è qualcosa di John Cage in questa scelta. Nel 1952, con "/>
                <ITEXT CPARENT="Italic" CH="4'33&quot;"/>
                <ITEXT CH=", Cage chiese al pubblico di ascoltare quello che era già nella sala, i fruscii, i colpi di tosse, il rumore del condizionatore, perché il silenzio assoluto non esiste e resta sempre il suono dell'ambiente. Qui il sistema fa una cosa simile in modo strumentale, perché prende quel suono e lo trasforma in luce."/>
                <para/>
                <ITEXT CPARENT="Bold" CH="[IMG]"/>
                <ITEXT CH=" Due stati della simulazione a confronto: ambiente silenzioso (particelle dim, luce contenuta) e ambiente rumoroso (particelle brillanti, bagliore più intenso e diffuso)."/>
                <para/>
                <ITEXT CH="Questa scelta aggiunge al sistema una dimensione che di solito non si associa alla grafica computazionale, l'ascolto. Il sistema non aspetta di essere toccato, sente, e risponde a quello che succede nella stanza anche quando nessuno sta interagendo con lui in modo diretto. Il rumore di una conversazione, una risata collettiva, un silenzio improvviso cambiano la luminosità dello sciame. È una forma di consapevolezza ambientale molto primitiva, ma dà la sensazione che il sistema sia attento a ciò che accade nella stanza, ben oltre l'input esplicito dei partecipanti."/>
                <para/>
                <ITEXT CH="I componenti che ho descritto, dalle particelle al microfono, agiscono insieme e di continuo. Quello che diventa visibile sullo schermo dipende da come si combinano momento per momento, e da cosa il sistema sceglie di proporre al pubblico quando lo invita a partecipare in modo esplicito. È il tema del prossimo capitolo."/>
                <para/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="161.228976377953" YPOS="17847.7089763779" OwnPage="55" ItemID="767030861" PTYPE="4" WIDTH="318.299625974026" HEIGHT="515.276015748002" FRTYPE="0" CLIPEDIT="1" PWIDTH="1" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="28.3464566929134" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L318.3 0 L318.3 515.276 L0 515.276 L0 0 Z" copath="M0 0 L318.3 0 L318.3 515.276 L0 515.276 L0 0 Z" gXpos="161.228976377953" gYpos="17847.7089763779" gWidth="318.299625974026" gHeight="347.402" PSTYLE="Default Paragraph Style" LAYER="0" NEXTITEM="794155757" BACKITEM="-1">
            <StoryText>
                <DefaultStyle PARENT="Default Paragraph Style" LINESPMode="1" CPARENT="Default Character Style"/>
                <ITEXT CH="6. L'esperienza"/>
                <para PARENT="section_subtitle"/>
                <ITEXT CH="Lo sciame si muove in due modi, in ascolto e per conto proprio, e quasi sempre li tiene insieme. Quando ascolta reagisce a ciò che lo tocca, dagli input di chi è connesso ai suoni della stanza, e si lascia spostare di conseguenza. Quando va per conto suo segue correnti che nessuno gli ha imposto e insiste su una direzione finché qualcosa non la interrompe. Anche allora resta influenzato da chi lo abita, perché la presenza del gruppo è sempre nel campo, e una particella che agisce di propria iniziativa lo fa comunque in un ambiente già pieno di altre intenzioni."/>
                <para/>
                <ITEXT CH="Anche i colori sono reattivi. Il colore scelto da chi si connette resta legato alla sua presenza, ma cambia luminosità a seconda di quello che gli accade attorno. Il suono della stanza lo attenua o lo intensifica, e le tracce che le particelle stanno seguendo possono trascinarlo verso aree dense, dove la luce di colori diversi si mescola e produce nuove tinte temporanee."/>
                <para/>
                <ITEXT CH="Quello che lo sciame fa in ogni momento è un comportamento continuo, fatto di molte forze che si sommano e si annullano fra loro. Non ci sono confini netti tra una fase e la successiva, perché alcune di queste forze vengono dal sistema, altre da chi lo abita, altre ancora da quello che sta accadendo nella stanza in quel secondo. Quello che si vede sullo schermo è ogni volta una miscela diversa, che non si ripete mai uguale a se stessa."/>
                <para/>
                <ITEXT CH="Dentro questa continuità ci sono però alcuni momenti in cui il sistema apre al pubblico una partecipazione esplicita. Sono occasioni che propone da solo, scegliendo quando farlo. La natura del comportamento dello sciame resta la stessa, ma cambia il modo in cui il pubblico è invitato a entrare in relazione con lui."/>
                <para/>
                <ITEXT CH="6.1 Una domanda al pubblico"/>
                <para PARENT="section_subtitle"/>
                <ITEXT CH="Ogni tanto il sistema pone una domanda al pubblico. Due opzioni, nessuna risposta giusta, e ogni partecipante può votare dal proprio telefono. Il risultato aggregato orienta una variazione dentro una struttura narrativa che procede comunque, e cambia la tessitura del percorso, il dettaglio che fa sentire la storia come la storia di quel pubblico, in quella sera."/>
                <para/>
                <ITEXT CH="Il voto introduce una dimensione esplicita di decisione collettiva, perché il sistema chiede al gruppo di orientarsi. Il fatto che nessuna opzione sia corretta è parte della scelta, perché l'obiettivo è coinvolgere il pubblico in una decisione reale, le cui conseguenze si vedono subito sullo schermo, senza nessuna pretesa di metterlo alla prova."/>
                <para/>
                <ITEXT CH="C'è un precedente per questo gesto. Nel 1970, al MoMA di New York, Hans Haacke installò "/>
                <ITEXT CPARENT="Italic" CH="MoMA Poll"/>
                <ITEXT CH=", due urne trasparenti e una domanda esplicitamente politica sul governatore Nelson Rockefeller, allora storico trustee e tra i principali donatori del museo. I visitatori mettevano una scheda nell'urna corrispondente alla loro risposta, e il risultato si accumulava in trasparenza per tutta la durata della mostra. Il pubblico smetteva di essere il destinatario dell'opera e ne diventava una variabile. L'idea che una decisione collettiva possa essere essa stessa la forma estetica viene da lì, e lo sciame la riprende a distanza di mezzo secolo, con strumenti diversi."/>
                <para/>
                <ITEXT CPARENT="Bold" CH="[IMG]"/>
                <ITEXT CH=" Schermata del voto sul telefono: due opzioni, timer visibile, interfaccia minimale. Sullo schermo grande in background, il sistema in attesa del risultato."/>
                <para/>
                <ITEXT CH="Quello che rende il voto interessante è il momento che lo precede, la consapevolezza che quello che si fa conta, che la propria scelta si somma a quella degli altri, che il gruppo deciderà qualcosa insieme anche se ognuno lo fa nel silenzio della propria mano. È un piccolo atto politico, compiuto da ciascuno per conto proprio."/>
                <para/>
                <ITEXT CH="Il voto porta dentro l'esperienza anche il tempo. C'è un conto alla rovescia e un risultato che arriva, e questo ritmo scandisce l'esperienza e crea un senso di evento condiviso, qualcosa che accade insieme e ha una durata precisa."/>
                <para/>
                <ITEXT CH="6.2 Un gesto che diventa territorio"/>
                <para PARENT="section_subtitle"/>
                <ITEXT CH="Quando un partecipante traccia un gesto sullo schermo, il sistema lo accoglie come territorio, una forma visibile sullo sfondo verso cui le particelle vengono attratte. Le particelle abitano il disegno e lo riempiono di luce, e il gesto individuale resta visibile come la struttura attorno a cui il collettivo si organizza."/>
                <para/>
                <ITEXT CPARENT="Bold" CH="[IMG]"/>
                <ITEXT CH=" Screenshot di un gesto trasformato in territorio: una forma visibile sullo schermo, le particelle che si addensano lungo il perimetro e all'interno, come se la forma avesse gravità."/>
                <para/>
                <ITEXT CH="C'è qualcosa di particolare in questo meccanismo. Il gesto funziona come un campo di attrazione, una specie di gravità, ma lascia alle particelle la loro logica di avvicinamento, perché si muovono verso la forma e la riempiono a modo loro, accumulandosi sul perimetro come su un campo magnetico. Il risultato è ogni volta una traduzione collettiva di quell'impulso individuale, e non somiglia mai del tutto al gesto di partenza."/>
                <para/>
                <ITEXT CH="Il gesto è l'unica occasione in cui una singola persona può lasciare un segno duraturo nell'esperienza collettiva. La forma rimane sullo schermo e le particelle di tutti continuano a esserne attratte, anche quelle di chi non ha partecipato a crearla. È una forma di influenza anonima, perché si sa che c'è un disegno ma non chi l'ha fatto."/>
                <para/>
                <ITEXT CH="Quello che rimane dopo che il gesto scompare è una configurazione del sistema che nessuno aveva previsto, prodotta dall'incontro tra un impulso individuale e migliaia di risposte."/>
                <para/>
                <ITEXT CH="6.3 La parola che si fa luce"/>
                <para PARENT="section_subtitle"/>
                <ITEXT CH="La parola compare sullo schermo in due modi diversi, e in entrambi lo sciame la tratta allo stesso modo. A intervalli il sistema propone frammenti suoi, parole o frasi brevi che restano in scena per qualche decina di secondi. Altre volte, in momenti precisi, il telefono apre una casella di scrittura e il partecipante può digitare qualcosa di proprio."/>
                <para/>
                <ITEXT CH="In entrambi i casi il comportamento dello sciame è lo stesso. Il testo si comporta come un campo di forza, le particelle vengono attratte verso la forma delle lettere e ne abitano i contorni riempiendole di luce. La parola diventa leggibile grazie alla densità con cui lo sciame la occupa, e i bordi restano sempre sfilacciati, perché sono fatti di luce che si accumula."/>
                <para/>
                <ITEXT CPARENT="Bold" CH="[IMG]"/>
                <ITEXT CH=" Screenshot di una parola abitata dallo sciame: le particelle che si addensano nella forma delle lettere, leggibili ma con bordi sfumati, riconoscibili per via di densità prima ancora che di contorno."/>
                <para/>
                <ITEXT CH="Il flusso dei frammenti proposti dal sistema è automatizzato, perché un'orchestrazione esterna decide cosa mostrare e quando, secondo un piano preparato in anticipo. Resta possibile, se serve, intervenire durante una sessione per spingere la narrazione verso qualcosa di più aderente al pubblico in sala quella sera. È una scelta che protegge il progetto da uno dei rischi più comuni delle installazioni interattive, dover stare davanti a un computer durante la mostra invece di stare in mezzo alle persone che la vivono."/>
                <para/>
                <ITEXT CH="La parola digitata dal partecipante fa qualcosa di diverso. Per qualche secondo una sola persona scrive dentro il sistema, e quello che scrive si trasforma in territorio per le particelle di tutti. Una parola privata diventa visibile a tutti, e l'anonimato del partecipante, per il tempo in cui la parola resta sullo schermo, ha una crepa."/>
                <para/>
                <ITEXT CH="Jenny Holzer fa qualcosa di simile da decenni con le sue "/>
                <ITEXT CPARENT="Italic" CH="Truisms"/>
                <ITEXT CH=", frasi brevi esposte in spazi pubblici e, dal 1982, anche sulle insegne luminose di Times Square, lette da chiunque passi senza che nessuno le abbia annunciate. Holzer aveva capito che una parola, esposta così, smette di essere un messaggio e diventa una presenza, qualcosa che la città guarda mentre la attraversa. Lo sciame riprende quell'intuizione e la sposta, perché anche qui la parola è una presenza condivisa. Quello che cambia è la fisica, perché la luce viene da dentro la forma della lettera, e migliaia di particelle entrano nello spazio della parola e lo occupano accumulando densità, finché quello che si legge sullo schermo è la traccia di un riempimento collettivo."/>
                <para/>
                <ITEXT CH="Cosa significhi, per uno sciame, scrivere una parola digitata da qualcuno è una domanda che il progetto lascia aperta. Forse è il momento in cui la distanza tra l'individuo che digita e il collettivo che lo riceve si riduce al minimo. Quello che rimane, dopo che la parola si dissolve, è una configurazione del flusso che nessuno aveva pianificato, la traccia di una parola che è passata."/>
                <para/>
                <ITEXT CH="Niente di quello che ho descritto in questo capitolo viene annunciato. Non c'è un'etichetta sullo schermo e non c'è una voce che dichiari cosa sta accadendo, il pubblico se ne accorge da quello che cambia sotto i suoi occhi. È una scelta di art direction, e ha conseguenze sull'estetica complessiva dell'opera. È il tema del prossimo capitolo."/>
                <para/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="161.228976377953" YPOS="21024.0853543307" OwnPage="65" ItemID="771815469" PTYPE="4" WIDTH="318.299212598425" HEIGHT="515.275590551153" FRTYPE="0" CLIPEDIT="1" PWIDTH="1" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="28.3464566929134" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L318.299 0 L318.299 515.276 L0 515.276 L0 0 Z" copath="M0 0 L318.299 0 L318.299 515.276 L0 515.276 L0 0 Z" gXpos="161.228976377953" gYpos="21024.0853543307" gWidth="318.299212598425" gHeight="515.275590551153" PSTYLE="Default Paragraph Style" LAYER="0" NEXTITEM="794174493" BACKITEM="-1">
            <StoryText>
                <DefaultStyle PARENT="Default Paragraph Style" LINESPMode="1" CPARENT="Default Character Style"/>
                <ITEXT CH="7. L'invisibilità"/>
                <para PARENT="section_subtitle"/>
                <ITEXT CH="Ogni scelta visiva di questo progetto è una decisione concettuale, perché non esiste un elemento estetico neutro. Il colore dello sfondo, la dimensione delle particelle, la quantità di testo sull'interfaccia del telefono, tutto dice qualcosa su come si vuole che l'esperienza venga vissuta."/>
                <para/>
                <ITEXT CH="Il principio che guida queste scelte ha un nome quasi paradossale, il design dell'invisibilità. L'obiettivo è che l'interfaccia sparisca e che resti solo l'esperienza."/>
                <para/>
                <ITEXT CH="7.1 Il nero come spazio"/>
                <para PARENT="section_subtitle"/>
                <ITEXT CH="La prima scelta è stata il nero, inteso come ambiente e non come sfondo. Uno sfondo è passivo, è ciò che resta quando non c'è nient'altro, mentre un ambiente è attivo, è la condizione che rende possibile quello che contiene."/>
                <para/>
                <ITEXT CH="Il nero assoluto del display lascia che le particelle esistano come luce pura, perché ogni punto luminoso emerge dal buio senza competere con altri elementi visivi. Quando le particelle si addensano la luce si accumula, si sovrappone e produce bagliori che su uno sfondo chiaro non sarebbero possibili. Il contrasto è la condizione stessa della visibilità, perché senza il buio attorno le particelle perderebbero il margine vibrante che fa sembrare dieci punti come cento, e cento punti come una piccola nebulosa."/>
                <para/>
                <ITEXT CPARENT="Bold" CH="[IMG]"/>
                <ITEXT CH=" Screenshot del sistema su sfondo nero totale: le particelle come punti di luce in uno spazio senza riferimenti, il nero come spazio fisico e non come assenza di colore."/>
                <para/>
                <ITEXT CH="Il buio della sala prolunga questo principio nello spazio fisico. Non c'è una separazione netta tra il nero dello schermo e il nero della stanza, e la proiezione sembra emergere dall'oscurità dell'ambiente invece che da una superficie delimitata. Ne nasce un effetto di profondità e continuità che uno schermo illuminato in una stanza normale non potrebbe avere."/>
                <para/>
                <ITEXT CH="C'è anche una ragione che viene da una lunga tradizione. Gran parte dell'arte che lavora con la luce usa il buio come condizione, perché il buio è una forma di presenza ricettiva e attenta, capace di accogliere quello che lo attraversa. Crea una qualità di percezione diversa da quella della luce ordinaria, perché l'occhio, lasciato senza riferimenti familiari, impara a cercare la luce dove c'è, e una volta che ha cominciato a cercarla la trova anche dove è debole, intermittente, quasi infinitesima. È in quel momento che lo sciame, anche disperso, diventa un evento e non un semplice effetto."/>
                <para/>
                <ITEXT CH="7.2 Le particelle come luce"/>
                <para PARENT="section_subtitle"/>
                <ITEXT CH="Una singola particella, sullo schermo, è quasi niente, un punto bianco di pochi pixel, appena visibile. Ma quando migliaia di particelle si trovano nello stesso punto la loro luce si somma, perché il rendering usa una miscelazione additiva, e invece di coprirsi a vicenda come farebbe la pittura i valori si sommano come fa la luce reale. Due luci sovrapposte danno una luce più intensa, non una mescolanza opaca."/>
                <para/>
                <ITEXT CH="Questo significa che la densità diventa luminosità. Un cluster fitto di particelle produce un bagliore che supera di molto la luminosità di ogni singola particella, e le forme che emergono dallo sciame non sono disegnate, ma sono effetti di luce prodotti dall'accumulo."/>
                <para/>
                <ITEXT CPARENT="Bold" CH="[IMG]"/>
                <ITEXT CH=" Due stati a confronto: sciame disperso (particelle dim, quasi invisibili individualmente) e sciame denso (bagliore intenso, luce accumulata che produce alone luminoso)."/>
                <para/>
                <ITEXT CH="C'è qualcosa di fisicamente accurato in questo comportamento, perché è così che funziona la luce vera. Una stella singola è un punto nel cielo notturno, una galassia è una nube luminosa. La bellezza che nasce dalla densità ha origine nel modo in cui la luce si comporta davvero, non in una scelta puramente estetica, e in questo senso la simulazione assomiglia a una fotografia della realtà fisica, perché le regole che segue sono le stesse che seguono i fotoni."/>
                <para/>
                <ITEXT CH="7.3 Il colore come voce"/>
                <para PARENT="section_subtitle"/>
                <ITEXT CH="Ogni partecipante sceglie un colore, e non c'è altro da scegliere, niente nome, niente avatar, niente numero."/>
                <para/>
                <ITEXT CH="La scelta non è casuale. Il colore è l'unico identificatore che funziona sia su uno schermo personale di pochi centimetri sia su una proiezione grande come una parete, senza bisogno di lettura né di interpretazione. Esiste come pura qualità percettiva, perché chi guarda lo sciame non deve cercare un'etichetta, gli basta seguire una tinta."/>
                <para/>
                <ITEXT CPARENT="Bold" CH="[IMG]"/>
                <ITEXT CH=" Screenshot con più colori distinti visibili nel flusso: tinte individuali riconoscibili all'interno del movimento collettivo, come fili colorati in un tessuto."/>
                <para/>
                <ITEXT CH="Anche i colori, nel sistema, si comportano come la luce e non come la pittura. Dove le particelle di due partecipanti si sovrappongono i loro colori si sommano, e due tinte sovrapposte ne producono una terza, più luminosa, mentre una folla di colori tende verso il bagliore bianco. L'effetto è che nessun colore copre l'altro, perché si mescolano verso qualcosa di comune senza perdere la propria origine."/>
                <para/>
                <ITEXT CH="La scelta del colore è anche il primo gesto che il partecipante compie nel sistema, prima ancora di muovere il joystick. È una scelta puramente estetica, senza conseguenze funzionali, perché il rosso e il blu muovono le particelle esattamente allo stesso modo. Ma il colore resta nello sciame per tutta la durata della connessione, ed è la firma di una presenza riconoscibile anche se senza nome, tanto che una persona arrivata quando l'installazione è già cominciata può individuare con un'occhiata la tinta di chi è entrato per primo e riconoscerla nei minuti successivi, come si riconosce una voce sentita da lontano senza saperne altro."/>
                <para/>
                <ITEXT CH="7.4 L'interfaccia che scompare"/>
                <para PARENT="section_subtitle"/>
                <ITEXT CH="Il telefono mostra tre cose, il joystick, il selettore del colore e un punto di stato nell'angolo. Nient'altro."/>
                <para/>
                <ITEXT CH="Nel corso del progetto questa schermata ha perso pezzi. Un testo introduttivo, rimosso. Le icone di stato, ridotte a un punto. Un bottone di aiuto, eliminato. A ogni passaggio la domanda era sempre la stessa, se quell'elemento servisse all'esperienza o servisse solo a rassicurare chi aveva progettato il sistema che l'utente non si sarebbe perso, e la seconda risposta ha sempre portato a togliere."/>
                <para/>
                <ITEXT CPARENT="Bold" CH="[IMG]"/>
                <ITEXT CH=" Schermata del telefono: interfaccia quasi vuota, sfondo scuro, elementi minimi, il meno possibile tra la persona e l'esperienza."/>
                <para/>
                <ITEXT CH="Il costo è misurabile. In alcune sessioni di test non tutti hanno capito subito dove guardare, e qualcuno ha fissato il telefono invece di alzare gli occhi verso lo schermo grande, cercando sull'oggetto piccolo la risposta che stava accadendo su quello grande. Questa latenza, di qualche secondo e raramente di più, è il prezzo del minimalismo."/>
                <para/>
                <ITEXT CH="Non è un problema che si vuole risolvere. Il momento in cui qualcuno smette di guardare il telefono e alza gli occhi verso la proiezione è esattamente il momento in cui l'interfaccia scompare. Non lo si può accelerare con le istruzioni, bisogna aspettare che accada da solo."/>
                <para/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="161.228976377953" YPOS="23565.1864566929" OwnPage="73" ItemID="776940573" PTYPE="4" WIDTH="318.299625974026" HEIGHT="515.276015748006" FRTYPE="0" CLIPEDIT="1" PWIDTH="1" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="28.3464566929134" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L318.3 0 L318.3 515.276 L0 515.276 L0 0 Z" copath="M0 0 L318.3 0 L318.3 515.276 L0 515.276 L0 0 Z" gXpos="161.228976377953" gYpos="23565.1864566929" gWidth="318.299625974026" gHeight="347.402" PSTYLE="Default Paragraph Style" LAYER="0" NEXTITEM="794288669" BACKITEM="-1">
            <StoryText>
                <DefaultStyle PARENT="Default Paragraph Style" LINESPMode="1" CPARENT="Default Character Style"/>
                <ITEXT CH="8. Il fare"/>
                <para PARENT="section_subtitle"/>
                <ITEXT CH="Costruire questo progetto ha insegnato cose che non avrei potuto imparare in nessun altro modo, cose che vanno oltre la parte tecnica, oltre l'imparare un'API grafica o gestire connessioni in tempo reale. Si tratta di capire come si comporta un sistema complesso da dentro, mentre prende forma."/>
                <para/>
                <ITEXT CH="Esiste una forma di conoscenza che nasce soltanto dal fare. È diversa da quella che nasce dallo studio, più difficile da trasmettere e da documentare, legata all'esperienza diretta di costruire qualcosa che non è mai esistito nella forma in cui lo si immagina. Mi è capitato spesso di avere la sensazione che il lavoro non si producesse tanto quanto si ricevesse, che ci fosse una direzione da ascoltare più che da imporre, e che il progetto spingesse verso qualcosa che non avevo previsto."/>
                <para/>
                <ITEXT CH="8.1 L'errore come informazione"/>
                <para PARENT="section_subtitle"/>
                <ITEXT CH="I sistemi di simulazione basati su agenti sono particolarmente instabili nelle fasi di sviluppo, perché le interazioni tra migliaia di entità producono comportamenti emergenti che non si possono prevedere leggendo il codice. Un errore in una formula di movimento raramente dà un risultato sbagliato in modo ovvio, ma produce un comportamento inaspettato, che a volte è un bug e a volte è qualcosa di interessante."/>
                <para/>
                <ITEXT CH="Più volte, durante lo sviluppo, mi sono trovato davanti a comportamenti che non avevo scritto. Particelle che formavano strutture filiformi invece di cluster tondi, correnti che si organizzavano in pattern ripetuti invece di fluire libere, oscillazioni che sembravano un respiro. In alcuni casi erano errori da correggere, in altri erano proprietà emergenti del sistema che non sapevo di voler costruire, ma che una volta viste sembravano ovvie."/>
                <para/>
                <ITEXT CPARENT="Bold" CH="[IMG]"/>
                <ITEXT CH=" Screenshot di un comportamento emergente inaspettato della simulazione: un pattern o una struttura che non era stata progettata esplicitamente, visivamente interessante proprio per la sua natura non intenzionale."/>
                <para/>
                <ITEXT CH="Questo ha cambiato il modo in cui pensavo alla simulazione. Ha smesso di essere un sistema che controllavo ed è diventato un sistema con cui negoziavo. Le mie decisioni tecniche producevano effetti che poi osservavo e valutavo, e che usavo per prendere la decisione successiva. Lo stesso processo di sviluppo era un'esperienza di sciame, con me come agente, il sistema come ambiente e la simulazione come risultato emergente di quella relazione."/>
                <para/>
                <ITEXT CH="Da qui è emersa una distinzione che conta, quella tra simulare un sistema e capire come si comporta. Si può scrivere la formula giusta senza sapere cosa produrrà nel groviglio di migliaia di interazioni a ogni frame, perché la comprensione vera arriva solo dall'osservazione in esecuzione, da quello che succede quando il sistema gira davvero."/>
                <para/>
                <ITEXT CH="8.2 Quando qualcosa ha funzionato"/>
                <para PARENT="section_subtitle"/>
                <ITEXT CH="C'è un momento difficile da descrivere ma facile da riconoscere, quello in cui un sistema smette di sembrare un esperimento e comincia a sembrare un'esperienza."/>
                <para/>
                <ITEXT CPARENT="Bold" CH="[IMG]"/>
                <ITEXT CH=" Screenshot di un momento particolarmente significativo della simulazione: composizione visiva intensa, luce e movimento in equilibrio, il sistema che sembra avere una propria presenza."/>
                <para/>
                <ITEXT CH="Per questo progetto è arrivato la prima volta che ho visto le particelle rispondere al suono della stanza. Il sistema già funzionava, le particelle si muovevano, i colori dei partecipanti erano visibili, il joystick rispondeva. Ma quando ho capito che la luminosità dello sciame cambiava ogni volta che alzavo la voce, qualcosa è cambiato di qualità. Non stavo più guardando un programma che funzionava, stavo guardando qualcosa che ascoltava."/>
                <para/>
                <ITEXT CH="Questa differenza è difficile da ridurre a criteri oggettivi. Non si misura in frame rate o in numero di particelle, si percepisce, perché c'è un momento in cui il sistema comincia ad avere una presenza, un carattere, qualcosa che lo rende riconoscibile come sé stesso invece che come la variante di qualcosa che esiste già. Riconoscere quel momento, e poi lavorare per conservarlo nelle iterazioni successive, è uno degli obiettivi impliciti di qualsiasi processo creativo."/>
                <para/>
                <ITEXT CH="8.3 La distanza tra l'intenzione e il risultato"/>
                <para PARENT="section_subtitle"/>
                <ITEXT CH="Il progetto che avevo in mente all'inizio era diverso da quello che esiste adesso. Le grandi linee tengono, ma sono i dettagli a essersi spostati, e in alcuni casi si sono spostati abbastanza da cambiare il senso complessivo dell'esperienza."/>
                <para/>
                <ITEXT CH="Alcune cose sono state semplificate, perché aspetti che all'inizio sembravano fondamentali si sono rivelati inutili una volta provati, o impossibili da fare nei tempi disponibili, o semplicemente meno interessanti di quanto pensassi. La narrazione, che avrebbe dovuto essere più strutturata e lineare, con un arco preciso, lungo il percorso si è frammentata, e quella frammentazione si è rivelata più adatta all'esperienza."/>
                <para/>
                <ITEXT CH="Altre cose sono emerse durante il lavoro e si sono rivelate centrali. La reattività al suono, per esempio, non era nel piano iniziale, ed è nata da una domanda semplice, cosa succederebbe se il sistema sentisse la stanza, cambiando in modo profondo la qualità dell'esperienza."/>
                <para/>
                <ITEXT CPARENT="Bold" CH="[IMG]"/>
                <ITEXT CH=" Documentazione di una fase intermedia dello sviluppo: screenshot più grezzo o interfaccia meno rifinita, a confronto implicito con lo stato attuale."/>
                <para/>
                <ITEXT CH="Questa distanza tra intenzione e risultato è una parte normale di ogni processo creativo serio. È il segno che il lavoro ha avuto una vita propria e ha cambiato forma mentre veniva costruito. Chi costruisce qualcosa di non banale lo sa, perché l'oggetto finito raramente coincide con quello immaginato all'inizio, e quando coincide spesso è perché si è progettato in difetto, evitando le occasioni che il processo apriva strada facendo. Rick Rubin, in "/>
                <ITEXT CPARENT="Italic" CH="The Creative Act"/>
                <ITEXT CH=" (2023), descrive l'artista come il custode di un progetto più che come il suo proprietario, qualcosa che ha una direzione propria che si rivela solo attraverso il fare. In anticipo non si può sapere dove porta, si può solo stare attenti a riconoscerlo quando ci si arriva."/>
                <para/>
                <ITEXT CH="Alla fine quello che rimane è quello che si è riusciti a fare, con i vincoli del tempo, delle competenze disponibili e di quello che il sistema stesso suggeriva di diventare. Non è esattamente quello che volevo fare. In molti casi, è meglio."/>
                <para/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="161.228976377953" YPOS="26106.2875590551" OwnPage="81" ItemID="780194957" PTYPE="4" WIDTH="318.299212598425" HEIGHT="515.275590551155" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="28.3464566929134" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L318.299 0 L318.299 515.276 L0 515.276 L0 0 Z" copath="M0 0 L318.299 0 L318.299 515.276 L0 515.276 L0 0 Z" gXpos="756.503376377953" gYpos="17287.4027086614" gWidth="0" gHeight="0" PSTYLE="Default Paragraph Style" LAYER="0" NEXTITEM="794353853" BACKITEM="-1">
            <StoryText>
                <DefaultStyle PARENT="Default Paragraph Style" LINESPMode="1" CPARENT="Default Character Style"/>
                <ITEXT CH="9. Il dialogo"/>
                <para PARENT="section_subtitle"/>
                <ITEXT CH="Il rapporto tra una persona e un sistema interattivo non è mai semplice come sembra. Si entra in uno spazio con l'idea di controllare qualcosa e si scopre che qualcosa, intanto, sta controllando noi. Il ruolo di soggetto che ci si era assunti entrando si rivela parziale, perché di fronte a un sistema che risponde si è anche oggetto."/>
                <para/>
                <ITEXT CH="Questa circolarità è al centro di molte delle domande più interessanti aperte dalla tecnologia computazionale negli ultimi decenni. Non interessa qui chi sia più intelligente, l'umano o la macchina, ma come si trasforma la relazione tra i due quando il sistema è abbastanza complesso da rispondere in modi non del tutto prevedibili."/>
                <para/>
                <ITEXT CH="9.1 Chi guida chi"/>
                <para PARENT="section_subtitle"/>
                <ITEXT CH="In un sistema di particelle orientate dai partecipanti, la risposta alla domanda «chi guida?» è sempre provvisoria. I partecipanti guidano le proprie particelle, e questo è ovvio, ma il comportamento delle particelle altrui influenza quello che si vede, e quello che si vede influenza i gesti successivi. Il sistema ha una logica propria che resiste alle direzioni individuali, e la narrazione che arriva dall'esterno orienta l'attenzione."/>
                <para/>
                <ITEXT CH="Alla fine non è chiaro chi stia guidando, o meglio, guidano tutti e nessuno guida del tutto. Il controllo è distribuito come nello sciame, perché nessuno vede l'intero, ognuno influenza una porzione, e il risultato finale appartiene a tutti i partecipanti insieme senza appartenere a nessuno in particolare."/>
                <para/>
                <ITEXT CPARENT="Bold" CH="[IMG]"/>
                <ITEXT CH=" Diagramma della circolarità dell'influenza: partecipanti che influenzano il sistema, il sistema che modifica il comportamento dei partecipanti, la narrativa esterna come terzo elemento."/>
                <para/>
                <ITEXT CH="Alan Turing, nel saggio del 1950 "/>
                <ITEXT CPARENT="Italic" CH="Computing Machinery and Intelligence"/>
                <ITEXT CH=", si chiedeva se si potesse mai distinguere, in una conversazione, una risposta umana da una risposta di macchina. La sua domanda riguardava la simulazione del linguaggio, ma la struttura del problema vale anche qui, perché quando non si riesce più a distinguere quali parti del comportamento del sistema vengono dai partecipanti e quali dalla sua logica interna, diventa difficile dire chi stia guidando."/>
                <para/>
                <ITEXT CH="In questo progetto l'ambiguità è voluta. Il sistema non vuole essere trasparente, vuole essere percepito come qualcosa con cui si è in relazione e non come uno strumento che si usa, e la circolarità dell'influenza, il fatto che nessuno abbia il controllo completo, fa parte di questa intenzione."/>
                <para/>
                <ITEXT CH="9.2 Il sistema come specchio"/>
                <para PARENT="section_subtitle"/>
                <ITEXT CH="Uno degli effetti più interessanti di un sistema collettivo è che rivela strutture che guardando i singoli non si vedevano. Le persone in una stanza si organizzano in modi che nessuna di loro ha pianificato, formano gruppi, seguono leader informali, producono ritmi condivisi di attenzione. Sono strutture reali, ma di solito invisibili."/>
                <para/>
                <ITEXT CH="Quando il comportamento collettivo di un gruppo viene visualizzato in tempo reale su uno schermo grande, quelle strutture diventano osservabili. Si vede dove si concentra l'attenzione del gruppo, si vede se qualcuno sta guidando il movimento degli altri anche senza volerlo, si vede il ritmo collettivo nella forma del flusso."/>
                <para/>
                <ITEXT CPARENT="Bold" CH="[IMG]"/>
                <ITEXT CH=" Screenshot che mostra un pattern visivo chiaro emergente dal comportamento collettivo: una struttura nel flusso che rivela l'organizzazione implicita del gruppo in quel momento."/>
                <para/>
                <ITEXT CH="Vale qui la stessa logica dello specchio che trasforma di cui ho parlato nel primo capitolo. Il sistema non restituisce una copia fedele di ciò che riceve, lo traduce, e la traduzione introduce una distanza interpretativa che rende osservabile quello che altrimenti resterebbe invisibile. Su scala collettiva questa traduzione lavora su un materiale più complesso del movimento di un singolo corpo, perché lavora sul comportamento aggregato di un gruppo. Quello che si vede sullo schermo è il gruppo, ma trasformato in qualcosa che il gruppo non avrebbe potuto vedere di sé in nessun altro modo."/>
                <para/>
                <ITEXT CH="Questa trasformazione ha un effetto preciso, perché rende osservabile quello che di solito si sente soltanto. Si può avere la sensazione di far parte di un gruppo coeso o di un gruppo disperso, e con questo sistema quella sensazione prende una forma visiva. La si può vedere."/>
                <para/>
                <ITEXT CH="9.3 La macchina che propone"/>
                <para PARENT="section_subtitle"/>
                <ITEXT CH="Tutti gli aspetti descritti fin qui, le particelle, i momenti di partecipazione, la narrazione, condividono una caratteristica che non ho ancora nominato apertamente, il sistema non aspetta."/>
                <para/>
                <ITEXT CPARENT="Bold" CH="[IMG]"/>
                <ITEXT CH=" Lo sciame in uno stato attivo senza input esterno: le particelle si muovono secondo una propria logica visibile, mentre la stanza è ancora vuota."/>
                <para/>
                <ITEXT CH="Quando le persone entrano nella stanza, il sistema ha già qualcosa in corso. Esiste prima che qualcuno arrivi e continuerà a esistere dopo che se ne sarà andato."/>
                <para/>
                <ITEXT CH="Questo cambia tutto nel tipo di relazione che si stabilisce. Davanti a un ambiente già in movimento la prima domanda non è «come lo uso?», è «cosa sta facendo?». Si osserva prima di agire, si cerca di capire la logica prima di intervenire. È una postura molto diversa da quella di chi usa uno strumento, perché chi usa uno strumento si avvicina con uno scopo già pronto e cerca i tasti che servono a raggiungerlo, mentre chi entra in questo progetto, le prime volte, si trova senza scopo. E quel vuoto, lontano dall'essere un difetto dell'interfaccia, è esattamente ciò che il sistema cerca di produrre."/>
                <para/>
                <ITEXT CH="Il sistema propone. Propone un comportamento, un ritmo, una qualità dell'esperienza, e i partecipanti rispondono a quella proposta con la propria. Il dialogo è già iniziato quando si collega il telefono, perché si entra in una conversazione in corso, non se ne apre una nuova."/>
                <para/>
                <ITEXT CH="È un modello molto diverso da quello dell'assistente conversazionale, che aspetta la domanda e risponde. È più vicino a un musicista che sta già suonando quando gli altri entrano nella stanza, dove l'interazione comincia dall'ascolto e non dall'interrogazione."/>
                <para/>
                <ITEXT CH="9.4 Un'estetica della relazione"/>
                <para PARENT="section_subtitle"/>
                <ITEXT CH="Nicolas Bourriaud, nel libro "/>
                <ITEXT CPARENT="Italic" CH="Estetica relazionale"/>
                <ITEXT CH=" (1998), descrive una tendenza dell'arte degli anni Novanta verso opere che producono modi di stare insieme, forme di relazione, più che oggetti da contemplare. L'opera diventa un contesto, lo spazio in cui nascono incontri tra persone, tra persone e sistemi, tra idee e corpi, e smette di essere un messaggio trasmesso da un autore a un pubblico."/>
                <para/>
                <ITEXT CH="Questo progetto appartiene a quella tradizione, ma la prolunga in una direzione che Bourriaud non poteva prevedere, perché il sistema stesso diventa un interlocutore attivo, una presenza che partecipa alla relazione invece di limitarsi a ospitarla."/>
                <para/>
                <ITEXT CPARENT="Bold" CH="[IMG]"/>
                <ITEXT CH=" Fotografia o screenshot che cattura l'esperienza complessiva dell'installazione: persone nella sala, proiezione grande sullo sfondo, telefoni in mano, la dimensione collettiva dell'evento."/>
                <para/>
                <ITEXT CH="Quello che il progetto propone, implicitamente, è un modo diverso di pensare il rapporto tra umani e sistemi intelligenti. Un modo lontano sia dallo strumento che si usa quando serve sia dall'oracolo che risponde alle domande, più vicino a una presenza, un sistema che ha una vita propria, che si modifica in risposta al contesto, che offre qualcosa e in cambio chiede qualcosa. Una funzione che diventa relazione."/>
                <para/>
                <ITEXT CH="Questa proposta non ha ambizioni di universalità. È un esperimento, un prototipo, una domanda posta attraverso la forma invece che attraverso il testo, e come ogni domanda posta bene non esaurisce il problema che apre, lo rende più preciso, più maneggiabile, più difficile da ignorare."/>
                <para/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="161.228976377953" YPOS="29282.6639370078" OwnPage="91" ItemID="783457981" PTYPE="4" WIDTH="318.299212598425" HEIGHT="515.275590551159" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="28.3464566929134" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L318.299 0 L318.299 515.276 L0 515.276 L0 0 Z" copath="M0 0 L318.299 0 L318.299 515.276 L0 515.276 L0 0 Z" gXpos="756.503376377953" gYpos="19581.8906015747" gWidth="0" gHeight="0" PSTYLE="Default Paragraph Style" LAYER="0" NEXTITEM="794425565" BACKITEM="-1">
            <StoryText>
                <DefaultStyle PARENT="Default Paragraph Style" LINESPMode="1" CPARENT="Default Character Style"/>
                <ITEXT CH="10. Il futuro"/>
                <para PARENT="section_subtitle"/>
                <ITEXT CH="Costruire qualcosa insegna anche cosa non si riesce a fare, e non è un dato neutro, perché i limiti di un sistema ne rivelano la natura con la stessa precisione delle sue possibilità. Quello che un sistema non sa fare dice dove finisce la sua intelligenza e dove comincia la necessità di qualcosa di diverso."/>
                <para/>
                <ITEXT CH="10.1 Cosa il sistema non riesce ancora a fare"/>
                <para PARENT="section_subtitle"/>
                <ITEXT CH="Il limite più evidente è nella qualità dell'ascolto. Il sistema percepisce il volume della stanza, ma non distingue i suoni, e non sa se quello che sente è musica, conversazione, applauso o silenzio improvviso. Risponde alla quantità di suono, non alla sua qualità, e questo produce effetti interessanti ma restringe la gamma di risposte possibili, perché il sistema non può reagire in modo diverso a una risata collettiva e a un rumore di sottofondo casuale."/>
                <para/>
                <ITEXT CH="Una limitazione simile riguarda la visione. Il sistema non vede la stanza, non sa quante persone ci sono, dove sono, se si muovono o stanno ferme, e l'unico canale di informazione sul comportamento fisico dei partecipanti è il telefono. Resta fuori gran parte di ciò che un corpo fa in uno spazio, la postura, il movimento, la direzione dello sguardo, la distanza dagli altri."/>
                <para/>
                <ITEXT CPARENT="Bold" CH="[IMG]"/>
                <ITEXT CH=" Diagramma schematico di quello che il sistema percepisce (volume audio, input touch) rispetto a quello che non vede (posizione fisica, gesti corporei, espressioni, numero di persone presenti)."/>
                <para/>
                <ITEXT CH="Un'altra limitazione riguarda la memoria. Il sistema non ricorda, perché ogni sessione comincia da zero, le particelle non sanno nulla delle sessioni precedenti e niente di quello che succede in quella corrente diventa permanente. È potente nel brevissimo termine, ma sul tempo lungo è cieco. Non ha storia, perché il pubblico di ieri sera non lascia tracce visibili a quello di stasera, e tutto ricomincia da capo a ogni accensione, come se il sistema fosse stato appena costruito."/>
                <para/>
                <ITEXT CH="Infine c'è un limite che riguarda la scala dell'esperienza. Il progetto è stato concepito e provato in condizioni controllate, e non è ancora stato esposto a un pubblico reale in un contesto espositivo vero. Molte delle assunzioni che lo attraversano, su come reagiscono le persone, su quanto tempo restano connesse, su come si comporta il sistema con dieci o venti partecipanti insieme, restano ipotesi da verificare."/>
                <para/>
                <ITEXT CH="10.2 La questione della scala"/>
                <para PARENT="section_subtitle"/>
                <ITEXT CH="Il progetto è pensato per una sala di dimensioni moderate, con un numero limitato di partecipanti. A questa scala funziona, perché c'è abbastanza partecipazione da produrre dinamiche collettive interessanti e abbastanza controllo da gestire la connessione in tempo reale."/>
                <para/>
                <ITEXT CH="Ma cosa succederebbe con cento persone? Con mille? In uno spazio aperto, in una piazza, in un aeroporto?"/>
                <para/>
                <ITEXT CPARENT="Bold" CH="[IMG]"/>
                <ITEXT CH=" Schizzo o mock-up concettuale del sistema in uno spazio pubblico di grandi dimensioni: visualizzazione ipotetica di un'installazione in un grande auditorium, in una piazza, o in un atrio di stazione."/>
                <para/>
                <ITEXT CH="Le sfide tecniche di questa espansione sono reali ma risolvibili, mentre quelle concettuali sono più interessanti. Con mille partecipanti le dinamiche collettive cambierebbero natura, si formerebbero sottogruppi, emergerebbero strutture di influenza più complesse, e la logica dello sciame diventerebbe ancora più evidente e meno controllabile. Il singolo si sentirebbe ancora meno un agente di controllo e ancora di più parte di qualcosa che lo supera."/>
                <para/>
                <ITEXT CH="Potrebbe essere bellissimo, oppure soverchiante nel senso peggiore, qualcosa che non lascia spazio all'individuo e lo annulla invece di includerlo. La differenza tra i due esiti dipende da scelte di design che a questa scala non sono ancora state fatte. È una domanda aperta."/>
                <para/>
                <ITEXT CH="10.3 Estensioni possibili"/>
                <para PARENT="section_subtitle"/>
                <ITEXT CH="Le direzioni in cui questo progetto potrebbe crescere sono molte, e non tutte tecnologiche."/>
                <para/>
                <ITEXT CH="Sul fronte dei sensi, il suono è già presente come input ma potrebbe diventare anche output, e un sistema che risponde al suono della stanza producendo a sua volta suono, in una retroazione audio-visiva, aprirebbe una dimensione del tutto nuova. Allo stesso modo, sistemi di visione artificiale potrebbero estendere la percezione del sistema dal tocco sullo schermo al corpo intero, alla postura, al movimento, alla direzione dello sguardo."/>
                <para/>
                <ITEXT CH="Sul fronte del tempo, un sistema che ricorda. Che tiene traccia di quello che è successo nelle sessioni passate, che si modifica lentamente nel corso di settimane o mesi di esposizione, che porta con sé la storia del pubblico che l'ha attraversato. Sarebbe una memoria diversa da quella umana, ma del tutto reale, un sistema che cambia perché è stato vissuto."/>
                <para/>
                <ITEXT CPARENT="Bold" CH="[IMG]"/>
                <ITEXT CH=" Tavola concettuale con schizzi di possibili estensioni: nuovi sensi integrati (visione, temperatura), configurazioni spaziali diverse, timeline di evoluzione del sistema nel tempo."/>
                <para/>
                <ITEXT CH="Sul fronte dei luoghi, installazioni distribuite in più spazi insieme, connesse in rete. Sciami che si trovano in città diverse ma si influenzano a vicenda in tempo reale, e la distanza fisica che scompare nella condivisione di uno sciame comune, persone a Milano e persone a Tokyo che muovono lo stesso sistema e vedono sullo schermo il risultato di azioni che nessuno di loro conosce per intero."/>
                <para/>
                <ITEXT CH="Tutte queste direzioni sono possibili. Nessuna è ovvia, e ognuna richiederebbe di affrontare problemi che questo progetto non ha ancora toccato, ma la logica di base è già qui, un organismo distribuito che risponde al contesto e produce qualcosa di significativo quando le persone si avvicinano abbastanza, e abbastanza a lungo."/>
                <para/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="161.228976377953" YPOS="31823.76503937" OwnPage="99" ItemID="788156957" PTYPE="4" WIDTH="318.299212598425" HEIGHT="515.275590551162" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="28.3464566929134" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L318.299 0 L318.299 515.276 L0 515.276 L0 0 Z" copath="M0 0 L318.299 0 L318.299 515.276 L0 515.276 L0 0 Z" gXpos="756.503376377953" gYpos="21241.1032188976" gWidth="0" gHeight="0" PSTYLE="Default Paragraph Style" LAYER="0" NEXTITEM="794484285" BACKITEM="-1">
            <StoryText>
                <DefaultStyle PARENT="Default Paragraph Style" LINESPMode="1" CPARENT="Default Character Style"/>
                <ITEXT CH="Conclusione"/>
                <para PARENT="section_subtitle"/>
                <ITEXT CH="Questo progetto nasce da una domanda sull'interazione. Finisce, almeno in questa forma, con molte domande in più. Non è un fallimento. Le domande che rimangono aperte alla fine di un lavoro serio sono spesso più preziose delle risposte che ha prodotto. Indicano dove c'è ancora qualcosa da capire, dove il pensiero non è ancora arrivato, dove il fare non ha ancora esaurito le sue possibilità. La domanda da cui tutto è partito era semplice: cosa succede quando un sistema intelligente è già presente nella stanza, invece di aspettare di essere interrogato? La risposta che questo progetto propone è parziale, senza alcuna pretesa di essere definitiva, ma è concreta, perché si può costruire qualcosa che abbia una propria vita, un proprio ritmo, una propria logica, e che risponda alla presenza delle persone senza che debbano fare nulla di speciale per farlo funzionare. Basta essere lì."/>
                <para/>
                <ITEXT CPARENT="Bold" CH="[IMG]"/>
                <ITEXT CH=" Screenshot finale del sistema in uno dei suoi momenti più belli: la composizione visiva più significativa dell'intera tesi, scelta con cura per essere l'ultima immagine che il lettore porta con sé. Quello che rimane, dopo l'esperienza, non è il ricordo del sistema. È il ricordo di essere stati parte di qualcosa. Di aver visto il proprio gesto tradursi in luce su uno schermo, di aver riconosciuto il proprio colore nel flusso degli altri, di aver partecipato a una decisione collettiva senza che nessuno lo avesse organizzato davvero. La tecnologia che produce questa esperienza scompare durante l'esperienza stessa. Il telefono in mano si dimentica. Lo schermo smette di essere uno schermo e diventa un fenomeno. Questo sparire è l'obiettivo di ogni design che funziona davvero. Una sparizione che fa spazio a qualcosa di più importante, non una rinuncia pigra."/>
                <para/>
                <ITEXT CH="Anche questo è stato un dialogo"/>
                <para PARENT="section_subtitle"/>
                <ITEXT CH="Ho descritto un dialogo tra le persone e una macchina. Costruire questo progetto è stato a sua volta un dialogo con delle macchine, e questo merita un'ultima riflessione. I modelli di OpenAI generano, lato server e in tempo reale, la storia che attraversa l'installazione, insieme ai testi che compaiono e alle immagini che lo sciame abita. La voce che accompagna il racconto la produce ElevenLabs. Il codice che tiene insieme tutto questo l'ho scritto con Claude, sotto una guida architetturale che non ho mai mollato. Anche queste pagine sono passate da strumenti di intelligenza artificiale, per la revisione del testo e la verifica delle fonti. L'opera e il modo in cui è nata raccontano la stessa cosa, vista da due lati. Lavorare così cambia il mestiere. Non si tratta più di eseguire ogni passaggio con le proprie mani, ma di dirigere qualcosa che produce molto più in fretta di me. È un'art direction estesa a un collaboratore che non si stanca e non discute. C'è però una condizione, e l'ho imparata sbattendoci la testa: si può dirigere solo quello che si capisce. Ogni volta che ho lasciato fare alla macchina senza sapere davvero cosa stesse facendo, il sistema è andato alla deriva. Il codice si sporcava, il flusso si rompeva in punti che non sapevo più ricostruire. Tenere una codebase pulita e un funzionamento solido, mentre uno strumento genera soluzioni a getto continuo, è stata la difficoltà più concreta di tutto il lavoro. La velocità della macchina non serve a niente se chi la guida perde il filo. E qui c'è la cosa che conta di più. Un modello generativo guarda indietro per costruzione: impara da quello che è già stato fatto e restituisce una media di tutto ciò che ha visto. La creatività fa il movimento opposto, guarda avanti, verso qualcosa che ancora non esiste. La macchina non prova desiderio, e non prova fastidio davanti a una soluzione che funziona ma non convince. Se le si lascia decidere tutto, converge sul punto medio, sul già visto, sulla mediocrità. È una cosa di cui ci stiamo accorgendo un po' tutti. Quello che spinge un lavoro in avanti non è la potenza dello strumento, è l'attrito di chi lo usa: il gusto e l'insoddisfazione di chi non si accontenta. Per questo la direzione è rimasta umana dall'inizio alla fine. La macchina ha scritto codice, generato immagini, prestato una voce. Ma la scelta di cosa tenere e cosa buttare, il senso da dare a tutto questo, gli errori e quello che mi hanno insegnato, restano miei. Lo strumento accelera, non risponde. La firma di un lavoro è esattamente la parte che non si delega."/>
                <para/>
                <ITEXT CH="C'è una cosa che vale la pena dire, alla fine, sul perché di questo progetto. L'ho costruito perché volevo vedere cosa sarebbe successo se avessi messo insieme un sistema complesso e delle persone in una stanza buia, senza spiegare nulla. Non per dimostrare l'efficacia di un algoritmo o per esplorare una tecnologia nuova. Quello che è successo, ogni volta che ho provato, è che le persone hanno cominciato a giocare. A esplorare. A collaborare senza che nessuno glielo chiedesse. È una cosa piccola. Ma dice qualcosa su come le persone si comportano quando si sentono libere, quando non c'è una risposta giusta, quando il sistema che le circonda è abbastanza aperto da contenere qualsiasi cosa decidano di fare. Forse è questo che manca, nel rapporto ordinario con i sistemi intelligenti. Non potenza in più, non accuratezza in più. Spazio in più. Spazio per fare cose che nessuno aveva previsto."/>
                <para/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="559.528188976378" YPOS="1330.55181102362" OwnPage="4" ItemID="791285693" PTYPE="4" WIDTH="339.527559055118" HEIGHT="515.275590551181" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L339.528 0 L339.528 515.276 L0 515.276 L0 0 Z" copath="M0 0 L339.528 0 L339.528 515.276 L0 515.276 L0 0 Z" gXpos="559.528188976378" gYpos="1330.55181102362" gWidth="0" gHeight="0" PSTYLE="Default Paragraph Style" LAYER="0" NEXTITEM="-1" BACKITEM="728069805"/>
