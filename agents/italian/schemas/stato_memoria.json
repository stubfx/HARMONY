{
  "name": "stato_memoria",
  "strict": true,
  "schema": {
    "type": "object",
    "properties": {
      "current_step": {
        "type": "integer",
        "description": "Il numero dell'ultimo passo completato"
      },
      "protagonist": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Nome del protagonista"
          },
          "description": {
            "type": "string",
            "description": "Descrizione aggiornata del protagonista"
          },
          "traits": {
            "type": "array",
            "description": "Tratti fisici, psicologici o capacità stabiliti nel corso della storia",
            "items": { "type": "string" }
          }
        },
        "required": ["name", "description", "traits"],
        "additionalProperties": false
      },
      "secondary_characters": {
        "type": "array",
        "description": "Tutti i personaggi secondari incontrati fino a questo passo",
        "items": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "role": {
              "type": "string",
              "description": "Ruolo narrativo (es. 'mentore', 'guardiano della soglia', 'alleato', 'nemico')"
            },
            "description": { "type": "string" }
          },
          "required": ["name", "role", "description"],
          "additionalProperties": false
        }
      },
      "locations": {
        "type": "array",
        "description": "Tutti i luoghi visitati o menzionati, in ordine di apparizione",
        "items": { "type": "string" }
      },
      "significant_objects": {
        "type": "array",
        "description": "Oggetti narrativamente importanti introdotti nel corso della storia",
        "items": { "type": "string" }
      },
      "audience_choices": {
        "type": "array",
        "description": "Registro di tutte le scelte di voto del pubblico",
        "items": {
          "type": "object",
          "properties": {
            "step": {
              "type": "integer",
              "description": "Il passo in cui è avvenuta la scelta"
            },
            "choice": {
              "type": "string",
              "description": "Il testo dell'opzione scelta"
            }
          },
          "required": ["step", "choice"],
          "additionalProperties": false
        }
      },
      "established_facts": {
        "type": "array",
        "description": "Fatti narrativi importanti che devono essere ricordati nei passi futuri",
        "items": { "type": "string" }
      }
    },
    "required": [
      "current_step",
      "protagonist",
      "secondary_characters",
      "locations",
      "significant_objects",
      "audience_choices",
      "established_facts"
    ],
    "additionalProperties": false
  }
}
