{
  "name": "scheletro_storia",
  "strict": true,
  "schema": {
    "type": "object",
    "properties": {
      "story_title": {
        "type": "string",
        "description": "Titolo conciso e suggestivo della storia"
      },
      "story_concept": {
        "type": "string",
        "description": "Il concept narrativo di fondo in una frase (es. 'un architetto che ricostruisce la città che ha distrutto')"
      },
      "protagonist_archetype": {
        "type": "string",
        "description": "L'archetipo narrativo del protagonista (es. 'l'eroe riluttante', 'il paria in cerca di redenzione')"
      },
      "protagonist_description": {
        "type": "string",
        "description": "Descrizione fisica e caratteriale iniziale del protagonista, specifica e concreta"
      },
      "world_setting": {
        "type": "string",
        "description": "Dove e quando si svolge la storia, con atmosfera visiva dominante"
      },
      "central_conflict": {
        "type": "string",
        "description": "La tensione fondamentale non risolta fino all'ultimo passo"
      },
      "steps": {
        "type": "array",
        "description": "Gli stadi del Viaggio dell'Eroe, in ordine",
        "items": {
          "type": "object",
          "properties": {
            "number": {
              "type": "integer",
              "description": "Numero del passo"
            },
            "vogler_stage": {
              "type": "string",
              "description": "Nome ufficiale dello stadio di Vogler/Campbell"
            },
            "dramatic_function": {
              "type": "string",
              "description": "Cosa DEVE accadere strutturalmente in questo passo. Immutabile. Specifica per questa storia."
            },
            "emotional_tone": {
              "type": "string",
              "description": "Emozione dominante del passo (es. 'paura e meraviglia')"
            },
            "narrative_seeds": {
              "type": "array",
              "description": "2-3 elementi concreti su cui il Generatore di Passo può costruire la scena",
              "items": {
                "type": "string"
              }
            }
          },
          "required": ["number", "vogler_stage", "dramatic_function", "emotional_tone", "narrative_seeds"],
          "additionalProperties": false
        }
      },
      "initial_memory_state": {
        "type": "object",
        "description": "Fatti fondamentali già noti prima che la storia inizi a essere narrata",
        "properties": {
          "protagonist": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "description": { "type": "string" },
              "traits": {
                "type": "array",
                "items": { "type": "string" }
              }
            },
            "required": ["name", "description", "traits"],
            "additionalProperties": false
          },
          "secondary_characters": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": { "type": "string" },
                "role": { "type": "string" },
                "description": { "type": "string" }
              },
              "required": ["name", "role", "description"],
              "additionalProperties": false
            }
          },
          "locations": {
            "type": "array",
            "items": { "type": "string" }
          },
          "significant_objects": {
            "type": "array",
            "items": { "type": "string" }
          },
          "audience_choices": {
            "type": "array",
            "items": { "type": "string" }
          },
          "established_facts": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "required": ["protagonist", "secondary_characters", "locations", "significant_objects", "audience_choices", "established_facts"],
        "additionalProperties": false
      }
    },
    "required": ["story_title", "story_concept", "protagonist_archetype", "protagonist_description", "world_setting", "central_conflict", "steps", "initial_memory_state"],
    "additionalProperties": false
  }
}
